<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="using:DepotDL.GUI.Converters"
        xmlns:helpers="using:DepotDL.GUI.Helpers">

    <Styles.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceInclude Source="avares://DepotDL.GUI/Styles/LucideIcons.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
            <conv:BoolToVisibilityConverter x:Key="InvBoolToVis" Invert="True"/>
            <conv:InverseBoolConverter x:Key="InvBool"/>
            <conv:DepotStatusToColorConverter x:Key="StatusToColor"/>
            <conv:DepotStatusToTextConverter x:Key="StatusToText"/>
            <conv:PercentToWidthConverter x:Key="PctToWidth"/>
            <conv:StringEmptyToVisibilityConverter x:Key="EmptyToVis" ShowWhenEmpty="True"/>
            <conv:StringEmptyToVisibilityConverter x:Key="NotEmptyToVis" ShowWhenEmpty="False"/>
            <conv:EqualityToVisibilityConverter x:Key="EqToVis"/>
            <conv:EqualityToBoolConverter x:Key="EqToBool"/>
            <conv:SpecStatusToBrushConverter x:Key="SpecToColor"/>

            <Color x:Key="AccentColor">#C07840</Color>
            <Color x:Key="BgCardColor">#FEFCF8</Color>
            <Color x:Key="BorderColor">#DDD0C2</Color>

            <SolidColorBrush x:Key="BgPage"          Color="#F5F0E8"/>
            <SolidColorBrush x:Key="BgSidebar"       Color="#EDE6DB"/>
            <SolidColorBrush x:Key="BgCard"          Color="#FEFCF8"/>
            <SolidColorBrush x:Key="BgInput"         Color="#FFFFFF"/>
            <SolidColorBrush x:Key="Accent"          Color="#C07840"/>
            <SolidColorBrush x:Key="AccentDark"      Color="#A86332"/>
            <SolidColorBrush x:Key="AccentLight"     Color="#F0E0CE"/>
            <SolidColorBrush x:Key="AccentSubtle"    Color="#FAF0E6"/>
            <SolidColorBrush x:Key="AccentVeryLight" Color="#FAF0E6"/>
            <SolidColorBrush x:Key="TextH"           Color="#1C1610"/>
            <SolidColorBrush x:Key="TextPrimary"     Color="#1C1610"/>
            <SolidColorBrush x:Key="TextBody"        Color="#5A4E42"/>
            <SolidColorBrush x:Key="TextSecondary"   Color="#5A4E42"/>
            <SolidColorBrush x:Key="TextMuted"       Color="#9C8E82"/>
            <SolidColorBrush x:Key="Border"          Color="#DDD0C2"/>
            <SolidColorBrush x:Key="BorderFocus"     Color="#C07840"/>
            <SolidColorBrush x:Key="DlcBadgeBg"      Color="#EDE8F5"/>
            <SolidColorBrush x:Key="DlcBadgeFg"      Color="#6B4FA0"/>
            <SolidColorBrush x:Key="Success"         Color="#4A7C59"/>
            <SolidColorBrush x:Key="SuccessBg"       Color="#EAF4EE"/>
            <SolidColorBrush x:Key="SuccessLight"    Color="#EAF4EE"/>
            <SolidColorBrush x:Key="Error"           Color="#B83B2A"/>
            <SolidColorBrush x:Key="ErrorBg"         Color="#FDECEA"/>
            <SolidColorBrush x:Key="ErrorLight"      Color="#FDECEA"/>
            <SolidColorBrush x:Key="Warning"         Color="#C07012"/>
            <SolidColorBrush x:Key="WarningBg"       Color="#FEF3E2"/>

            <!-- ══ ScrollBar ════════════════════════════════════════════════════ -->
            <ControlTheme x:Key="{x:Type ScrollBar}" TargetType="ScrollBar">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="Width" Value="6"/>
                <Setter Property="MinWidth" Value="6"/>
                <Setter Property="AllowAutoHide" Value="False"/>
                <Setter Property="Template">
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid Background="{TemplateBinding Background}">
                            <Track Name="PART_Track"
                                   IsDirectionReversed="True"
                                   Minimum="{TemplateBinding Minimum}"
                                   Maximum="{TemplateBinding Maximum}"
                                   Value="{TemplateBinding Value, Mode=TwoWay}"
                                   ViewportSize="{TemplateBinding ViewportSize}"
                                   Orientation="{TemplateBinding Orientation}">
                                <Track.DecreaseButton>
                                    <RepeatButton Name="PART_PageUpButton" IsVisible="False" Focusable="False"/>
                                </Track.DecreaseButton>
                                <Track.IncreaseButton>
                                    <RepeatButton Name="PART_PageDownButton" IsVisible="False" Focusable="False"/>
                                </Track.IncreaseButton>
                                <Thumb Name="PART_Thumb" Background="{StaticResource Border}">
                                    <Thumb.Template>
                                        <ControlTemplate TargetType="Thumb">
                                            <Border CornerRadius="3"
                                                    Background="{TemplateBinding Background}"
                                                    Margin="1,2">
                                                <Border.Transitions>
                                                    <Transitions>
                                                        <BrushTransition Property="Background" Duration="0:0:0.12"/>
                                                    </Transitions>
                                                </Border.Transitions>
                                            </Border>
                                        </ControlTemplate>
                                    </Thumb.Template>
                                </Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter>
                <Style Selector="^:pointerover /template/ Thumb#PART_Thumb">
                    <Setter Property="Background" Value="{StaticResource TextMuted}"/>
                </Style>
            </ControlTheme>

            <!-- ══ CheckBox ════════════════════════════════════════════════════ -->
            <ControlTheme x:Key="{x:Type CheckBox}" TargetType="CheckBox">
                <Setter Property="Foreground" Value="{StaticResource TextBody}"/>
                <Setter Property="FontSize" Value="13"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Template">
                    <ControlTemplate TargetType="CheckBox">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Grid Width="17" Height="17">
                                <Border Name="boxBorder"
                                        CornerRadius="4"
                                        BorderThickness="1.5"
                                        Background="White"
                                        BorderBrush="{StaticResource Border}">
                                    <Border.Transitions>
                                        <Transitions>
                                            <BrushTransition Property="Background" Duration="0:0:0.15"/>
                                            <BrushTransition Property="BorderBrush" Duration="0:0:0.12"/>
                                        </Transitions>
                                    </Border.Transitions>
                                </Border>
                                <Path Name="tick"
                                      Data="{StaticResource LucideCheck}"
                                      Margin="3"
                                      Stretch="Uniform"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center"
                                      Stroke="White"
                                      StrokeThickness="1.8"
                                      StrokeLineCap="Round"
                                      StrokeJoin="Round"
                                      Fill="Transparent"
                                      Opacity="0"
                                      RenderTransformOrigin="0.5,0.5">
                                    <Path.Transitions>
                                        <Transitions>
                                            <DoubleTransition Property="Opacity" Duration="0:0:0.12"/>
                                            <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.2"/>
                                        </Transitions>
                                    </Path.Transitions>
                                </Path>
                            </Grid>
                            <ContentPresenter Name="PART_ContentPresenter" Margin="8,0,0,0" VerticalAlignment="Center"
                                              Content="{TemplateBinding Content}"
                                              ContentTemplate="{TemplateBinding ContentTemplate}"
                                              RecognizesAccessKey="True"/>
                        </StackPanel>
                    </ControlTemplate>
                </Setter>
                <Style Selector="^ /template/ Path#tick">
                    <Setter Property="RenderTransform" Value="scale(0,0)"/>
                </Style>
                <Style Selector="^:checked /template/ Border#boxBorder">
                    <Setter Property="Background" Value="{StaticResource Accent}"/>
                    <Setter Property="BorderBrush" Value="{StaticResource Accent}"/>
                </Style>
                <Style Selector="^:checked /template/ Path#tick">
                    <Setter Property="Opacity" Value="1"/>
                    <Setter Property="RenderTransform" Value="scale(1,1)"/>
                </Style>
                <Style Selector="^:pointerover:not(:checked) /template/ Border#boxBorder">
                    <Setter Property="BorderBrush" Value="{StaticResource Accent}"/>
                </Style>
            </ControlTheme>

            <!-- ══ Slider ════════════════════════════════════════════════════ -->
            <ControlTheme x:Key="SliderThumb" TargetType="Thumb">
                <Setter Property="Template">
                    <ControlTemplate TargetType="Thumb">
                        <Ellipse Name="e"
                                 Width="18" Height="18"
                                 Fill="{StaticResource Accent}"
                                 Stroke="White"
                                 StrokeThickness="2.5">
                            <Ellipse.Transitions>
                                <Transitions>
                                    <BrushTransition Property="Fill" Duration="0:0:0.1"/>
                                </Transitions>
                            </Ellipse.Transitions>
                        </Ellipse>
                    </ControlTemplate>
                </Setter>
                <Style Selector="^:pointerover /template/ Ellipse#e">
                    <Setter Property="Fill" Value="{StaticResource AccentDark}"/>
                </Style>
            </ControlTheme>

            <ControlTheme x:Key="{x:Type Slider}" TargetType="Slider">
                <Setter Property="IsSnapToTickEnabled" Value="True"/>
                <Setter Property="Template">
                    <ControlTemplate TargetType="Slider">
                        <DataValidationErrors>
                            <Grid VerticalAlignment="Center" Height="20">
                                <Track Name="PART_Track"
                                       Minimum="{TemplateBinding Minimum}"
                                       Maximum="{TemplateBinding Maximum}"
                                       Value="{TemplateBinding Value, Mode=TwoWay}"
                                       Orientation="{TemplateBinding Orientation}">
                                    <Track.DecreaseButton>
                                        <RepeatButton Name="PART_DecreaseButton" Focusable="False">
                                            <RepeatButton.Template>
                                                <ControlTemplate TargetType="RepeatButton">
                                                    <Border Height="4" CornerRadius="2"
                                                            Background="{StaticResource Accent}"
                                                            VerticalAlignment="Center"/>
                                                </ControlTemplate>
                                            </RepeatButton.Template>
                                        </RepeatButton>
                                    </Track.DecreaseButton>
                                    <Track.Thumb>
                                        <Thumb Name="PART_Thumb" Theme="{StaticResource SliderThumb}"/>
                                    </Track.Thumb>
                                    <Track.IncreaseButton>
                                        <RepeatButton Name="PART_IncreaseButton" Focusable="False">
                                            <RepeatButton.Template>
                                                <ControlTemplate TargetType="RepeatButton">
                                                    <Border Height="4" CornerRadius="2"
                                                            Background="{StaticResource Border}"
                                                            VerticalAlignment="Center"/>
                                                </ControlTemplate>
                                            </RepeatButton.Template>
                                        </RepeatButton>
                                    </Track.IncreaseButton>
                                </Track>
                            </Grid>
                        </DataValidationErrors>
                    </ControlTemplate>
                </Setter>
            </ControlTheme>

            <!-- ══ Button ControlThemes ════════════════════════════════════════ -->
            <ControlTheme x:Key="BtnPrimary" TargetType="Button">
                <Setter Property="Background" Value="{StaticResource Accent}"/>
                <Setter Property="Foreground" Value="White"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Padding" Value="20,10"/>
                <Setter Property="FontSize" Value="13"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="HorizontalAlignment" Value="Left"/>
                <Setter Property="Template">
                    <ControlTemplate TargetType="Button">
                        <Border Name="bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="9"
                                Padding="{TemplateBinding Padding}"
                                BoxShadow="0 3 14 0 #38C07840">
                            <Border.Transitions>
                                <Transitions>
                                    <BrushTransition Property="Background" Duration="0:0:0.12"/>
                                    <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.1"/>
                                </Transitions>
                            </Border.Transitions>
                            <ContentPresenter Name="PART_ContentPresenter"
                                              Content="{TemplateBinding Content}"
                                              ContentTemplate="{TemplateBinding ContentTemplate}"
                                              HorizontalAlignment="Center" VerticalAlignment="Center"
                                              HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}"/>
                        </Border>
                    </ControlTemplate>
                </Setter>
                <Style Selector="^:pointerover /template/ Border#bd">
                    <Setter Property="Background" Value="{StaticResource AccentDark}"/>
                </Style>
                <Style Selector="^:pressed /template/ Border#bd">
                    <Setter Property="RenderTransform" Value="scale(0.97)"/>
                </Style>
                <Style Selector="^:disabled">
                    <Setter Property="Opacity" Value="0.4"/>
                </Style>
            </ControlTheme>

            <ControlTheme x:Key="BtnSecondary" TargetType="Button">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="Foreground" Value="{StaticResource TextBody}"/>
                <Setter Property="BorderBrush" Value="{StaticResource Border}"/>
                <Setter Property="BorderThickness" Value="1.5"/>
                <Setter Property="Padding" Value="16,8"/>
                <Setter Property="FontSize" Value="13"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="HorizontalAlignment" Value="Left"/>
                <Setter Property="Template">
                    <ControlTemplate TargetType="Button">
                        <Border Name="bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="9"
                                Padding="{TemplateBinding Padding}">
                            <Border.Transitions>
                                <Transitions>
                                    <BrushTransition Property="Background" Duration="0:0:0.12"/>
                                    <BrushTransition Property="BorderBrush" Duration="0:0:0.12"/>
                                </Transitions>
                            </Border.Transitions>
                            <ContentPresenter Name="PART_ContentPresenter"
                                              Content="{TemplateBinding Content}"
                                              ContentTemplate="{TemplateBinding ContentTemplate}"
                                              HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter>
                <Style Selector="^:pointerover /template/ Border#bd">
                    <Setter Property="Background" Value="{StaticResource BgCard}"/>
                    <Setter Property="BorderBrush" Value="{StaticResource TextMuted}"/>
                </Style>
                <Style Selector="^:disabled">
                    <Setter Property="Opacity" Value="0.4"/>
                </Style>
            </ControlTheme>

            <ControlTheme x:Key="BtnDanger" TargetType="Button">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="Foreground" Value="{StaticResource Error}"/>
                <Setter Property="BorderBrush" Value="#EBC5C1"/>
                <Setter Property="BorderThickness" Value="1.5"/>
                <Setter Property="Padding" Value="14,7"/>
                <Setter Property="FontSize" Value="12"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="HorizontalAlignment" Value="Left"/>
                <Setter Property="Template">
                    <ControlTemplate TargetType="Button">
                        <Border Name="bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <Border.Transitions>
                                <Transitions>
                                    <BrushTransition Property="Background" Duration="0:0:0.12"/>
                                </Transitions>
                            </Border.Transitions>
                            <ContentPresenter Name="PART_ContentPresenter"
                                              Content="{TemplateBinding Content}"
                                              ContentTemplate="{TemplateBinding ContentTemplate}"
                                              HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter>
                <Style Selector="^:pointerover /template/ Border#bd">
                    <Setter Property="Background" Value="{StaticResource ErrorBg}"/>
                </Style>
            </ControlTheme>

            <ControlTheme x:Key="BtnGhost" TargetType="Button">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="Foreground" Value="{StaticResource TextBody}"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Padding" Value="10,6"/>
                <Setter Property="FontSize" Value="12"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="HorizontalAlignment" Value="Left"/>
                <Setter Property="Template">
                    <ControlTemplate TargetType="Button">
                        <Border Name="bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <Border.Transitions>
                                <Transitions>
                                    <BrushTransition Property="Background" Duration="0:0:0.12"/>
                                </Transitions>
                            </Border.Transitions>
                            <ContentPresenter Name="PART_ContentPresenter"
                                              Content="{TemplateBinding Content}"
                                              ContentTemplate="{TemplateBinding ContentTemplate}"
                                              HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter>
                <Style Selector="^:pointerover /template/ Border#bd">
                    <Setter Property="Background" Value="{StaticResource Border}"/>
                </Style>
            </ControlTheme>

            <!-- ══ BtnPill (ToggleButton) ════════════════════════════════════ -->
            <ControlTheme x:Key="BtnPill" TargetType="ToggleButton">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
                <Setter Property="BorderBrush" Value="{StaticResource Border}"/>
                <Setter Property="BorderThickness" Value="1.5"/>
                <Setter Property="Padding" Value="11,5"/>
                <Setter Property="FontSize" Value="11.5"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Margin" Value="0,0,6,6"/>
                <Setter Property="HorizontalAlignment" Value="Left"/>
                <Setter Property="Template">
                    <ControlTemplate TargetType="ToggleButton">
                        <Border Name="bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="20"
                                Padding="{TemplateBinding Padding}">
                            <Border.Transitions>
                                <Transitions>
                                    <BrushTransition Property="Background" Duration="0:0:0.12"/>
                                    <BrushTransition Property="BorderBrush" Duration="0:0:0.12"/>
                                </Transitions>
                            </Border.Transitions>
                            <ContentPresenter Name="PART_ContentPresenter"
                                              Content="{TemplateBinding Content}"
                                              ContentTemplate="{TemplateBinding ContentTemplate}"
                                              HorizontalAlignment="Center" VerticalAlignment="Center"
                                              TextElement.Foreground="{TemplateBinding Foreground}"/>
                        </Border>
                    </ControlTemplate>
                </Setter>
                <Style Selector="^:checked /template/ Border#bd">
                    <Setter Property="Background" Value="{StaticResource Accent}"/>
                    <Setter Property="BorderBrush" Value="{StaticResource Accent}"/>
                </Style>
                <Style Selector="^:checked">
                    <Setter Property="Foreground" Value="White"/>
                </Style>
                <Style Selector="^:pointerover:not(:checked) /template/ Border#bd">
                    <Setter Property="Background" Value="{StaticResource AccentVeryLight}"/>
                    <Setter Property="BorderBrush" Value="{StaticResource Accent}"/>
                </Style>
            </ControlTheme>

        </ResourceDictionary>
    </Styles.Resources>

    <!-- ══ TextBlock class-based styles ════════════════════════════════════ -->
    <Style Selector="TextBlock.TextH1">
        <Setter Property="FontSize" Value="28"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{StaticResource TextH}"/>
        <Setter Property="LineHeight" Value="36"/>
    </Style>
    <Style Selector="TextBlock.H1">
        <Setter Property="FontSize" Value="28"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{StaticResource TextH}"/>
        <Setter Property="LineHeight" Value="36"/>
    </Style>
    <Style Selector="TextBlock.TextH2">
        <Setter Property="FontSize" Value="20"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{StaticResource TextH}"/>
    </Style>
    <Style Selector="TextBlock.H2">
        <Setter Property="FontSize" Value="20"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{StaticResource TextH}"/>
    </Style>
    <Style Selector="TextBlock.TextH3">
        <Setter Property="FontSize" Value="15"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{StaticResource TextH}"/>
    </Style>
    <Style Selector="TextBlock.H3">
        <Setter Property="FontSize" Value="15"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{StaticResource TextH}"/>
    </Style>
    <Style Selector="TextBlock.BodyText">
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Foreground" Value="{StaticResource TextBody}"/>
        <Setter Property="LineHeight" Value="20"/>
    </Style>
    <Style Selector="TextBlock.TextBodyStyle">
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Foreground" Value="{StaticResource TextBody}"/>
        <Setter Property="LineHeight" Value="20"/>
    </Style>
    <Style Selector="TextBlock.Caption">
        <Setter Property="FontSize" Value="11"/>
        <Setter Property="Foreground" Value="{StaticResource TextMuted}"/>
    </Style>
    <Style Selector="TextBlock.TextLabel">
        <Setter Property="FontSize" Value="10.5"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{StaticResource TextMuted}"/>
        <Setter Property="Margin" Value="0,0,0,5"/>
    </Style>
    <Style Selector="TextBlock.Label">
        <Setter Property="FontSize" Value="10.5"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{StaticResource TextMuted}"/>
        <Setter Property="Margin" Value="0,0,0,5"/>
    </Style>
    <Style Selector="TextBlock.Mono">
        <Setter Property="FontFamily" Value="Consolas"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="Foreground" Value="{StaticResource TextBody}"/>
    </Style>

    <!-- ══ Border class-based styles ════════════════════════════════════ -->
    <Style Selector="Border.Card">
        <Setter Property="Background" Value="{StaticResource BgCard}"/>
        <Setter Property="CornerRadius" Value="14"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="BorderBrush" Value="{StaticResource Border}"/>
    </Style>
    <Style Selector="Border.CardFlat">
        <Setter Property="Background" Value="{StaticResource BgCard}"/>
        <Setter Property="CornerRadius" Value="10"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="BorderBrush" Value="{StaticResource Border}"/>
    </Style>
    <Style Selector="Border.CardSmall">
        <Setter Property="Background" Value="{StaticResource BgCard}"/>
        <Setter Property="CornerRadius" Value="10"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="BorderBrush" Value="{StaticResource Border}"/>
    </Style>
    <Style Selector="Border.Pill">
        <Setter Property="CornerRadius" Value="20"/>
        <Setter Property="Padding" Value="10,4"/>
    </Style>
    <Style Selector="Border.StatusPill">
        <Setter Property="CornerRadius" Value="6"/>
        <Setter Property="Padding" Value="8,3"/>
    </Style>
    <Style Selector="Border.DepotListItem">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="CornerRadius" Value="8"/>
        <Setter Property="Padding" Value="10,8"/>
        <Setter Property="Margin" Value="0,2"/>
    </Style>

    <!-- ══ ScrollViewer global style ════════════════════════════════════ -->
    <Style Selector="ScrollViewer">
        <Setter Property="VerticalScrollBarVisibility" Value="Auto"/>
        <Setter Property="HorizontalScrollBarVisibility" Value="Disabled"/>
        <Setter Property="helpers:SmoothScroll.IsEnabled" Value="True"/>
    </Style>

    <!-- ══ Separator ════════════════════════════════════════════════════ -->
    <Style Selector="Separator">
        <Setter Property="Background" Value="{StaticResource Border}"/>
        <Setter Property="Height" Value="1"/>
        <Setter Property="Margin" Value="0,12"/>
    </Style>

    <!-- ══ TextBox ════════════════════════════════════════════════════ -->
    <Style Selector="TextBox">
        <Setter Property="Background" Value="{StaticResource BgInput}"/>
        <Setter Property="Foreground" Value="{StaticResource TextH}"/>
        <Setter Property="BorderBrush" Value="{StaticResource Border}"/>
        <Setter Property="BorderThickness" Value="1.5"/>
        <Setter Property="Padding" Value="10,6"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="CornerRadius" Value="8"/>
        <Setter Property="CaretBrush" Value="{StaticResource Accent}"/>
        <Setter Property="SelectionBrush" Value="{StaticResource AccentLight}"/>
        <Setter Property="Transitions">
            <Transitions>
                <BrushTransition Property="BorderBrush" Duration="0:0:0.12"/>
            </Transitions>
        </Setter>
    </Style>
    <Style Selector="TextBox:focus-within">
        <Setter Property="BorderBrush" Value="{StaticResource BorderFocus}"/>
    </Style>
    <Style Selector="TextBox:pointerover">
        <Setter Property="BorderBrush" Value="{StaticResource TextMuted}"/>
    </Style>

</Styles>
