<UserControl x:Class="DepotDL.GUI.Views.LibraryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:DepotDL.GUI.ViewModels"
             FontFamily="Segoe UI">

    <Grid>
    <Grid Margin="32,28,32,28">
        <Grid.Resources>
            <Style x:Key="PremiumRefreshBtn" TargetType="Button">
                <Setter Property="Background" Value="{StaticResource AccentSubtle}"/>
                <Setter Property="Foreground" Value="{StaticResource Accent}"/>
                <Setter Property="BorderBrush" Value="{StaticResource Accent}"/>
                <Setter Property="BorderThickness" Value="1.2"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="border"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="16" Padding="14,6">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Center">
                                    <Viewbox x:Name="iconBox" Width="14" Height="14" Margin="0,0,6,0" RenderTransformOrigin="0.5,0.5">
                                        <Viewbox.RenderTransform>
                                            <RotateTransform x:Name="rotator" Angle="0"/>
                                        </Viewbox.RenderTransform>
                                        <Canvas Width="24" Height="24">
                                            <Path Data="M21,12 A9,9 0 1,1 12,3 C14.52,3 16.93,4 18.74,5.74 L21,8 M21,3 L21,8 L16,8"
                                                  Stroke="{StaticResource Accent}"
                                                  StrokeThickness="1.7"
                                                  StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                                  StrokeLineJoin="Round"
                                                  Fill="Transparent"/>
                                        </Canvas>
                                    </Viewbox>
                                    <TextBlock Text="Refresh Sizes" FontSize="11.5" FontWeight="SemiBold"
                                               Foreground="{StaticResource Accent}" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Trigger.EnterActions>
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetName="rotator"
                                                                 Storyboard.TargetProperty="Angle"
                                                                 To="360" Duration="0:0:0.65">
                                                    <DoubleAnimation.EasingFunction>
                                                        <QuadraticEase EasingMode="EaseInOut"/>
                                                    </DoubleAnimation.EasingFunction>
                                                </DoubleAnimation>
                                                <ColorAnimation Storyboard.TargetName="border"
                                                                Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                                                To="#F2D5BF" Duration="0:0:0.2"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </Trigger.EnterActions>
                                    <Trigger.ExitActions>
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetName="rotator"
                                                                 Storyboard.TargetProperty="Angle"
                                                                 To="0" Duration="0:0:0.45">
                                                    <DoubleAnimation.EasingFunction>
                                                        <QuadraticEase EasingMode="EaseInOut"/>
                                                    </DoubleAnimation.EasingFunction>
                                                </DoubleAnimation>
                                                <ColorAnimation Storyboard.TargetName="border"
                                                                Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                                                To="#FAF0E6" Duration="0:0:0.2"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </Trigger.ExitActions>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter Property="Opacity" Value="0.8"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
            <Style x:Key="ModernContextMenu" TargetType="ContextMenu">
                <Setter Property="Background" Value="#FEFCF8"/>
                <Setter Property="BorderBrush" Value="#DDD0C2"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="Padding" Value="4,4"/>
                <Setter Property="HasDropShadow" Value="False"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ContextMenu">
                            <Border Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="8">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="12" ShadowDepth="2" Opacity="0.15" Color="#1C1610"/>
                                </Border.Effect>
                                <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Cycle"/>
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="ModernMenuItem" TargetType="MenuItem">
                <Setter Property="Padding" Value="14,8"/>
                <Setter Property="FontSize" Value="12"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="MenuItem">
                            <Border x:Name="Bg" Background="{TemplateBinding Background}" CornerRadius="5" Margin="2,1">
                                <ContentPresenter ContentSource="Header" Margin="{TemplateBinding Padding}"
                                                  RecognizesAccessKey="True" VerticalAlignment="Center"
                                                  TextElement.Foreground="{TemplateBinding Foreground}"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsHighlighted" Value="True">
                                    <Setter TargetName="Bg" Property="Background" Value="#F0E0CE"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </Grid.Resources>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="20"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
                <TextBlock Style="{StaticResource TextH1}" Text="My Library"/>
                <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                    <TextBlock Style="{StaticResource BodyText}"
                               Text="{Binding GameCount, StringFormat={}{0} game(s)}"
                               Visibility="{Binding GameCount, Converter={StaticResource NotEmptyToVis}}"/>
                    <TextBlock Style="{StaticResource BodyText}"
                               Margin="8,0,0,0"
                               Foreground="{StaticResource TextMuted}"
                               Visibility="{Binding TotalSizeText, Converter={StaticResource NotEmptyToVis}}">
                        <Run Text="·  "/>
                        <Run Text="{Binding TotalSizeText}"/>
                    </TextBlock>
                </StackPanel>
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,96,0">
                <Button Style="{StaticResource PremiumRefreshBtn}"
                        Command="{Binding RefreshSizesCommand}"/>
            </StackPanel>
        </Grid>

        <Border Grid.Row="2"
                Background="{StaticResource BgCard}"
                BorderBrush="{StaticResource Border}"
                BorderThickness="1"
                CornerRadius="10">
            <Grid Margin="12,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Viewbox Grid.Column="0" Width="15" Height="15" Margin="0,0,10,0">
                    <Canvas Width="24" Height="24">
                        <Ellipse Canvas.Left="3" Canvas.Top="3" Width="14" Height="14"
                                 Stroke="{StaticResource TextMuted}" StrokeThickness="2"/>
                        <Path Data="M15,15 L21,21"
                              Stroke="{StaticResource TextMuted}"
                              StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                    </Canvas>
                </Viewbox>
                <TextBox Grid.Column="1"
                         BorderThickness="0"
                         Background="Transparent"
                         Padding="0,10"
                         FontSize="13"
                         Foreground="{StaticResource TextPrimary}"
                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                         CaretBrush="{StaticResource Accent}">
                    <TextBox.Template>
                        <ControlTemplate TargetType="TextBox">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="Center"/>
                        </ControlTemplate>
                    </TextBox.Template>
                </TextBox>
            </Grid>
        </Border>

        <Grid Grid.Row="4">

            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                        Visibility="{Binding IsEmpty, Converter={StaticResource BoolToVis}}">
                <Border Width="64" Height="64"
                        CornerRadius="16"
                        Background="{StaticResource AccentVeryLight}"
                        HorizontalAlignment="Center"
                        Margin="0,0,0,16">
                    <Viewbox Width="28" Height="28">
                        <Canvas Width="24" Height="24">
                            <Path Data="M4,6 L20,6 M4,12 L20,12 M4,18 L12,18"
                                  Stroke="{StaticResource Accent}"
                                  StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                        </Canvas>
                    </Viewbox>
                </Border>
                <TextBlock Text="No games yet"
                           Style="{StaticResource TextH3}"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,6"/>
                <TextBlock Text="Download a game to see it here."
                           Style="{StaticResource BodyText}"
                           HorizontalAlignment="Center"/>
            </StackPanel>

            <ScrollViewer Visibility="{Binding IsEmpty, Converter={StaticResource InvBoolToVis}}"
                          VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding Games}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type vm:LibraryGameViewModel}">
                            <Border Visibility="{Binding IsVisible, Converter={StaticResource BoolToVis}}"
                                    Margin="0,0,14,14"
                                    Width="260">
                                <Border Style="{StaticResource Card}"
                                        Padding="0"
                                        ClipToBounds="True"
                                        Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=ItemsControl}}">
                                    <Border.RenderTransform>
                                        <TranslateTransform/>
                                    </Border.RenderTransform>
                                    <Border.ContextMenu>
                                        <ContextMenu Style="{StaticResource ModernContextMenu}">
                                            <MenuItem Header="Open Download Folder"
                                                      Style="{StaticResource ModernMenuItem}"
                                                      Command="{Binding Path=PlacementTarget.Tag.OpenFolderCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                      CommandParameter="{Binding Path=PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                            <Separator Margin="6,3" Background="#E8DDD2"/>
                                            <MenuItem Header="Validate Files"
                                                      Style="{StaticResource ModernMenuItem}"
                                                      Command="{Binding Path=PlacementTarget.Tag.ValidateFilesCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                      CommandParameter="{Binding Path=PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                            <MenuItem Header="Redownload"
                                                      Style="{StaticResource ModernMenuItem}"
                                                      Command="{Binding Path=PlacementTarget.Tag.ConfirmRedownloadCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                      CommandParameter="{Binding Path=PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                            <MenuItem Header="Pack"
                                                      Style="{StaticResource ModernMenuItem}"
                                                      Command="{Binding Path=PlacementTarget.Tag.PackGameCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                      CommandParameter="{Binding Path=PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                            <Separator Margin="6,3" Background="#E8DDD2"/>
                                            <MenuItem Header="Remove from Library"
                                                      Style="{StaticResource ModernMenuItem}"
                                                      Foreground="#B83B2A"
                                                      Command="{Binding Path=PlacementTarget.Tag.ConfirmRemoveCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                      CommandParameter="{Binding Path=PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                        </ContextMenu>
                                    </Border.ContextMenu>
                                    <Border.Triggers>
                                        <EventTrigger RoutedEvent="MouseEnter">
                                            <BeginStoryboard>
                                                <Storyboard>
                                                    <DoubleAnimation
                                                        Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                                                        To="-3" Duration="0:0:0.15">
                                                        <DoubleAnimation.EasingFunction>
                                                            <CubicEase EasingMode="EaseOut"/>
                                                        </DoubleAnimation.EasingFunction>
                                                    </DoubleAnimation>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </EventTrigger>
                                        <EventTrigger RoutedEvent="MouseLeave">
                                            <BeginStoryboard>
                                                <Storyboard>
                                                    <DoubleAnimation
                                                        Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                                                        To="0" Duration="0:0:0.15">
                                                        <DoubleAnimation.EasingFunction>
                                                            <CubicEase EasingMode="EaseOut"/>
                                                        </DoubleAnimation.EasingFunction>
                                                    </DoubleAnimation>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </EventTrigger>
                                    </Border.Triggers>

                                    <Grid>
                                        <!-- Header image (ImageBrush respects CornerRadius) -->
                                        <Border Height="103" VerticalAlignment="Top"
                                                CornerRadius="13,13,0,0">
                                            <Border.Background>
                                                <ImageBrush ImageSource="{Binding HeaderImage}" Stretch="UniformToFill"/>
                                            </Border.Background>
                                        </Border>

                                        <!-- Shimmer placeholder -->
                                        <Border Height="103" VerticalAlignment="Top"
                                                CornerRadius="13,13,0,0"
                                                Background="{StaticResource AccentLight}">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsImageLoading}" Value="True">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <Border.Triggers>
                                                <EventTrigger RoutedEvent="Border.Loaded">
                                                    <BeginStoryboard>
                                                        <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                                            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                             From="0.4" To="0.85" Duration="0:0:0.8"/>
                                                        </Storyboard>
                                                    </BeginStoryboard>
                                                </EventTrigger>
                                            </Border.Triggers>
                                        </Border>

                                        <!-- Content below image -->
                                        <Border Margin="0,103,0,0" Padding="14,10,14,14">
                                        <StackPanel>

                                            <Grid Margin="0,0,0,4">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>

                                                <TextBlock Grid.Column="0"
                                                           Text="{Binding Game.GameName}"
                                                           FontSize="13.5" FontWeight="SemiBold"
                                                           Foreground="{StaticResource TextPrimary}"
                                                           TextTrimming="CharacterEllipsis"/>

                                                <Border Grid.Column="1"
                                                        Style="{StaticResource StatusPill}"
                                                        Background="{StaticResource SuccessLight}"
                                                        Visibility="{Binding Game.IsVerified, Converter={StaticResource BoolToVis}}">
                                                    <TextBlock Text="✓" FontSize="10"
                                                               Foreground="{StaticResource Success}"
                                                               FontWeight="SemiBold"/>
                                                </Border>
                                                <Border Grid.Column="1"
                                                        Style="{StaticResource StatusPill}"
                                                        Background="{StaticResource ErrorLight}"
                                                        Visibility="{Binding Game.IsVerified, Converter={StaticResource InvBoolToVis}}">
                                                    <TextBlock Text="Missing" FontSize="10"
                                                               Foreground="{StaticResource Error}"/>
                                                </Border>
                                            </Grid>

                                            <TextBlock Margin="0,0,0,10"
                                                       FontSize="11"
                                                       Foreground="{StaticResource TextMuted}">
                                                <Run Text="AppID "/>
                                                <Run Text="{Binding Game.AppId}" FontFamily="Consolas"/>
                                            </TextBlock>

                                            <Grid Margin="0,0,0,10">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>

                                                <StackPanel Grid.Column="0">
                                                    <TextBlock Text="SIZE" Style="{StaticResource TextLabel}"/>
                                                    <TextBlock Text="{Binding SizeText}"
                                                               FontSize="12" FontWeight="SemiBold"
                                                               Foreground="{StaticResource TextPrimary}"
                                                               Margin="0,2,0,0"/>
                                                </StackPanel>

                                                <StackPanel Grid.Column="1">
                                                    <TextBlock Text="ADDED" Style="{StaticResource TextLabel}"/>
                                                    <TextBlock Text="{Binding InstallDateText}"
                                                               FontSize="11.5" FontWeight="SemiBold"
                                                               Foreground="{StaticResource TextPrimary}"
                                                               Margin="0,2,0,0"/>
                                                </StackPanel>
                                            </Grid>
                                            <Button Style="{StaticResource BtnPrimary}"
                                                    Padding="12,8"
                                                    HorizontalAlignment="Stretch"
                                                    IsEnabled="{Binding FolderExists}"
                                                    Command="{Binding DataContext.LaunchGameCommand,
                                                              RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                    CommandParameter="{Binding}">
                                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                    <Viewbox Width="12" Height="12" Margin="0,0,6,0">
                                                        <Canvas Width="24" Height="24">
                                                            <Path Data="M8,5 L19,12 L8,19 Z" Fill="White"/>
                                                        </Canvas>
                                                    </Viewbox>
                                                    <TextBlock Text="Play" FontSize="12.5"
                                                               FontWeight="SemiBold"
                                                               Foreground="White"/>
                                                </StackPanel>
                                            </Button>
                                        </StackPanel>
                                        </Border>
                                    </Grid>
                                </Border>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>
    </Grid>

    <!-- ══ Redownload confirmation overlay ══════════════════════════ -->
    <Grid x:Name="RedownloadOverlayRoot" Panel.ZIndex="50" Opacity="0"
          IsHitTestVisible="{Binding IsRedownloadOverlayVisible}">
        <Grid.Style>
            <Style TargetType="Grid">
                <Style.Triggers>
                    <DataTrigger Binding="{Binding IsRedownloadOverlayVisible}" Value="True">
                        <DataTrigger.EnterActions>
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                     To="1" Duration="0:0:0.18">
                                        <DoubleAnimation.EasingFunction>
                                            <CubicEase EasingMode="EaseOut"/>
                                        </DoubleAnimation.EasingFunction>
                                    </DoubleAnimation>
                                </Storyboard>
                            </BeginStoryboard>
                        </DataTrigger.EnterActions>
                        <DataTrigger.ExitActions>
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                     To="0" Duration="0:0:0.14"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </DataTrigger.ExitActions>
                    </DataTrigger>
                </Style.Triggers>
            </Style>
        </Grid.Style>

        <Rectangle Fill="#1C1610" Opacity="0.72">
            <Rectangle.InputBindings>
                <MouseBinding MouseAction="LeftClick" Command="{Binding CancelRedownloadCommand}"/>
            </Rectangle.InputBindings>
        </Rectangle>

        <Border Width="420"
                HorizontalAlignment="Center" VerticalAlignment="Center"
                Background="{StaticResource BgCard}"
                BorderBrush="{StaticResource Border}"
                BorderThickness="1"
                CornerRadius="16"
                Padding="28">
            <Border.RenderTransform>
                <TranslateTransform/>
            </Border.RenderTransform>
            <Border.Style>
                <Style TargetType="Border">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsRedownloadOverlayVisible}" Value="True">
                            <DataTrigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation
                                            Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                                            From="20" To="0" Duration="0:0:0.22">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </DataTrigger.EnterActions>
                            <DataTrigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation
                                            Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                                            To="12" Duration="0:0:0.14">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseIn"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </DataTrigger.ExitActions>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>

            <StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                    <Border Width="36" Height="36" CornerRadius="10"
                            Background="{StaticResource AccentSubtle}"
                            Margin="0,0,12,0">
                        <Viewbox Width="16" Height="16">
                            <Canvas Width="24" Height="24">
                                <Path Data="M21,12 A9,9 0 1,1 12,3 C14.52,3 16.93,4 18.74,5.74 L21,8 M21,3 L21,8 L16,8"
                                      Stroke="{StaticResource Accent}"
                                      StrokeThickness="1.8" Fill="Transparent"
                                      StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                      StrokeLineJoin="Round"/>
                            </Canvas>
                        </Viewbox>
                    </Border>
                    <TextBlock Text="Redownload Game"
                               FontSize="17" FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimary}"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <TextBlock Text="{Binding GameToRedownload.Game.GameName}"
                           FontSize="13" FontWeight="SemiBold"
                           Foreground="{StaticResource Accent}"
                           Margin="0,0,0,6"
                           TextTrimming="CharacterEllipsis"/>

                <TextBlock Text="All existing game files will be deleted and the game will be re-downloaded from scratch."
                           FontSize="13" Foreground="{StaticResource TextBody}"
                           TextWrapping="Wrap" Margin="0,0,0,20"/>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0"
                            Content="Cancel"
                            Command="{Binding CancelRedownloadCommand}"
                            Style="{StaticResource BtnGhost}"
                            Padding="12,10" FontSize="12" FontWeight="SemiBold"/>
                    <Button Grid.Column="2"
                            Content="Redownload"
                            Command="{Binding DoRedownloadCommand}"
                            Style="{StaticResource BtnPrimary}"
                            Padding="12,10" FontSize="12" FontWeight="SemiBold"/>
                </Grid>
            </StackPanel>
        </Border>
    </Grid>

        <!-- ══ Remove-game confirmation overlay ══════════════════════════ -->
        <Grid x:Name="RemoveOverlayRoot" Panel.ZIndex="50" Opacity="0"
              IsHitTestVisible="{Binding IsRemoveOverlayVisible}">
            <Grid.Style>
                <Style TargetType="Grid">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsRemoveOverlayVisible}" Value="True">
                            <DataTrigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                         To="1" Duration="0:0:0.18">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </DataTrigger.EnterActions>
                            <DataTrigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                         To="0" Duration="0:0:0.14"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </DataTrigger.ExitActions>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Grid.Style>

            <!-- Backdrop -->
            <Rectangle Fill="#1C1610" Opacity="0.72">
                <Rectangle.InputBindings>
                    <MouseBinding MouseAction="LeftClick" Command="{Binding CancelRemoveCommand}"/>
                </Rectangle.InputBindings>
            </Rectangle>

            <!-- Dialog card -->
            <Border Width="420"
                    HorizontalAlignment="Center" VerticalAlignment="Center"
                    Background="{StaticResource BgCard}"
                    BorderBrush="{StaticResource Border}"
                    BorderThickness="1"
                    CornerRadius="16"
                    Padding="28">
                <Border.RenderTransform>
                    <TranslateTransform/>
                </Border.RenderTransform>
                <Border.Style>
                    <Style TargetType="Border">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsRemoveOverlayVisible}" Value="True">
                                <DataTrigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation
                                                Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                                                From="20" To="0" Duration="0:0:0.22">
                                                <DoubleAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseOut"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </DataTrigger.EnterActions>
                                <DataTrigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation
                                                Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                                                To="12" Duration="0:0:0.14">
                                                <DoubleAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseIn"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </DataTrigger.ExitActions>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>

                <StackPanel>
                    <!-- Icon + title -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <Border Width="36" Height="36" CornerRadius="10"
                                Background="{StaticResource ErrorLight}"
                                Margin="0,0,12,0">
                            <Viewbox Width="16" Height="16">
                                <Canvas Width="24" Height="24">
                                    <Path Data="M3,6 L21,6 M8,6 L8,4 L16,4 L16,6 M19,6 L18,20 A1,1,0,0,1,17,21 L7,21 A1,1,0,0,1,6,20 L5,6"
                                          Stroke="{StaticResource Error}"
                                          StrokeThickness="1.8" Fill="Transparent"
                                          StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                                </Canvas>
                            </Viewbox>
                        </Border>
                        <TextBlock Text="Remove Game"
                                   FontSize="17" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimary}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- Game name -->
                    <TextBlock Text="{Binding GameToRemove.Game.GameName}"
                               FontSize="13" FontWeight="SemiBold"
                               Foreground="{StaticResource Accent}"
                               Margin="0,0,0,6"
                               TextTrimming="CharacterEllipsis"/>

                    <!-- Message -->
                    <TextBlock Text="Remove this game from your library?"
                               FontSize="13" Foreground="{StaticResource TextBody}"
                               TextWrapping="Wrap" Margin="0,0,0,16"/>

                    <!-- Delete files checkbox -->
                    <Border Background="{StaticResource BgInput}"
                            BorderBrush="{StaticResource Border}"
                            BorderThickness="1" CornerRadius="8"
                            Padding="12,10" Margin="0,0,0,20">
                        <CheckBox IsChecked="{Binding DeleteFiles}" Cursor="Hand">
                            <CheckBox.Template>
                                <ControlTemplate TargetType="CheckBox">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.Column="0"
                                                Width="18" Height="18"
                                                BorderBrush="{StaticResource Border}"
                                                BorderThickness="1.5"
                                                CornerRadius="4"
                                                Margin="0,0,10,0">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="Transparent"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsChecked, RelativeSource={RelativeSource AncestorType=CheckBox}}" Value="True">
                                                            <Setter Property="Background" Value="{StaticResource Accent}"/>
                                                            <Setter Property="BorderBrush" Value="{StaticResource Accent}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock Text="✓" FontSize="12" FontWeight="Bold"
                                                       Foreground="White"
                                                       VerticalAlignment="Center"
                                                       HorizontalAlignment="Center">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsChecked, RelativeSource={RelativeSource AncestorType=CheckBox}}" Value="True">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Border>
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Text="Also delete all game files"
                                                       FontSize="13" FontWeight="SemiBold"
                                                       Foreground="{StaticResource TextPrimary}"/>
                                            <TextBlock Text="This cannot be undone"
                                                       FontSize="11" Foreground="{StaticResource TextMuted}"
                                                       Margin="0,2,0,0"/>
                                        </StackPanel>
                                    </Grid>
                                </ControlTemplate>
                            </CheckBox.Template>
                        </CheckBox>
                    </Border>

                    <!-- Buttons -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0"
                                Content="Cancel"
                                Command="{Binding CancelRemoveCommand}"
                                Style="{StaticResource BtnGhost}"
                                Padding="12,10" FontSize="12" FontWeight="SemiBold"/>
                        <Button Grid.Column="2"
                                Content="Remove"
                                Command="{Binding DoRemoveCommand}"
                                Style="{StaticResource BtnDanger}"
                                Padding="12,10" FontSize="12" FontWeight="SemiBold"/>
                    </Grid>
                </StackPanel>
            </Border>
        </Grid>

    </Grid>
</UserControl>
