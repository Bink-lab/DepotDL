<UserControl x:Class="DepotDL.GUI.Views.LibraryView"
             xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:DepotDL.GUI.ViewModels">

    <UserControl.Resources>

        <ControlTheme x:Key="PremiumRefreshBtn" TargetType="Button">
            <Setter Property="Background"    Value="{StaticResource AccentSubtle}"/>
            <Setter Property="Foreground"    Value="{StaticResource Accent}"/>
            <Setter Property="BorderBrush"   Value="{StaticResource Accent}"/>
            <Setter Property="BorderThickness" Value="1.2"/>
            <Setter Property="Cursor"        Value="Hand"/>
            <Setter Property="Template">
                <ControlTemplate>
                    <Border x:Name="border"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="16" Padding="14,6">
                        <Border.Transitions>
                            <Transitions>
                                <BrushTransition Property="Background" Duration="0:0:0.2"/>
                            </Transitions>
                        </Border.Transitions>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Center">
                            <Border x:Name="iconBox" Width="14" Height="14" Margin="0,0,6,0"
                                    Background="Transparent"
                                    RenderTransformOrigin="50%,50%">
                                <Border.RenderTransform>
                                    <RotateTransform/>
                                </Border.RenderTransform>
                                <Path Data="{StaticResource LucideRotateCw}"
                                      Width="14" Height="14" Stretch="Uniform"
                                      Stroke="{StaticResource Accent}" StrokeThickness="1.7"
                                      StrokeLineCap="Round" StrokeJoin="Round"
                                      Fill="Transparent"/>
                            </Border>
                            <TextBlock Text="Refresh Sizes" FontSize="11.5" FontWeight="SemiBold"
                                       Foreground="{StaticResource Accent}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </ControlTemplate>
            </Setter>
            <Style Selector="^:pointerover /template/ Border#border">
                <Setter Property="Background" Value="#F2D5BF"/>
            </Style>
            <Style Selector="^:pointerover /template/ Border#iconBox">
                <Style.Animations>
                    <Animation Duration="0:0:0.9" IterationCount="Infinite" Easing="LinearEasing">
                        <KeyFrame Cue="0%">
                            <Setter Property="RotateTransform.Angle" Value="0"/>
                        </KeyFrame>
                        <KeyFrame Cue="100%">
                            <Setter Property="RotateTransform.Angle" Value="360"/>
                        </KeyFrame>
                    </Animation>
                </Style.Animations>
            </Style>
            <Style Selector="^:pressed">
                <Setter Property="Opacity" Value="0.8"/>
            </Style>
        </ControlTheme>

        <ControlTheme x:Key="ModernContextMenu" TargetType="ContextMenu">
            <Setter Property="Background"      Value="#FEFCF8"/>
            <Setter Property="BorderBrush"     Value="#DDD0C2"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"         Value="4"/>
            <Setter Property="Template">
                <ControlTemplate>
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="8"
                            Padding="{TemplateBinding Padding}">
                        <ItemsPresenter/>
                    </Border>
                </ControlTemplate>
            </Setter>
        </ControlTheme>

        <ControlTheme x:Key="ModernMenuItem" TargetType="MenuItem">
            <Setter Property="Padding"         Value="14,8"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="Foreground"      Value="{StaticResource TextPrimary}"/>
            <Setter Property="Template">
                <ControlTemplate>
                    <Border x:Name="Bg" Background="{TemplateBinding Background}" CornerRadius="5" Margin="2,1">
                        <Border.Transitions>
                            <Transitions>
                                <BrushTransition Property="Background" Duration="0:0:0.12"/>
                            </Transitions>
                        </Border.Transitions>
                        <ContentPresenter Content="{TemplateBinding Header}"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="Center"
                                          TextElement.Foreground="{TemplateBinding Foreground}"/>
                    </Border>
                </ControlTemplate>
            </Setter>
            <Style Selector="^:pointerover /template/ Border#Bg">
                <Setter Property="Background" Value="#F0E0CE"/>
            </Style>
        </ControlTheme>

    </UserControl.Resources>

    <UserControl.Styles>
        <Style Selector="Grid.overlayGrid">
            <Setter Property="Opacity" Value="0"/>
        </Style>
        <Style Selector="Grid.overlayGrid.overlayVisible">
            <Setter Property="Opacity" Value="1"/>
        </Style>
        <Style Selector="Border.overlayCard">
            <Setter Property="RenderTransform" Value="translateY(16px)"/>
        </Style>
        <Style Selector="Border.overlayCard.overlayVisible">
            <Setter Property="RenderTransform" Value="translateY(0px)"/>
        </Style>
    </UserControl.Styles>

    <Grid>

        <!-- ══ Main content ════════════════════════════════════════════════════ -->
        <Grid Margin="32,28,32,28">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="16"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="20"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header row -->
            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Classes="H1" Text="My Library"/>
                    <StackPanel Orientation="Horizontal" Margin="0,4,0,0"
                                IsVisible="{Binding IsEmpty, Converter={StaticResource InvBoolToVis}}">
                        <TextBlock Classes="BodyText"
                                   Text="{Binding GameCount, StringFormat='{}{0} game(s)'}"/>
                        <TextBlock Classes="BodyText"
                                   Margin="8,0,0,0"
                                   Foreground="{StaticResource TextMuted}"
                                   IsVisible="{Binding TotalSizeText, Converter={StaticResource NotEmptyToVis}}"
                                   Text="{Binding TotalSizeText}"/>
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,96,0">
                    <Button Theme="{StaticResource PremiumRefreshBtn}"
                            Command="{Binding RefreshSizesCommand}"/>
                </StackPanel>
            </Grid>

            <!-- Search box -->
            <Border Grid.Row="2"
                    Background="{StaticResource BgCard}"
                    BorderBrush="{StaticResource Border}"
                    BorderThickness="1"
                    CornerRadius="10">
                <Grid Margin="12,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Path Grid.Column="0"
                          Data="{StaticResource LucideSearch}"
                          Width="15" Height="15" Stretch="Uniform" Margin="0,0,10,0"
                          Stroke="{StaticResource TextMuted}" StrokeThickness="1.7"
                          StrokeLineCap="Round" StrokeJoin="Round"
                          Fill="Transparent"/>
                    <TextBox Grid.Column="1"
                             BorderThickness="0"
                             Background="Transparent"
                             Padding="0,10"
                             FontSize="13"
                             Foreground="{StaticResource TextPrimary}"
                             Text="{Binding SearchText}"
                             CaretBrush="{StaticResource Accent}"/>
                </Grid>
            </Border>

            <!-- Games area -->
            <Grid Grid.Row="4">

                <!-- Empty state -->
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                            IsVisible="{Binding IsEmpty}">
                    <Border Width="64" Height="64"
                            CornerRadius="16"
                            Background="{StaticResource AccentVeryLight}"
                            HorizontalAlignment="Center"
                            Margin="0,0,0,16">
                        <Path Data="{StaticResource LucideAlignLeft}"
                              Width="28" Height="28" Stretch="Uniform"
                              Stroke="{StaticResource Accent}" StrokeThickness="1.7"
                              StrokeLineCap="Round" StrokeJoin="Round"
                              Fill="Transparent"/>
                    </Border>
                    <TextBlock Text="No games yet"
                               Classes="H3"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,6"/>
                    <TextBlock Text="Download a game to see it here."
                               Classes="BodyText"
                               HorizontalAlignment="Center"/>
                </StackPanel>

                <!-- Game list -->
                <ScrollViewer IsVisible="{Binding IsEmpty, Converter={StaticResource InvBoolToVis}}"
                              VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding Games}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="vm:LibraryGameViewModel">
                                <Border IsVisible="{Binding IsVisible}"
                                        Margin="0,0,12,12"
                                        Width="250">
                                    <Border Classes="Card gameCard"
                                            Padding="0"
                                            ClipToBounds="True">
                                        <Border.Transitions>
                                            <Transitions>
                                                <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.15"/>
                                            </Transitions>
                                        </Border.Transitions>
                                        <Border.Styles>
                                            <Style Selector="Border.gameCard">
                                                <Setter Property="RenderTransform" Value="translateY(0px)"/>
                                            </Style>
                                            <Style Selector="Border.gameCard:pointerover">
                                                <Setter Property="RenderTransform" Value="translateY(-3px)"/>
                                            </Style>
                                        </Border.Styles>
                                        <Border.ContextMenu>
                                            <ContextMenu Theme="{StaticResource ModernContextMenu}">
                                                <MenuItem Header="Open Download Folder"
                                                          Theme="{StaticResource ModernMenuItem}"
                                                          Command="{Binding LibVm.OpenFolderCommand}"
                                                          CommandParameter="{Binding}"/>
                                                <MenuItem Header="Rename"
                                                          Theme="{StaticResource ModernMenuItem}"
                                                          Command="{Binding LibVm.RenameGameCommand}"
                                                          CommandParameter="{Binding}"/>
                                                <Separator/>
                                                <MenuItem Header="Validate Files"
                                                          Theme="{StaticResource ModernMenuItem}"
                                                          Command="{Binding LibVm.ValidateFilesCommand}"
                                                          CommandParameter="{Binding}"/>
                                                <MenuItem Header="Redownload"
                                                          Theme="{StaticResource ModernMenuItem}"
                                                          Command="{Binding LibVm.ConfirmRedownloadCommand}"
                                                          CommandParameter="{Binding}"/>
                                                <MenuItem Header="Pack"
                                                          Theme="{StaticResource ModernMenuItem}"
                                                          Command="{Binding LibVm.PackGameCommand}"
                                                          CommandParameter="{Binding}"/>
                                                <Separator/>
                                                <MenuItem Header="Install OnlineFix"
                                                          Theme="{StaticResource ModernMenuItem}"
                                                          Command="{Binding LibVm.InstallOnlineFixCommand}"
                                                          CommandParameter="{Binding}"
                                                          IsVisible="{Binding OnlineFixApplied, Converter={StaticResource InvBoolToVis}}"/>
                                                <MenuItem Header="Remove OnlineFix"
                                                          Theme="{StaticResource ModernMenuItem}"
                                                          Command="{Binding LibVm.RemoveOnlineFixCommand}"
                                                          CommandParameter="{Binding}"
                                                          IsVisible="{Binding OnlineFixApplied}"/>
                                                <Separator/>
                                                <MenuItem Header="Remove from Library"
                                                          Theme="{StaticResource ModernMenuItem}"
                                                          Foreground="#B83B2A"
                                                          Command="{Binding LibVm.ConfirmRemoveCommand}"
                                                          CommandParameter="{Binding}"/>
                                            </ContextMenu>
                                        </Border.ContextMenu>

                                        <Grid>
                                            <!-- Header image -->
                                            <Border Height="103" VerticalAlignment="Top" CornerRadius="13,13,0,0">
                                                <Border.Background>
                                                    <ImageBrush Source="{Binding HeaderImage}" Stretch="UniformToFill"/>
                                                </Border.Background>
                                            </Border>

                                            <!-- OnlineFix blink dot -->
                                            <Ellipse Width="10" Height="10"
                                                     Fill="#2ECC71"
                                                     HorizontalAlignment="Right" VerticalAlignment="Top"
                                                     Margin="0,8,8,0"
                                                     IsVisible="{Binding OnlineFixApplied}"
                                                     Classes.blinking="{Binding OnlineFixApplied}">
                                                <Ellipse.Styles>
                                                    <Style Selector="Ellipse.blinking">
                                                        <Style.Animations>
                                                            <Animation Duration="0:0:0.85" IterationCount="INFINITE" PlaybackDirection="Alternate">
                                                                <KeyFrame Cue="0%"><Setter Property="Opacity" Value="1"/></KeyFrame>
                                                                <KeyFrame Cue="100%"><Setter Property="Opacity" Value="0.2"/></KeyFrame>
                                                            </Animation>
                                                        </Style.Animations>
                                                    </Style>
                                                </Ellipse.Styles>
                                            </Ellipse>

                                            <!-- Shimmer placeholder -->
                                            <Border Height="103" VerticalAlignment="Top"
                                                    CornerRadius="13,13,0,0"
                                                    Background="{StaticResource AccentLight}"
                                                    IsVisible="{Binding IsImageLoading}"
                                                    Classes.shimmer="{Binding IsImageLoading}">
                                                <Border.Styles>
                                                    <Style Selector="Border.shimmer">
                                                        <Style.Animations>
                                                            <Animation Duration="0:0:0.8" IterationCount="INFINITE" PlaybackDirection="Alternate">
                                                                <KeyFrame Cue="0%"><Setter Property="Opacity" Value="0.4"/></KeyFrame>
                                                                <KeyFrame Cue="100%"><Setter Property="Opacity" Value="0.85"/></KeyFrame>
                                                            </Animation>
                                                        </Style.Animations>
                                                    </Style>
                                                </Border.Styles>
                                            </Border>

                                            <!-- Content below image -->
                                            <Border Margin="0,103,0,0" Padding="14,10,14,14">
                                                <StackPanel>

                                                    <Grid Margin="0,0,0,4">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>

                                                        <TextBlock Grid.Column="0"
                                                                   Text="{Binding GameName}"
                                                                   FontSize="13.5" FontWeight="SemiBold"
                                                                   Foreground="{StaticResource TextPrimary}"
                                                                   TextTrimming="CharacterEllipsis"/>

                                                        <Border Grid.Column="1"
                                                                Classes="StatusPill"
                                                                Background="{StaticResource SuccessLight}"
                                                                IsVisible="{Binding Game.IsVerified}">
                                                            <TextBlock Text="✓" FontSize="10"
                                                                       Foreground="{StaticResource Success}"
                                                                       FontWeight="SemiBold"/>
                                                        </Border>
                                                        <Border Grid.Column="1"
                                                                Classes="StatusPill"
                                                                Background="{StaticResource ErrorLight}"
                                                                IsVisible="{Binding Game.IsVerified, Converter={StaticResource InvBoolToVis}}">
                                                            <TextBlock Text="Missing" FontSize="10"
                                                                       Foreground="{StaticResource Error}"/>
                                                        </Border>
                                                    </Grid>

                                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                                        <TextBlock Text="AppID " FontSize="11"
                                                                   Foreground="{StaticResource TextMuted}"
                                                                   VerticalAlignment="Center"/>
                                                        <TextBlock Text="{Binding Game.AppId}" FontFamily="Consolas"
                                                                   FontSize="11" Foreground="{StaticResource TextMuted}"
                                                                   VerticalAlignment="Center"/>
                                                        <TextBlock Text="{Binding BuildIdLabel}" FontSize="11"
                                                                   Foreground="{StaticResource TextMuted}"
                                                                   VerticalAlignment="Center"/>
                                                        <TextBlock Text="{Binding Game.BuildId}" FontFamily="Consolas"
                                                                   FontSize="11" Foreground="{StaticResource TextMuted}"
                                                                   VerticalAlignment="Center"/>
                                                    </StackPanel>

                                                    <Grid Margin="0,0,0,10">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>

                                                        <StackPanel Grid.Column="0">
                                                            <TextBlock Text="SIZE" Classes="Label"/>
                                                            <TextBlock Text="{Binding SizeText}"
                                                                       FontSize="12" FontWeight="SemiBold"
                                                                       Foreground="{StaticResource TextPrimary}"
                                                                       Margin="0,2,0,0"/>
                                                        </StackPanel>

                                                        <StackPanel Grid.Column="1">
                                                            <TextBlock Text="ADDED" Classes="Label"/>
                                                            <TextBlock Text="{Binding InstallDateText}"
                                                                       FontSize="11.5" FontWeight="SemiBold"
                                                                       Foreground="{StaticResource TextPrimary}"
                                                                       Margin="0,2,0,0"/>
                                                        </StackPanel>
                                                    </Grid>

                                                    <Button Theme="{StaticResource BtnPrimary}"
                                                            Padding="12,8"
                                                            HorizontalAlignment="Stretch"
                                                            IsEnabled="{Binding FolderExists}"
                                                            Command="{Binding DataContext.LaunchGameCommand,
                                                                      RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                            CommandParameter="{Binding}">
                                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                            <Path Data="{StaticResource LucidePlay}"
                                                                  Width="12" Height="12" Stretch="Uniform" Margin="0,0,6,0"
                                                                  Fill="White" Stroke="White" StrokeThickness="1"
                                                                  StrokeJoin="Round"/>
                                                            <TextBlock Text="Play" FontSize="12.5"
                                                                       FontWeight="SemiBold"
                                                                       Foreground="White"/>
                                                        </StackPanel>
                                                    </Button>

                                                </StackPanel>
                                            </Border>
                                        </Grid>
                                    </Border>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Grid>

        <!-- ══ Redownload confirmation overlay ══════════════════════════════════ -->
        <Grid Classes="overlayGrid" ZIndex="50"
              IsHitTestVisible="{Binding IsRedownloadOverlayVisible}"
              Classes.overlayVisible="{Binding IsRedownloadOverlayVisible}">
            <Grid.Transitions>
                <Transitions>
                    <DoubleTransition Property="Opacity" Duration="0:0:0.18"/>
                </Transitions>
            </Grid.Transitions>

            <Rectangle Fill="#1C1610" Opacity="0.72"/>

            <Border Width="420"
                    Classes="overlayCard"
                    HorizontalAlignment="Center" VerticalAlignment="Center"
                    Background="{StaticResource BgCard}"
                    BorderBrush="{StaticResource Border}"
                    BorderThickness="1"
                    CornerRadius="16"
                    Padding="28"
                    Classes.overlayVisible="{Binding IsRedownloadOverlayVisible}">
                <Border.Transitions>
                    <Transitions>
                        <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.22"/>
                    </Transitions>
                </Border.Transitions>

                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <Border Width="36" Height="36" CornerRadius="10"
                                Background="{StaticResource AccentSubtle}"
                                Margin="0,0,12,0">
                            <Path Data="{StaticResource LucideRotateCw}"
                                  Width="16" Height="16" Stretch="Uniform"
                                  Stroke="{StaticResource Accent}" StrokeThickness="1.8" Fill="Transparent"
                                  StrokeLineCap="Round" StrokeJoin="Round"/>
                        </Border>
                        <TextBlock Text="Redownload Game"
                                   FontSize="17" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimary}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <TextBlock Text="{Binding GameToRedownload.Game.GameName}"
                               FontSize="13" FontWeight="SemiBold"
                               Foreground="{StaticResource Accent}"
                               Margin="0,0,0,6"
                               TextTrimming="CharacterEllipsis"/>

                    <TextBlock Text="All existing game files will be deleted and the game will be re-downloaded from scratch."
                               FontSize="13" Foreground="{StaticResource TextBody}"
                               TextWrapping="Wrap" Margin="0,0,0,20"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0"
                                Content="Cancel"
                                Command="{Binding CancelRedownloadCommand}"
                                Theme="{StaticResource BtnGhost}"
                                Padding="12,10" FontSize="12" FontWeight="SemiBold"/>
                        <Button Grid.Column="2"
                                Content="Redownload"
                                Command="{Binding DoRedownloadCommand}"
                                Theme="{StaticResource BtnPrimary}"
                                Padding="12,10" FontSize="12" FontWeight="SemiBold"/>
                    </Grid>
                </StackPanel>
            </Border>
        </Grid>

        <!-- ══ Remove-game confirmation overlay ══════════════════════════════════ -->
        <Grid Classes="overlayGrid" ZIndex="50"
              IsHitTestVisible="{Binding IsRemoveOverlayVisible}"
              Classes.overlayVisible="{Binding IsRemoveOverlayVisible}">
            <Grid.Transitions>
                <Transitions>
                    <DoubleTransition Property="Opacity" Duration="0:0:0.18"/>
                </Transitions>
            </Grid.Transitions>

            <Rectangle Fill="#1C1610" Opacity="0.72"/>

            <Border Width="420"
                    Classes="overlayCard"
                    HorizontalAlignment="Center" VerticalAlignment="Center"
                    Background="{StaticResource BgCard}"
                    BorderBrush="{StaticResource Border}"
                    BorderThickness="1"
                    CornerRadius="16"
                    Padding="28"
                    Classes.overlayVisible="{Binding IsRemoveOverlayVisible}">
                <Border.Transitions>
                    <Transitions>
                        <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.22"/>
                    </Transitions>
                </Border.Transitions>

                <StackPanel>
                    <!-- Icon + title -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <Border Width="36" Height="36" CornerRadius="10"
                                Background="{StaticResource ErrorLight}"
                                Margin="0,0,12,0">
                            <Path Data="{StaticResource LucideTrash2}"
                                  Width="16" Height="16" Stretch="Uniform"
                                  Stroke="{StaticResource Error}" StrokeThickness="1.8" Fill="Transparent"
                                  StrokeLineCap="Round" StrokeJoin="Round"/>
                        </Border>
                        <TextBlock Text="Remove Game"
                                   FontSize="17" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimary}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- Game name -->
                    <TextBlock Text="{Binding GameToRemove.Game.GameName}"
                               FontSize="13" FontWeight="SemiBold"
                               Foreground="{StaticResource Accent}"
                               Margin="0,0,0,6"
                               TextTrimming="CharacterEllipsis"/>

                    <!-- Message -->
                    <TextBlock Text="Remove this game from your library?"
                               FontSize="13" Foreground="{StaticResource TextBody}"
                               TextWrapping="Wrap" Margin="0,0,0,16"/>

                    <!-- Delete files checkbox -->
                    <Border Background="{StaticResource BgInput}"
                            BorderBrush="{StaticResource Border}"
                            BorderThickness="1" CornerRadius="8"
                            Padding="12,10" Margin="0,0,0,20">
                        <CheckBox IsChecked="{Binding DeleteFiles}" Cursor="Hand">
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Also delete all game files"
                                           FontSize="13" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextPrimary}"/>
                                <TextBlock Text="This cannot be undone"
                                           FontSize="11" Foreground="{StaticResource TextMuted}"
                                           Margin="0,2,0,0"/>
                            </StackPanel>
                        </CheckBox>
                    </Border>

                    <!-- Buttons -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0"
                                Content="Cancel"
                                Command="{Binding CancelRemoveCommand}"
                                Theme="{StaticResource BtnGhost}"
                                Padding="12,10" FontSize="12" FontWeight="SemiBold"/>
                        <Button Grid.Column="2"
                                Content="Remove"
                                Command="{Binding DoRemoveCommand}"
                                Theme="{StaticResource BtnDanger}"
                                Padding="12,10" FontSize="12" FontWeight="SemiBold"/>
                    </Grid>
                </StackPanel>
            </Border>
        </Grid>

    </Grid>
</UserControl>
