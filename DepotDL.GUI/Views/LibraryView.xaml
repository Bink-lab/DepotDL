<UserControl x:Class="DepotDL.GUI.Views.LibraryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:DepotDL.GUI.ViewModels"
             FontFamily="Segoe UI">

    <Grid Margin="32,28,32,28">
        <Grid.Resources>
            <Style x:Key="PremiumRefreshBtn" TargetType="Button">
                <Setter Property="Background" Value="{StaticResource AccentSubtle}"/>
                <Setter Property="Foreground" Value="{StaticResource Accent}"/>
                <Setter Property="BorderBrush" Value="{StaticResource Accent}"/>
                <Setter Property="BorderThickness" Value="1.2"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="border"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="16" Padding="14,6">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Center">
                                    <Viewbox x:Name="iconBox" Width="14" Height="14" Margin="0,0,6,0" RenderTransformOrigin="0.5,0.5">
                                        <Viewbox.RenderTransform>
                                            <RotateTransform x:Name="rotator" Angle="0"/>
                                        </Viewbox.RenderTransform>
                                        <Canvas Width="24" Height="24">
                                            <Path Data="M21,12 A9,9 0 1,1 12,3 C14.52,3 16.93,4 18.74,5.74 L21,8 M21,3 L21,8 L16,8"
                                                  Stroke="{StaticResource Accent}"
                                                  StrokeThickness="1.7"
                                                  StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                                  StrokeLineJoin="Round"
                                                  Fill="Transparent"/>
                                        </Canvas>
                                    </Viewbox>
                                    <TextBlock Text="Refresh Sizes" FontSize="11.5" FontWeight="SemiBold"
                                               Foreground="{StaticResource Accent}" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Trigger.EnterActions>
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetName="rotator"
                                                                 Storyboard.TargetProperty="Angle"
                                                                 To="360" Duration="0:0:0.65">
                                                    <DoubleAnimation.EasingFunction>
                                                        <QuadraticEase EasingMode="EaseInOut"/>
                                                    </DoubleAnimation.EasingFunction>
                                                </DoubleAnimation>
                                                <ColorAnimation Storyboard.TargetName="border"
                                                                Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                                                To="#F2D5BF" Duration="0:0:0.2"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </Trigger.EnterActions>
                                    <Trigger.ExitActions>
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetName="rotator"
                                                                 Storyboard.TargetProperty="Angle"
                                                                 To="0" Duration="0:0:0.45">
                                                    <DoubleAnimation.EasingFunction>
                                                        <QuadraticEase EasingMode="EaseInOut"/>
                                                    </DoubleAnimation.EasingFunction>
                                                </DoubleAnimation>
                                                <ColorAnimation Storyboard.TargetName="border"
                                                                Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                                                To="#FAF0E6" Duration="0:0:0.2"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </Trigger.ExitActions>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter Property="Opacity" Value="0.8"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </Grid.Resources>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="20"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
                <TextBlock Style="{StaticResource TextH1}" Text="My Library"/>
                <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                    <TextBlock Style="{StaticResource BodyText}"
                               Text="{Binding GameCount, StringFormat={}{0} game(s)}"
                               Visibility="{Binding GameCount, Converter={StaticResource NotEmptyToVis}}"/>
                    <TextBlock Style="{StaticResource BodyText}"
                               Margin="8,0,0,0"
                               Foreground="{StaticResource TextMuted}"
                               Visibility="{Binding TotalSizeText, Converter={StaticResource NotEmptyToVis}}">
                        <Run Text="·  "/>
                        <Run Text="{Binding TotalSizeText}"/>
                    </TextBlock>
                </StackPanel>
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,96,0">
                <Button Style="{StaticResource PremiumRefreshBtn}"
                        Command="{Binding RefreshSizesCommand}"/>
            </StackPanel>
        </Grid>

        <Border Grid.Row="2"
                Background="{StaticResource BgCard}"
                BorderBrush="{StaticResource Border}"
                BorderThickness="1"
                CornerRadius="10">
            <Grid Margin="12,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Viewbox Grid.Column="0" Width="15" Height="15" Margin="0,0,10,0">
                    <Canvas Width="24" Height="24">
                        <Ellipse Canvas.Left="3" Canvas.Top="3" Width="14" Height="14"
                                 Stroke="{StaticResource TextMuted}" StrokeThickness="2"/>
                        <Path Data="M15,15 L21,21"
                              Stroke="{StaticResource TextMuted}"
                              StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                    </Canvas>
                </Viewbox>
                <TextBox Grid.Column="1"
                         BorderThickness="0"
                         Background="Transparent"
                         Padding="0,10"
                         FontSize="13"
                         Foreground="{StaticResource TextPrimary}"
                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                         CaretBrush="{StaticResource Accent}">
                    <TextBox.Template>
                        <ControlTemplate TargetType="TextBox">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="Center"/>
                        </ControlTemplate>
                    </TextBox.Template>
                </TextBox>
            </Grid>
        </Border>

        <Grid Grid.Row="4">

            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                        Visibility="{Binding IsEmpty, Converter={StaticResource BoolToVis}}">
                <Border Width="64" Height="64"
                        CornerRadius="16"
                        Background="{StaticResource AccentVeryLight}"
                        HorizontalAlignment="Center"
                        Margin="0,0,0,16">
                    <Viewbox Width="28" Height="28">
                        <Canvas Width="24" Height="24">
                            <Path Data="M4,6 L20,6 M4,12 L20,12 M4,18 L12,18"
                                  Stroke="{StaticResource Accent}"
                                  StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                        </Canvas>
                    </Viewbox>
                </Border>
                <TextBlock Text="No games yet"
                           Style="{StaticResource TextH3}"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,6"/>
                <TextBlock Text="Download a game to see it here."
                           Style="{StaticResource BodyText}"
                           HorizontalAlignment="Center"/>
            </StackPanel>

            <ScrollViewer Visibility="{Binding IsEmpty, Converter={StaticResource InvBoolToVis}}"
                          VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding Games}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type vm:LibraryGameViewModel}">
                            <Border Visibility="{Binding IsVisible, Converter={StaticResource BoolToVis}}"
                                    Margin="0,0,16,16"
                                    Width="300">
                                <Border Style="{StaticResource Card}"
                                        Padding="0">
                                    <Border.RenderTransform>
                                        <TranslateTransform/>
                                    </Border.RenderTransform>
                                    <Border.Triggers>
                                        <EventTrigger RoutedEvent="MouseEnter">
                                            <BeginStoryboard>
                                                <Storyboard>
                                                    <DoubleAnimation
                                                        Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                                                        To="-2" Duration="0:0:0.15">
                                                        <DoubleAnimation.EasingFunction>
                                                            <CubicEase EasingMode="EaseOut"/>
                                                        </DoubleAnimation.EasingFunction>
                                                    </DoubleAnimation>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </EventTrigger>
                                        <EventTrigger RoutedEvent="MouseLeave">
                                            <BeginStoryboard>
                                                <Storyboard>
                                                    <DoubleAnimation
                                                        Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                                                        To="0" Duration="0:0:0.15">
                                                        <DoubleAnimation.EasingFunction>
                                                            <CubicEase EasingMode="EaseOut"/>
                                                        </DoubleAnimation.EasingFunction>
                                                    </DoubleAnimation>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </EventTrigger>
                                    </Border.Triggers>

                                    <Grid>
                                        <Border Height="4" VerticalAlignment="Top"
                                                CornerRadius="12,12,0,0"
                                                Background="{StaticResource Accent}"/>

                                        <StackPanel Margin="20,16,20,16">
                                            <Grid Margin="0,0,0,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>

                                                <TextBlock Grid.Column="0"
                                                           Text="{Binding Game.GameName}"
                                                           FontSize="15" FontWeight="SemiBold"
                                                           Foreground="{StaticResource TextPrimary}"
                                                           TextTrimming="CharacterEllipsis"/>

                                                <Border Grid.Column="1"
                                                        Style="{StaticResource StatusPill}"
                                                        Background="{StaticResource SuccessLight}"
                                                        Visibility="{Binding Game.IsVerified, Converter={StaticResource BoolToVis}}">
                                                    <TextBlock Text="✓" FontSize="11"
                                                               Foreground="{StaticResource Success}"
                                                               FontWeight="SemiBold"/>
                                                </Border>
                                                <Border Grid.Column="1"
                                                        Style="{StaticResource StatusPill}"
                                                        Background="{StaticResource ErrorLight}"
                                                        Visibility="{Binding Game.IsVerified, Converter={StaticResource InvBoolToVis}}">
                                                    <TextBlock Text="Missing" FontSize="10"
                                                               Foreground="{StaticResource Error}"/>
                                                </Border>
                                            </Grid>

                                            <TextBlock Margin="0,4,0,12"
                                                       FontSize="11"
                                                       Foreground="{StaticResource TextMuted}">
                                                <Run Text="AppID "/>
                                                <Run Text="{Binding Game.AppId}" FontFamily="Consolas"/>
                                            </TextBlock>

                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>

                                                <StackPanel Grid.Column="0">
                                                    <TextBlock Text="SIZE" Style="{StaticResource TextLabel}"/>
                                                    <TextBlock Text="{Binding SizeText}"
                                                               FontSize="13" FontWeight="SemiBold"
                                                               Foreground="{StaticResource TextPrimary}"
                                                               Margin="0,2,0,0"/>
                                                </StackPanel>

                                                <StackPanel Grid.Column="1">
                                                    <TextBlock Text="DEPOTS" Style="{StaticResource TextLabel}"/>
                                                    <TextBlock Text="{Binding DepotCount}"
                                                               FontSize="13" FontWeight="SemiBold"
                                                               Foreground="{StaticResource TextPrimary}"
                                                               Margin="0,2,0,0"/>
                                                </StackPanel>

                                                <StackPanel Grid.Column="2">
                                                    <TextBlock Text="ADDED" Style="{StaticResource TextLabel}"/>
                                                    <TextBlock Text="{Binding InstallDateText}"
                                                               FontSize="12" FontWeight="SemiBold"
                                                               Foreground="{StaticResource TextPrimary}"
                                                               Margin="0,2,0,0"/>
                                                </StackPanel>
                                            </Grid>

                                            <StackPanel Orientation="Horizontal"
                                                        Margin="0,14,0,0">
                                                <Button Style="{StaticResource BtnGhost}"
                                                        Padding="10,6"
                                                        IsEnabled="{Binding FolderExists}"
                                                        Command="{Binding DataContext.OpenFolderCommand,
                                                                  RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                        CommandParameter="{Binding}">
                                                    <StackPanel Orientation="Horizontal">
                                                        <Viewbox Width="12" Height="12" Margin="0,0,5,0">
                                                            <Canvas Width="24" Height="24">
                                                                <Path Data="M3,7 L21,7 L21,19 A2,2,0,0,1,19,21 L5,21 A2,2,0,0,1,3,19 Z M3,7 L7,3 L11,3 L11,7"
                                                                      Stroke="{StaticResource TextSecondary}"
                                                                      StrokeThickness="1.8" Fill="Transparent"
                                                                      StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                                                            </Canvas>
                                                        </Viewbox>
                                                        <TextBlock Text="Open" FontSize="12"
                                                                   Foreground="{StaticResource TextSecondary}"/>
                                                    </StackPanel>
                                                </Button>

                                                <Button Style="{StaticResource BtnDanger}"
                                                        Padding="10,6"
                                                        Margin="8,0,0,0"
                                                        Command="{Binding DataContext.RemoveGameCommand,
                                                                  RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                        CommandParameter="{Binding}">
                                                    <StackPanel Orientation="Horizontal">
                                                        <Viewbox Width="12" Height="12" Margin="0,0,5,0">
                                                            <Canvas Width="24" Height="24">
                                                                <Path Data="M3,6 L21,6 M8,6 L8,4 L16,4 L16,6 M19,6 L18,20 A1,1,0,0,1,17,21 L7,21 A1,1,0,0,1,6,20 L5,6"
                                                                      Stroke="{StaticResource Error}"
                                                                      StrokeThickness="1.8" Fill="Transparent"
                                                                      StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                                                            </Canvas>
                                                        </Viewbox>
                                                        <TextBlock Text="Remove" FontSize="12"
                                                                   Foreground="{StaticResource Error}"/>
                                                    </StackPanel>
                                                </Button>
                                            </StackPanel>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>
    </Grid>
</UserControl>
