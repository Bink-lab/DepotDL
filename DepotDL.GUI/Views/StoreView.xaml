<UserControl x:Class="DepotDL.GUI.Views.StoreView"
             xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:DepotDL.GUI.ViewModels"
             xmlns:models="using:DepotDL.GUI.Models"
             xmlns:helpers="using:DepotDL.GUI.Helpers">

    <UserControl.Resources>
        <ControlTheme x:Key="ProviderDropBtn" TargetType="ToggleButton">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="13,8"/>
            <Setter Property="FontSize" Value="12.5"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
            <Setter Property="Template">
                <ControlTemplate>
                    <Border Name="bd"
                            Background="White"
                            BorderBrush="{StaticResource Border}"
                            BorderThickness="1.5"
                            CornerRadius="7"
                            Padding="{TemplateBinding Padding}">
                        <Border.Transitions>
                            <Transitions>
                                <BrushTransition Property="Background" Duration="0:0:0.15"/>
                                <BrushTransition Property="BorderBrush" Duration="0:0:0.15"/>
                            </Transitions>
                        </Border.Transitions>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <ContentPresenter Name="PART_ContentPresenter"
                                              Content="{TemplateBinding Content}"
                                              ContentTemplate="{TemplateBinding ContentTemplate}"
                                              VerticalAlignment="Center"/>
                            <Path Name="chevron"
                                  Data="{StaticResource LucideChevronDown}"
                                  Width="10" Height="10" Stretch="Uniform" Margin="6,1,0,0"
                                  VerticalAlignment="Center"
                                  Stroke="{StaticResource TextSecondary}" StrokeThickness="2"
                                  StrokeLineCap="Round"                                  StrokeJoin="Round" Fill="Transparent"/>
                        </StackPanel>
                    </Border>
                </ControlTemplate>
            </Setter>
            <Style Selector="^:pointerover /template/ Border#bd">
                <Setter Property="Background" Value="{StaticResource AccentVeryLight}"/>
                <Setter Property="BorderBrush" Value="{StaticResource Accent}"/>
            </Style>
            <Style Selector="^:pointerover">
                <Setter Property="Foreground" Value="{StaticResource Accent}"/>
            </Style>
            <Style Selector="^:pointerover /template/ Path#chevron">
                <Setter Property="Stroke" Value="{StaticResource Accent}"/>
            </Style>
            <Style Selector="^:checked /template/ Border#bd">
                <Setter Property="Background" Value="{StaticResource AccentLight}"/>
                <Setter Property="BorderBrush" Value="{StaticResource Accent}"/>
            </Style>
            <Style Selector="^:checked">
                <Setter Property="Foreground" Value="{StaticResource Accent}"/>
            </Style>
            <Style Selector="^:checked /template/ Path#chevron">
                <Setter Property="Stroke" Value="{StaticResource Accent}"/>
                <Setter Property="Data" Value="{StaticResource LucideChevronUp}"/>
            </Style>
        </ControlTheme>

        <ControlTheme x:Key="ProviderDropItem" TargetType="Button">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <ControlTemplate>
                    <Border Name="bd"
                            Background="{TemplateBinding Background}"
                            CornerRadius="5"
                            Padding="10,9">
                        <Border.Transitions>
                            <Transitions>
                                <BrushTransition Property="Background" Duration="0:0:0.12"/>
                            </Transitions>
                        </Border.Transitions>
                        <ContentPresenter Name="PART_ContentPresenter"
                                          Content="{TemplateBinding Content}"
                                          ContentTemplate="{TemplateBinding ContentTemplate}"
                                          HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Setter>
            <Style Selector="^:pointerover /template/ Border#bd">
                <Setter Property="Background" Value="{StaticResource AccentVeryLight}"/>
            </Style>
            <Style Selector="^:pointerover">
                <Setter Property="Foreground" Value="{StaticResource Accent}"/>
            </Style>
            <Style Selector="^:disabled">
                <Setter Property="Foreground" Value="{StaticResource TextMuted}"/>
                <Setter Property="Cursor" Value="Arrow"/>
            </Style>
        </ControlTheme>

        <ControlTheme x:Key="PassthroughBtn" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Template">
                <ControlTemplate>
                    <Border Background="Transparent">
                        <ContentPresenter Name="PART_ContentPresenter"
                                          Content="{TemplateBinding Content}"
                                          ContentTemplate="{TemplateBinding ContentTemplate}"/>
                    </Border>
                </ControlTemplate>
            </Setter>
        </ControlTheme>

        <ControlTheme x:Key="GameCardBtnTheme" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Template">
                <ControlTemplate>
                    <ContentPresenter Name="PART_ContentPresenter"
                                      Content="{TemplateBinding Content}"
                                      ContentTemplate="{TemplateBinding ContentTemplate}"/>
                </ControlTemplate>
            </Setter>
        </ControlTheme>
    </UserControl.Resources>

    <UserControl.Styles>
        <Style Selector="Ellipse.spinner">
            <Style.Animations>
                <Animation Duration="0:0:0.85" IterationCount="INFINITE" PlaybackDirection="Normal">
                    <KeyFrame Cue="0%">
                        <Setter Property="RenderTransform" Value="rotate(0deg)"/>
                    </KeyFrame>
                    <KeyFrame Cue="100%">
                        <Setter Property="RenderTransform" Value="rotate(360deg)"/>
                    </KeyFrame>
                </Animation>
            </Style.Animations>
        </Style>
        <Style Selector="Border.storeShimmer">
            <Style.Animations>
                <Animation Duration="0:0:0.75" IterationCount="INFINITE" PlaybackDirection="Alternate">
                    <KeyFrame Cue="0%"><Setter Property="Opacity" Value="0.4"/></KeyFrame>
                    <KeyFrame Cue="100%"><Setter Property="Opacity" Value="0.9"/></KeyFrame>
                </Animation>
            </Style.Animations>
        </Style>
        <Style Selector="ScrollViewer.transitioning">
            <Setter Property="Opacity" Value="0"/>
        </Style>
        <Style Selector="Grid.overlayGrid">
            <Setter Property="Opacity" Value="0"/>
        </Style>
        <Style Selector="Grid.overlayGrid.overlayVisible">
            <Setter Property="Opacity" Value="1"/>
        </Style>
        <Style Selector="Border.overlayCard">
            <Setter Property="RenderTransform" Value="translateY(28px)"/>
        </Style>
        <Style Selector="Border.overlayCard.overlayVisible">
            <Setter Property="RenderTransform" Value="translateY(0px)"/>
        </Style>
        <Style Selector="Border.storeGameCard">
            <Setter Property="RenderTransform" Value="translateY(0px)"/>
        </Style>
        <Style Selector="Button:pointerover Border.storeGameCard">
            <Setter Property="RenderTransform" Value="translateY(-3px)"/>
        </Style>
    </UserControl.Styles>

    <Grid>

        <!-- ══ Main content ══════════════════════════════════════════ -->
        <Grid Margin="24,28,20,16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="16"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="12"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="12"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <StackPanel Grid.Row="0">
                <TextBlock Classes="H1" Text="Steam Store"/>
                <TextBlock Classes="BodyText" Margin="0,4,0,0"
                           Text="{Binding GamesInfo, FallbackValue='Browse all Steam games'}"/>
            </StackPanel>

            <!-- Search bar -->
            <Border Grid.Row="2"
                    Background="{StaticResource BgCard}"
                    BorderBrush="{StaticResource Border}"
                    BorderThickness="1"
                    CornerRadius="10">
                <Grid Margin="12,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Path Grid.Column="0" Data="{StaticResource LucideSearch}"
                          Width="15" Height="15" Stretch="Uniform" Margin="0,0,10,0"
                          Stroke="{StaticResource TextMuted}" StrokeThickness="1.7"
                          StrokeLineCap="Round" StrokeJoin="Round"
                          Fill="Transparent"/>
                    <TextBox Grid.Column="1"
                             BorderThickness="0"
                             Background="Transparent"
                             Padding="0,10"
                             FontSize="13"
                             Foreground="{StaticResource TextPrimary}"
                             Text="{Binding SearchText}"
                             CaretBrush="{StaticResource Accent}"/>
                </Grid>
            </Border>

            <!-- Game grid area -->
            <Grid Grid.Row="4">

                <!-- ① Loading spinner -->
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                            IsVisible="{Binding ShowLoadingSpinner}">
                    <Grid Width="52" Height="52" HorizontalAlignment="Center" Margin="0,0,0,18">
                        <Ellipse Stroke="{StaticResource AccentLight}" StrokeThickness="4"/>
                        <Ellipse Classes="spinner"
                                 Stroke="{StaticResource Accent}" StrokeThickness="4"
                                 StrokeDashArray="35,1000"/>
                    </Grid>
                    <TextBlock Text="{Binding LoadingStatus}"
                               FontSize="13" Foreground="{StaticResource TextMuted}"
                               HorizontalAlignment="Center"/>
                </StackPanel>

                <!-- ② Empty state -->
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                            IsVisible="{Binding ShowEmptyState}">
                    <Border Width="64" Height="64" CornerRadius="16"
                            Background="{StaticResource AccentVeryLight}"
                            HorizontalAlignment="Center" Margin="0,0,0,16">
                        <Path Data="{StaticResource LucideFileText}"
                              Width="28" Height="28" Stretch="Uniform"
                              Stroke="{StaticResource Accent}" StrokeThickness="1.7" Fill="Transparent"
                              StrokeLineCap="Round" StrokeJoin="Round"/>
                    </Border>
                    <TextBlock Text="No games found" Classes="H3"
                               HorizontalAlignment="Center" Margin="0,0,0,6"/>
                    <TextBlock Text="Try a different search term."
                               Classes="BodyText" HorizontalAlignment="Center"/>
                </StackPanel>

                <!-- ③ Game cards with page-transition -->
                <ScrollViewer helpers:SmoothScroll.IsEnabled="True"
                              VerticalScrollBarVisibility="Auto"
                              IsVisible="{Binding HasGames}"
                              Opacity="1"
                              Classes.transitioning="{Binding IsPageTransitioning}">
                    <ScrollViewer.Transitions>
                        <Transitions>
                            <DoubleTransition Property="Opacity" Duration="0:0:0.15" Easing="CubicEaseOut"/>
                        </Transitions>
                    </ScrollViewer.Transitions>
                    <ItemsControl ItemsSource="{Binding DisplayedGames}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="vm:StoreGameViewModel">
                                <Button Theme="{StaticResource GameCardBtnTheme}"
                                        Width="193" Margin="0,0,8,8"
                                        Cursor="Hand"
                                        Command="{Binding DataContext.OpenOverlayCommand,
                                            RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                        CommandParameter="{Binding}">
                                    <Border Classes="Card storeGameCard" Padding="0" ClipToBounds="True">
                                        <Border.Transitions>
                                            <Transitions>
                                                <TransformOperationsTransition Property="RenderTransform"
                                                                               Duration="0:0:0.15" Easing="CubicEaseOut"/>
                                            </Transitions>
                                        </Border.Transitions>
                                        <Grid>
                                            <!-- Game image -->
                                            <Border Height="96" VerticalAlignment="Top" CornerRadius="13,13,0,0">
                                                <Border.Background>
                                                    <ImageBrush Source="{Binding HeaderImage}" Stretch="UniformToFill"/>
                                                </Border.Background>
                                            </Border>

                                            <!-- Shimmer placeholder -->
                                            <Border Height="96" VerticalAlignment="Top"
                                                    CornerRadius="13,13,0,0"
                                                    Background="{StaticResource AccentLight}"
                                                    IsVisible="{Binding IsImageLoading}"
                                                    Classes.storeShimmer="{Binding IsImageLoading}"/>

                                            <!-- Game name -->
                                            <Border Margin="0,96,0,0" Padding="10,8,10,10">
                                                <TextBlock Text="{Binding Game.Name}"
                                                           FontSize="12.5" FontWeight="SemiBold"
                                                           Foreground="{StaticResource TextPrimary}"
                                                           TextTrimming="CharacterEllipsis"/>
                                            </Border>
                                        </Grid>
                                    </Border>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>

            <!-- Pagination -->
            <Grid Grid.Row="6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="{Binding GamesInfo}"
                           FontSize="12" Foreground="{StaticResource TextMuted}"
                           VerticalAlignment="Center"/>

                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Theme="{StaticResource BtnSecondary}"
                            Padding="12,6" FontSize="12"
                            Command="{Binding PrevPageCommand}"
                            IsEnabled="{Binding HasPrev}">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="{StaticResource LucideChevronLeft}"
                                  Width="12" Height="12" Stretch="Uniform" Margin="0,0,5,0"
                                  Stroke="{StaticResource TextBody}" StrokeThickness="1.7"
                                  StrokeLineCap="Round" StrokeJoin="Round"
                                  Fill="Transparent"/>
                            <TextBlock Text="Prev" Foreground="{StaticResource TextBody}"/>
                        </StackPanel>
                    </Button>

                    <TextBlock Text="{Binding PageInfo}"
                               FontSize="12" Foreground="{StaticResource TextSecondary}"
                               VerticalAlignment="Center" Margin="14,0"/>

                    <Button Theme="{StaticResource BtnSecondary}"
                            Padding="12,6" FontSize="12"
                            Command="{Binding NextPageCommand}"
                            IsEnabled="{Binding HasNext}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Next" Foreground="{StaticResource TextBody}"/>
                            <Path Data="{StaticResource LucideChevronRight}"
                                  Width="12" Height="12" Stretch="Uniform" Margin="5,0,0,0"
                                  Stroke="{StaticResource TextBody}" StrokeThickness="1.7"
                                  StrokeLineCap="Round" StrokeJoin="Round"
                                  Fill="Transparent"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Grid>

        <!-- ══ Game detail overlay ══════════════════════════════════════════ -->
        <Grid Classes="overlayGrid" ZIndex="50"
              IsHitTestVisible="{Binding OverlayVisible}"
              Classes.overlayVisible="{Binding OverlayVisible}">
            <Grid.Transitions>
                <Transitions>
                    <DoubleTransition Property="Opacity" Duration="0:0:0.22" Easing="CubicEaseOut"/>
                </Transitions>
            </Grid.Transitions>

            <!-- Backdrop -->
            <Button Theme="{StaticResource PassthroughBtn}"
                    Command="{Binding CloseOverlayCommand}"
                    HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                <Rectangle Fill="#1C1610" Opacity="0.72"/>
            </Button>

            <!-- Card -->
            <Border Classes="overlayCard" Margin="80,50"
                    MaxWidth="1000" MaxHeight="820"
                    HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                    Background="{StaticResource BgCard}"
                    CornerRadius="16"
                    BorderBrush="{StaticResource Border}"
                    BorderThickness="1"
                    ClipToBounds="True"
                    Classes.overlayVisible="{Binding OverlayVisible}">
                <Border.Transitions>
                    <Transitions>
                        <TransformOperationsTransition Property="RenderTransform"
                                                       Duration="0:0:0.28" Easing="CubicEaseOut"/>
                    </Transitions>
                </Border.Transitions>

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="162"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Hero image -->
                    <Border Grid.Row="0" CornerRadius="16,16,0,0">
                        <Border.Background>
                            <ImageBrush Source="{Binding SelectedGame.HeaderImage}" Stretch="UniformToFill"/>
                        </Border.Background>
                        <Grid>
                            <Border Background="#1C1610" Opacity="0.45" CornerRadius="16,16,0,0"/>
                            <!-- Close button -->
                            <Button HorizontalAlignment="Right" VerticalAlignment="Top"
                                    Margin="0,10,10,0"
                                    Command="{Binding CloseOverlayCommand}"
                                    Width="30" Height="30"
                                    Cursor="Hand">
                                <Button.Theme>
                                    <ControlTheme TargetType="Button">
                                        <Setter Property="Template">
                                            <ControlTemplate>
                                                <Border Name="bg" CornerRadius="8"
                                                        Background="#88000000"
                                                        Width="30" Height="30">
                                                    <Border.Transitions>
                                                        <Transitions>
                                                            <BrushTransition Property="Background" Duration="0:0:0.12"/>
                                                        </Transitions>
                                                    </Border.Transitions>
                                                    <Path Data="{StaticResource LucideX}"
                                                          Width="14" Height="14" Stretch="Uniform"
                                                          HorizontalAlignment="Center" VerticalAlignment="Center"
                                                          Stroke="White" StrokeThickness="2" Fill="Transparent"
                                                          StrokeLineCap="Round" StrokeJoin="Round"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter>
                                        <Style Selector="^:pointerover /template/ Border#bg">
                                            <Setter Property="Background" Value="#BB000000"/>
                                        </Style>
                                    </ControlTheme>
                                </Button.Theme>
                            </Button>
                            <!-- Title overlay -->
                            <StackPanel VerticalAlignment="Bottom" Margin="20,0,20,16">
                                <TextBlock Text="{Binding SelectedGame.Game.Name}"
                                           FontSize="20" FontWeight="Bold" Foreground="White"
                                           TextTrimming="CharacterEllipsis"/>
                                <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                    <TextBlock Text="{Binding SelectedGame.Game.Developer}"
                                               FontSize="12" Foreground="#CCFFFFFF"/>
                                    <TextBlock Text=" · " FontSize="12" Foreground="#88FFFFFF"
                                               IsVisible="{Binding SelectedGame.Game.Developer,
                                                   Converter={StaticResource NotEmptyToVis}}"/>
                                    <TextBlock Text="{Binding SelectedGame.PriceDisplay}"
                                               FontSize="12" FontWeight="SemiBold" Foreground="#FFDDA060"/>
                                </StackPanel>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Content -->
                    <ScrollViewer Grid.Row="1" Margin="20,16,20,0" VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <!-- Loading -->
                            <TextBlock Text="Loading details..."
                                       FontSize="13" Foreground="{StaticResource TextMuted}"
                                       HorizontalAlignment="Center" Margin="0,20"
                                       IsVisible="{Binding IsDetailLoading}"/>

                            <!-- Details (shown once loaded) -->
                            <StackPanel IsVisible="{Binding IsDetailLoading,
                                            Converter={StaticResource InvBoolToVis}}">

                                <!-- Short description -->
                                <TextBlock Text="{Binding SelectedDetail.ShortDescription}"
                                           FontSize="13" Foreground="{StaticResource TextBody}"
                                           TextWrapping="Wrap" LineHeight="20"
                                           Margin="0,0,0,14"/>

                                <!-- Genre tags -->
                                <ItemsControl ItemsSource="{Binding SelectedDetail.Genres}"
                                              Margin="0,0,0,14">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="{StaticResource AccentSubtle}"
                                                    BorderBrush="{StaticResource AccentLight}"
                                                    BorderThickness="1"
                                                    CornerRadius="6" Padding="8,3" Margin="0,0,6,6">
                                                <TextBlock Text="{Binding}" FontSize="11"
                                                           Foreground="{StaticResource Accent}"
                                                           FontWeight="SemiBold"/>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <!-- Stats grid -->
                                <Grid Margin="0,0,0,16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="REVIEWS" Classes="Label"/>
                                        <TextBlock Text="{Binding SelectedGame.ReviewRatio}"
                                                   FontSize="12" FontWeight="SemiBold"
                                                   Foreground="{StaticResource TextPrimary}"
                                                   TextWrapping="Wrap"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="DEVELOPER" Classes="Label"/>
                                        <TextBlock Text="{Binding SelectedDetail.Developer}"
                                                   FontSize="12" FontWeight="SemiBold"
                                                   Foreground="{StaticResource TextPrimary}"
                                                   TextTrimming="CharacterEllipsis"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="PUBLISHER" Classes="Label"/>
                                        <TextBlock Text="{Binding SelectedDetail.Publisher}"
                                                   FontSize="12" FontWeight="SemiBold"
                                                   Foreground="{StaticResource TextPrimary}"
                                                   TextTrimming="CharacterEllipsis"/>
                                    </StackPanel>
                                </Grid>

                                <!-- PC Requirements section -->
                                <Border BorderBrush="{StaticResource Border}" BorderThickness="0,1,0,0"
                                        Padding="0,12,0,0">
                                    <StackPanel>
                                        <Button Theme="{StaticResource PassthroughBtn}"
                                                Command="{Binding ToggleReqsCommand}"
                                                HorizontalAlignment="Stretch" Cursor="Hand">
                                            <Grid Margin="0,0,0,8">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="PC REQUIREMENTS"
                                                           Classes="Label" Margin="0"/>
                                                <Path Grid.Column="1" Data="{StaticResource LucideChevronDown}"
                                                      Width="12" Height="12" Stretch="Uniform"
                                                      Stroke="{StaticResource TextMuted}" StrokeThickness="1.7"
                                                      StrokeLineCap="Round"                                                      StrokeJoin="Round" Fill="Transparent"/>
                                            </Grid>
                                        </Button>

                                        <StackPanel IsVisible="{Binding IsReqsExpanded}">
                                            <!-- Column headers -->
                                            <Grid Margin="0,0,0,6">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="90"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="" FontSize="10"
                                                           Foreground="{StaticResource TextMuted}"/>
                                                <TextBlock Grid.Column="1" Text="MINIMUM" FontSize="10"
                                                           FontWeight="SemiBold" Foreground="{StaticResource TextMuted}"/>
                                                <TextBlock Grid.Column="2" Text="RECOMMENDED" FontSize="10"
                                                           FontWeight="SemiBold" Foreground="{StaticResource TextMuted}"/>
                                                <TextBlock Grid.Column="3" Text="YOUR PC" FontSize="10"
                                                           FontWeight="SemiBold" Foreground="{StaticResource TextMuted}"/>
                                            </Grid>

                                            <!-- Benchmark loading -->
                                            <TextBlock Text="Fetching benchmark scores..."
                                                       FontSize="10" Margin="0,0,0,6"
                                                       HorizontalAlignment="Right"
                                                       Foreground="{StaticResource TextMuted}"
                                                       IsVisible="{Binding IsSpecsLoading}"/>

                                            <!-- Spec rows -->
                                            <ItemsControl ItemsSource="{Binding SpecRows}" Margin="0,0,0,12">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate DataType="models:SpecRow">
                                                        <Grid Margin="0,0,0,6">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="90"/>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="*"/>
                                                            </Grid.ColumnDefinitions>
                                                            <TextBlock Grid.Column="0" Text="{Binding Label}"
                                                                       FontSize="11" FontWeight="SemiBold"
                                                                       Foreground="{StaticResource TextSecondary}"
                                                                       VerticalAlignment="Top"/>
                                                            <TextBlock Grid.Column="1" Text="{Binding MinValue}"
                                                                       FontSize="11" Foreground="{StaticResource TextBody}"
                                                                       TextWrapping="Wrap" Margin="0,0,8,0"
                                                                       VerticalAlignment="Top"/>
                                                            <TextBlock Grid.Column="2" Text="{Binding RecValue}"
                                                                       FontSize="11" Foreground="{StaticResource TextBody}"
                                                                       TextWrapping="Wrap" Margin="0,0,8,0"
                                                                       VerticalAlignment="Top"/>
                                                            <StackPanel Grid.Column="3" Orientation="Horizontal"
                                                                        VerticalAlignment="Top">
                                                                <Ellipse Width="7" Height="7"
                                                                         Margin="0,2,5,0" VerticalAlignment="Top"
                                                                         Fill="{Binding Status,
                                                                             Converter={StaticResource SpecToColor}}"/>
                                                                <TextBlock Text="{Binding UserValue}"
                                                                           FontSize="11" TextWrapping="Wrap"
                                                                           VerticalAlignment="Top"
                                                                           Foreground="{Binding Status,
                                                                               Converter={StaticResource SpecToColor}}"/>
                                                            </StackPanel>
                                                        </Grid>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>

                                <!-- Full Description section -->
                                <Border BorderBrush="{StaticResource Border}" BorderThickness="0,1,0,0"
                                        Margin="0,0,0,12" Padding="0,12,0,0">
                                    <StackPanel>
                                        <Button Theme="{StaticResource PassthroughBtn}"
                                                Command="{Binding ToggleDescriptionCommand}"
                                                HorizontalAlignment="Stretch" Cursor="Hand">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="FULL DESCRIPTION"
                                                           Classes="Label" Margin="0"/>
                                                <Path Grid.Column="1" Data="{StaticResource LucideChevronDown}"
                                                      Width="12" Height="12" Stretch="Uniform"
                                                      Stroke="{StaticResource TextMuted}" StrokeThickness="1.7"
                                                      StrokeLineCap="Round"                                                      StrokeJoin="Round" Fill="Transparent"/>
                                            </Grid>
                                        </Button>

                                        <StackPanel Margin="0,10,0,0"
                                                    IsVisible="{Binding IsDescriptionExpanded}">
                                            <!-- Screenshots strip -->
                                            <ScrollViewer x:Name="ScreenshotScroller"
                                                          HorizontalScrollBarVisibility="Hidden"
                                                          VerticalScrollBarVisibility="Disabled"
                                                          Margin="0,0,0,12"
                                                          Cursor="Hand"
                                                          PointerPressed="ScreenshotScroller_PointerPressed"
                                                          PointerMoved="ScreenshotScroller_PointerMoved"
                                                          PointerReleased="ScreenshotScroller_PointerReleased"
                                                          PointerCaptureLost="ScreenshotScroller_PointerCaptureLost"
                                                          PointerWheelChanged="ScreenshotScroller_PointerWheelChanged">
                                                <ItemsControl ItemsSource="{Binding SelectedDetail.Screenshots}">
                                                    <ItemsControl.ItemsPanel>
                                                        <ItemsPanelTemplate>
                                                            <StackPanel Orientation="Horizontal"/>
                                                        </ItemsPanelTemplate>
                                                    </ItemsControl.ItemsPanel>
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Border Width="200" Height="113"
                                                                    Margin="0,0,8,0"
                                                                    CornerRadius="8"
                                                                    ClipToBounds="True">
                                                                <Image Source="{Binding}" Stretch="UniformToFill"/>
                                                            </Border>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </ScrollViewer>

                                            <!-- Full description text -->
                                            <TextBlock Text="{Binding SelectedDetail.DetailedDescription}"
                                                       FontSize="12.5" Foreground="{StaticResource TextBody}"
                                                       TextWrapping="Wrap" LineHeight="20"
                                                       Margin="0,0,0,8"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>

                            </StackPanel>
                        </StackPanel>
                    </ScrollViewer>

                    <!-- Footer -->
                    <Border Grid.Row="2"
                            BorderBrush="{StaticResource Border}" BorderThickness="0,1,0,0"
                            Padding="20,14">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                <TextBlock Text="App ID" Classes="Label" Margin="0"/>
                                <TextBlock FontFamily="Consolas" FontSize="13"
                                           Foreground="{StaticResource TextSecondary}"
                                           Text="{Binding SelectedGame.Game.AppId}"/>
                            </StackPanel>

                            <!-- Provider dropdown -->
                            <Grid Grid.Column="1" VerticalAlignment="Center">
                                <ToggleButton x:Name="providerToggle"
                                              Theme="{StaticResource ProviderDropBtn}"
                                              IsChecked="{Binding IsProviderDropdownOpen, Mode=TwoWay}">
                                    <TextBlock Text="{Binding SelectedProviderLabel}"/>
                                </ToggleButton>

                                <Popup IsOpen="{Binding IsProviderDropdownOpen, Mode=TwoWay}"
                                       IsLightDismissEnabled="True"
                                       Placement="Bottom"
                                       PlacementTarget="{Binding #providerToggle}"
                                       VerticalOffset="5">
                                    <Border Background="White"
                                            CornerRadius="9"
                                            BorderBrush="{StaticResource Border}"
                                            BorderThickness="1"
                                            Padding="4"
                                            MinWidth="170">
                                        <StackPanel>
                                            <Button Theme="{StaticResource ProviderDropItem}"
                                                    Command="{Binding SelectProviderCommand}"
                                                    CommandParameter="{x:Static vm:ManifestProvider.Ryuu}"
                                                    IsEnabled="{Binding CanUseRyuu}">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel Grid.Column="0">
                                                        <TextBlock Text="Ryuu" FontWeight="SemiBold" FontSize="13"/>
                                                        <TextBlock Text="No API key configured"
                                                                   FontSize="10.5" Margin="0,1,0,0"
                                                                   Foreground="{StaticResource TextMuted}"
                                                                   IsVisible="{Binding CanUseRyuu,
                                                                       Converter={StaticResource InvBoolToVis}}"/>
                                                    </StackPanel>
                                                    <Path Grid.Column="1" Data="{StaticResource LucideCheck}"
                                                          Width="13" Height="13" Stretch="Uniform"
                                                          Margin="14,0,2,0" VerticalAlignment="Center"
                                                          IsVisible="{Binding IsRyuuSelected}"
                                                          Stroke="{StaticResource Accent}" StrokeThickness="2"
                                                          Fill="Transparent" StrokeLineCap="Round"
                                                          StrokeJoin="Round"/>
                                                </Grid>
                                            </Button>

                                            <Button Theme="{StaticResource ProviderDropItem}"
                                                    Command="{Binding SelectProviderCommand}"
                                                    CommandParameter="{x:Static vm:ManifestProvider.Hubcap}"
                                                    IsEnabled="{Binding CanUseHubcap}">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel Grid.Column="0">
                                                        <TextBlock Text="Hubcap" FontWeight="SemiBold" FontSize="13"/>
                                                        <TextBlock Text="No API key configured"
                                                                   FontSize="10.5" Margin="0,1,0,0"
                                                                   Foreground="{StaticResource TextMuted}"
                                                                   IsVisible="{Binding CanUseHubcap,
                                                                       Converter={StaticResource InvBoolToVis}}"/>
                                                    </StackPanel>
                                                    <Path Grid.Column="1" Data="{StaticResource LucideCheck}"
                                                          Width="13" Height="13" Stretch="Uniform"
                                                          Margin="14,0,2,0" VerticalAlignment="Center"
                                                          IsVisible="{Binding IsHubcapSelected}"
                                                          Stroke="{StaticResource Accent}" StrokeThickness="2"
                                                          Fill="Transparent" StrokeLineCap="Round"
                                                          StrokeJoin="Round"/>
                                                </Grid>
                                            </Button>
                                        </StackPanel>
                                    </Border>
                                </Popup>
                            </Grid>

                            <Button Grid.Column="3"
                                    Theme="{StaticResource BtnPrimary}"
                                    Padding="24,10"
                                    Command="{Binding DownloadGameCommand}">
                                <StackPanel Orientation="Horizontal">
                                    <Path Data="{StaticResource LucideDownload}"
                                          Width="15" Height="15" Stretch="Uniform" Margin="0,0,8,0"
                                          Stroke="White" StrokeThickness="1.7" Fill="Transparent"
                                          StrokeLineCap="Round" StrokeJoin="Round"/>
                                    <TextBlock Text="Download" FontSize="13" FontWeight="SemiBold" Foreground="White"/>
                                </StackPanel>
                            </Button>
                        </Grid>
                    </Border>
                </Grid>
            </Border>
        </Grid>

    </Grid>
</UserControl>
