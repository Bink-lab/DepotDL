<UserControl x:Class="DepotDL.GUI.Views.StoreView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:DepotDL.GUI.ViewModels"
             xmlns:models="clr-namespace:DepotDL.GUI.Models"
             FontFamily="Segoe UI">

    <UserControl.Resources>
        <!-- SpecStatus → colour converters inline via styles -->
        <Style x:Key="SpecStatusDot" TargetType="Ellipse">
            <Setter Property="Width" Value="8"/>
            <Setter Property="Height" Value="8"/>
            <Setter Property="Fill" Value="#888"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,6,0"/>
        </Style>

        <!-- Provider dropdown trigger button -->
        <Style x:Key="ProviderDropBtn" TargetType="ToggleButton">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Padding" Value="13,8"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="12.5"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="bd"
                                Background="White"
                                BorderBrush="{StaticResource Border}"
                                BorderThickness="1.5"
                                CornerRadius="7"
                                Padding="{TemplateBinding Padding}">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <ContentPresenter VerticalAlignment="Center"/>
                                <Viewbox Width="10" Height="10" Margin="6,1,0,0" VerticalAlignment="Center">
                                    <Canvas Width="24" Height="24">
                                        <Path x:Name="chevron"
                                              Data="M6,9 L12,15 L18,9"
                                              Stroke="{StaticResource TextSecondary}"
                                              StrokeThickness="2.5"
                                              StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                              StrokeLineJoin="Round" Fill="Transparent"/>
                                    </Canvas>
                                </Viewbox>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{StaticResource AccentVeryLight}"/>
                                <Setter TargetName="bd" Property="BorderBrush" Value="{StaticResource Accent}"/>
                                <Setter Property="Foreground" Value="{StaticResource Accent}"/>
                                <Setter TargetName="chevron" Property="Stroke" Value="{StaticResource Accent}"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{StaticResource AccentLight}"/>
                                <Setter TargetName="bd" Property="BorderBrush" Value="{StaticResource Accent}"/>
                                <Setter Property="Foreground" Value="{StaticResource Accent}"/>
                                <Setter TargetName="chevron" Property="Stroke" Value="{StaticResource Accent}"/>
                                <Setter TargetName="chevron" Property="Data" Value="M6,15 L12,9 L18,15"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Provider dropdown item -->
        <Style x:Key="ProviderDropItem" TargetType="Button">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="5"
                                Padding="10,9">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{StaticResource AccentVeryLight}"/>
                                <Setter Property="Foreground" Value="{StaticResource Accent}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="{StaticResource TextMuted}"/>
                                <Setter Property="Cursor" Value="Arrow"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>

        <!-- ══ Main content ══════════════════════════════════════════ -->
        <Grid Margin="24,28,20,16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="16"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="12"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="12"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Grid Grid.Row="0">
                <StackPanel>
                    <TextBlock Style="{StaticResource TextH1}" Text="Steam Store"/>
                    <TextBlock Style="{StaticResource BodyText}" Margin="0,4,0,0"
                               Text="{Binding GamesInfo, FallbackValue='Browse all Steam games'}"/>
                </StackPanel>
            </Grid>

            <!-- Search bar -->
            <Border Grid.Row="2"
                    Background="{StaticResource BgCard}"
                    BorderBrush="{StaticResource Border}"
                    BorderThickness="1"
                    CornerRadius="10">
                <Grid Margin="12,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Viewbox Grid.Column="0" Width="15" Height="15" Margin="0,0,10,0">
                        <Canvas Width="24" Height="24">
                            <Ellipse Canvas.Left="3" Canvas.Top="3" Width="14" Height="14"
                                     Stroke="{StaticResource TextMuted}" StrokeThickness="2"/>
                            <Path Data="M15,15 L21,21"
                                  Stroke="{StaticResource TextMuted}"
                                  StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                        </Canvas>
                    </Viewbox>
                    <TextBox Grid.Column="1"
                             BorderThickness="0"
                             Background="Transparent"
                             Padding="0,10"
                             FontSize="13"
                             Foreground="{StaticResource TextPrimary}"
                             Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                             CaretBrush="{StaticResource Accent}">
                        <TextBox.Template>
                            <ControlTemplate TargetType="TextBox">
                                <ScrollViewer x:Name="PART_ContentHost"
                                              Margin="{TemplateBinding Padding}"
                                              VerticalAlignment="Center"/>
                            </ControlTemplate>
                        </TextBox.Template>
                    </TextBox>
                </Grid>
            </Border>

            <!-- Game grid area: spinner / empty / games all layered -->
            <Grid Grid.Row="4">

                <!-- ① Loading spinner (first fetch only, while no games yet) -->
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                            Visibility="{Binding ShowLoadingSpinner, Converter={StaticResource BoolToVis}}">
                    <Grid Width="52" Height="52" HorizontalAlignment="Center" Margin="0,0,0,18">
                        <Ellipse Stroke="{StaticResource AccentLight}" StrokeThickness="4"/>
                        <Ellipse Stroke="{StaticResource Accent}" StrokeThickness="4"
                                 StrokeDashArray="35 1000"
                                 RenderTransformOrigin="0.5,0.5">
                            <Ellipse.RenderTransform>
                                <RotateTransform/>
                            </Ellipse.RenderTransform>
                            <Ellipse.Triggers>
                                <EventTrigger RoutedEvent="Ellipse.Loaded">
                                    <BeginStoryboard>
                                        <Storyboard RepeatBehavior="Forever">
                                            <DoubleAnimation
                                                Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)"
                                                From="0" To="360" Duration="0:0:0.85"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger>
                            </Ellipse.Triggers>
                        </Ellipse>
                    </Grid>
                    <TextBlock Text="{Binding LoadingStatus}"
                               FontSize="13" Foreground="{StaticResource TextMuted}"
                               HorizontalAlignment="Center"/>
                </StackPanel>

                <!-- ② Empty state -->
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                            Visibility="{Binding ShowEmptyState, Converter={StaticResource BoolToVis}}">
                    <Border Width="64" Height="64" CornerRadius="16"
                            Background="{StaticResource AccentVeryLight}"
                            HorizontalAlignment="Center" Margin="0,0,0,16">
                        <Viewbox Width="28" Height="28">
                            <Canvas Width="24" Height="24">
                                <Path Data="M6,2 L18,2 C19.1,2 20,2.9 20,4 L20,20 C20,21.1 19.1,22 18,22 L6,22 C4.9,22 4,21.1 4,20 L4,4 C4,2.9 4.9,2 6,2 M9,7 L15,7 M9,11 L15,11 M9,15 L12,15"
                                      Stroke="{StaticResource Accent}"
                                      StrokeThickness="1.8" Fill="Transparent"
                                      StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                            </Canvas>
                        </Viewbox>
                    </Border>
                    <TextBlock Text="No games found" Style="{StaticResource TextH3}"
                               HorizontalAlignment="Center" Margin="0,0,0,6"/>
                    <TextBlock Text="Try a different search term."
                               Style="{StaticResource BodyText}" HorizontalAlignment="Center"/>
                </StackPanel>

                <!-- ③ Game cards with page-transition animation -->
                <ScrollViewer x:Name="GameScrollViewer"
                              VerticalScrollBarVisibility="Auto"
                              Visibility="{Binding HasGames, Converter={StaticResource BoolToVis}}">
                    <ScrollViewer.Style>
                        <Style TargetType="ScrollViewer">
                            <Setter Property="Opacity" Value="1"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsPageTransitioning}" Value="True">
                                    <DataTrigger.EnterActions>
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                 To="0" Duration="0:0:0.12">
                                                    <DoubleAnimation.EasingFunction>
                                                        <CubicEase EasingMode="EaseOut"/>
                                                    </DoubleAnimation.EasingFunction>
                                                </DoubleAnimation>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </DataTrigger.EnterActions>
                                    <DataTrigger.ExitActions>
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                 To="1" Duration="0:0:0.20">
                                                    <DoubleAnimation.EasingFunction>
                                                        <CubicEase EasingMode="EaseOut"/>
                                                    </DoubleAnimation.EasingFunction>
                                                </DoubleAnimation>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </DataTrigger.ExitActions>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ScrollViewer.Style>
                    <ItemsControl ItemsSource="{Binding DisplayedGames}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type vm:StoreGameViewModel}">
                                <Border Width="193" Margin="0,0,8,8" Cursor="Hand">
                                    <Border Style="{StaticResource Card}" Padding="0"
                                            ClipToBounds="True" Effect="{x:Null}">
                                        <Border.RenderTransform>
                                            <TranslateTransform/>
                                        </Border.RenderTransform>
                                        <Border.InputBindings>
                                            <MouseBinding MouseAction="LeftClick"
                                                          Command="{Binding DataContext.OpenOverlayCommand,
                                                              RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                          CommandParameter="{Binding}"/>
                                        </Border.InputBindings>
                                        <Border.Triggers>
                                            <EventTrigger RoutedEvent="MouseEnter">
                                                <BeginStoryboard>
                                                    <Storyboard>
                                                        <DoubleAnimation
                                                            Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                                                            To="-3" Duration="0:0:0.15">
                                                            <DoubleAnimation.EasingFunction>
                                                                <CubicEase EasingMode="EaseOut"/>
                                                            </DoubleAnimation.EasingFunction>
                                                        </DoubleAnimation>
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </EventTrigger>
                                            <EventTrigger RoutedEvent="MouseLeave">
                                                <BeginStoryboard>
                                                    <Storyboard>
                                                        <DoubleAnimation
                                                            Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                                                            To="0" Duration="0:0:0.15">
                                                            <DoubleAnimation.EasingFunction>
                                                                <CubicEase EasingMode="EaseOut"/>
                                                            </DoubleAnimation.EasingFunction>
                                                        </DoubleAnimation>
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </EventTrigger>
                                        </Border.Triggers>

                                        <Grid>
                                            <!-- Game image via ImageBrush — respects CornerRadius -->
                                            <Border Height="96" VerticalAlignment="Top"
                                                    CornerRadius="13,13,0,0">
                                                <Border.Background>
                                                    <ImageBrush ImageSource="{Binding HeaderImage}" Stretch="UniformToFill"/>
                                                </Border.Background>
                                            </Border>

                                            <!-- Shimmer placeholder -->
                                            <Border Height="96" VerticalAlignment="Top"
                                                    CornerRadius="13,13,0,0"
                                                    Background="{StaticResource AccentLight}">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsImageLoading}" Value="True">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <Border.Triggers>
                                                    <EventTrigger RoutedEvent="Border.Loaded">
                                                        <BeginStoryboard>
                                                            <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                                                <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                                 From="0.4" To="0.9" Duration="0:0:0.75"/>
                                                            </Storyboard>
                                                        </BeginStoryboard>
                                                    </EventTrigger>
                                                </Border.Triggers>
                                            </Border>

                                            <!-- Game name -->
                                            <Border Margin="0,96,0,0" Padding="10,8,10,10">
                                                <TextBlock Text="{Binding Game.Name}"
                                                           FontSize="12.5" FontWeight="SemiBold"
                                                           Foreground="{StaticResource TextPrimary}"
                                                           TextTrimming="CharacterEllipsis"/>
                                            </Border>
                                        </Grid>
                                    </Border>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>

            <!-- Pagination -->
            <Grid Grid.Row="6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="{Binding GamesInfo}"
                           FontSize="12" Foreground="{StaticResource TextMuted}"
                           VerticalAlignment="Center"/>

                <StackPanel Grid.Column="1" Orientation="Horizontal">

                    <!-- Prev button with scale animation -->
                    <Button Style="{StaticResource BtnSecondary}"
                            Padding="12,6" FontSize="12"
                            Command="{Binding PrevPageCommand}"
                            IsEnabled="{Binding HasPrev}"
                            RenderTransformOrigin="0.5,0.5">
                        <Button.RenderTransform>
                            <ScaleTransform/>
                        </Button.RenderTransform>
                        <Button.Triggers>
                            <EventTrigger RoutedEvent="MouseEnter">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" To="1.05" Duration="0:0:0.1"/>
                                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" To="1.05" Duration="0:0:0.1"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <EventTrigger RoutedEvent="MouseLeave">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" To="1" Duration="0:0:0.1"/>
                                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" To="1" Duration="0:0:0.1"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <EventTrigger RoutedEvent="PreviewMouseLeftButtonDown">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" To="0.94" Duration="0:0:0.06"/>
                                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" To="0.94" Duration="0:0:0.06"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <EventTrigger RoutedEvent="PreviewMouseLeftButtonUp">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" To="1.05" Duration="0:0:0.08"/>
                                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" To="1.05" Duration="0:0:0.08"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </Button.Triggers>
                        <StackPanel Orientation="Horizontal">
                            <Viewbox Width="12" Height="12" Margin="0,0,5,0">
                                <Canvas Width="24" Height="24">
                                    <Path Data="M15,6 L9,12 L15,18"
                                          Stroke="{StaticResource TextBody}"
                                          StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="Transparent"/>
                                </Canvas>
                            </Viewbox>
                            <TextBlock Text="Prev" Foreground="{StaticResource TextBody}"/>
                        </StackPanel>
                    </Button>

                    <TextBlock Text="{Binding PageInfo}"
                               FontSize="12" Foreground="{StaticResource TextSecondary}"
                               VerticalAlignment="Center" Margin="14,0"/>

                    <!-- Next button with scale animation -->
                    <Button Style="{StaticResource BtnSecondary}"
                            Padding="12,6" FontSize="12"
                            Command="{Binding NextPageCommand}"
                            IsEnabled="{Binding HasNext}"
                            RenderTransformOrigin="0.5,0.5">
                        <Button.RenderTransform>
                            <ScaleTransform/>
                        </Button.RenderTransform>
                        <Button.Triggers>
                            <EventTrigger RoutedEvent="MouseEnter">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" To="1.05" Duration="0:0:0.1"/>
                                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" To="1.05" Duration="0:0:0.1"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <EventTrigger RoutedEvent="MouseLeave">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" To="1" Duration="0:0:0.1"/>
                                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" To="1" Duration="0:0:0.1"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <EventTrigger RoutedEvent="PreviewMouseLeftButtonDown">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" To="0.94" Duration="0:0:0.06"/>
                                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" To="0.94" Duration="0:0:0.06"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <EventTrigger RoutedEvent="PreviewMouseLeftButtonUp">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" To="1.05" Duration="0:0:0.08"/>
                                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" To="1.05" Duration="0:0:0.08"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </Button.Triggers>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Next" Foreground="{StaticResource TextBody}"/>
                            <Viewbox Width="12" Height="12" Margin="5,0,0,0">
                                <Canvas Width="24" Height="24">
                                    <Path Data="M9,6 L15,12 L9,18"
                                          Stroke="{StaticResource TextBody}"
                                          StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="Transparent"/>
                                </Canvas>
                            </Viewbox>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Grid>

        <!-- ══ Game detail overlay ══════════════════════════════════════════ -->
        <Grid x:Name="OverlayRoot" Panel.ZIndex="50" Opacity="0"
              IsHitTestVisible="{Binding OverlayVisible}">
            <Grid.Style>
                <Style TargetType="Grid">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding OverlayVisible}" Value="True">
                            <DataTrigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                         To="1" Duration="0:0:0.22">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </DataTrigger.EnterActions>
                            <DataTrigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                         To="0" Duration="0:0:0.18"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </DataTrigger.ExitActions>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Grid.Style>

            <!-- Backdrop -->
            <Rectangle Fill="#1C1610" Opacity="0.72">
                <Rectangle.InputBindings>
                    <MouseBinding MouseAction="LeftClick" Command="{Binding CloseOverlayCommand}"/>
                </Rectangle.InputBindings>
            </Rectangle>

            <!-- Card -->
            <Border Margin="80,50"
                    MaxWidth="1000" MaxHeight="820"
                    HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                    Background="{StaticResource BgCard}"
                    CornerRadius="16"
                    BorderBrush="{StaticResource Border}"
                    BorderThickness="1"
                    ClipToBounds="True">
                <Border.RenderTransform>
                    <TranslateTransform/>
                </Border.RenderTransform>
                <Border.Style>
                    <Style TargetType="Border">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding OverlayVisible}" Value="True">
                                <DataTrigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation
                                                Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                                                From="28" To="0" Duration="0:0:0.28">
                                                <DoubleAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseOut"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </DataTrigger.EnterActions>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="162"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- ── Hero image (ImageBrush → proper rounded corners) ── -->
                    <Border Grid.Row="0" CornerRadius="16,16,0,0">
                        <Border.Background>
                            <ImageBrush ImageSource="{Binding SelectedGame.HeaderImage}" Stretch="UniformToFill"/>
                        </Border.Background>
                        <Grid>
                            <!-- Dim overlay -->
                            <Border Background="#1C1610" Opacity="0.45" CornerRadius="16,16,0,0"/>
                            <!-- Close button -->
                            <Button HorizontalAlignment="Right" VerticalAlignment="Top"
                                    Margin="0,10,10,0"
                                    Command="{Binding CloseOverlayCommand}"
                                    Width="30" Height="30"
                                    BorderThickness="0"
                                    Cursor="Hand">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="bg" CornerRadius="8"
                                                Background="#88000000"
                                                Width="30" Height="30">
                                            <Viewbox Width="14" Height="14"
                                                     HorizontalAlignment="Center"
                                                     VerticalAlignment="Center">
                                                <Canvas Width="24" Height="24">
                                                    <Path Data="M6,6 L18,18 M18,6 L6,18"
                                                          Stroke="White" StrokeThickness="2.2"
                                                          StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                                                </Canvas>
                                            </Viewbox>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="bg" Property="Background" Value="#BB000000"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                            <!-- Title overlay -->
                            <StackPanel VerticalAlignment="Bottom" Margin="20,0,20,16">
                                <TextBlock Text="{Binding SelectedGame.Game.Name}"
                                           FontSize="20" FontWeight="Bold" Foreground="White"
                                           TextTrimming="CharacterEllipsis"/>
                                <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                    <TextBlock Text="{Binding SelectedGame.Game.Developer}"
                                               FontSize="12" Foreground="#CCFFFFFF"/>
                                    <TextBlock Text=" · "
                                               FontSize="12" Foreground="#88FFFFFF"
                                               Visibility="{Binding SelectedGame.Game.Developer,
                                                   Converter={StaticResource NotEmptyToVis}}"/>
                                    <TextBlock Text="{Binding SelectedGame.PriceDisplay}"
                                               FontSize="12" FontWeight="SemiBold" Foreground="#FFDDA060"/>
                                </StackPanel>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- ── Content ── -->
                    <ScrollViewer Grid.Row="1" Margin="20,16,20,0" VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <!-- Loading text -->
                            <TextBlock Text="Loading details..."
                                       FontSize="13" Foreground="{StaticResource TextMuted}"
                                       HorizontalAlignment="Center" Margin="0,20">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsDetailLoading}" Value="True">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>

                            <!-- Details (shown once loaded) -->
                            <StackPanel>
                                <StackPanel.Style>
                                    <Style TargetType="StackPanel">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsDetailLoading}" Value="False">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </StackPanel.Style>

                                <!-- Short description -->
                                <TextBlock Text="{Binding SelectedDetail.ShortDescription}"
                                           FontSize="13" Foreground="{StaticResource TextBody}"
                                           TextWrapping="Wrap" LineHeight="20"
                                           Margin="0,0,0,14"/>

                                <!-- Genre tags -->
                                <ItemsControl ItemsSource="{Binding SelectedDetail.Genres}"
                                              Margin="0,0,0,14">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="{StaticResource AccentSubtle}"
                                                    BorderBrush="{StaticResource AccentLight}"
                                                    BorderThickness="1"
                                                    CornerRadius="6" Padding="8,3" Margin="0,0,6,6">
                                                <TextBlock Text="{Binding}" FontSize="11"
                                                           Foreground="{StaticResource Accent}"
                                                           FontWeight="SemiBold"/>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <!-- Stats grid -->
                                <Grid Margin="0,0,0,16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="REVIEWS" Style="{StaticResource TextLabel}"/>
                                        <TextBlock Text="{Binding SelectedGame.ReviewRatio}"
                                                   FontSize="12" FontWeight="SemiBold"
                                                   Foreground="{StaticResource TextPrimary}"
                                                   TextWrapping="Wrap"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="DEVELOPER" Style="{StaticResource TextLabel}"/>
                                        <TextBlock Text="{Binding SelectedDetail.Developer}"
                                                   FontSize="12" FontWeight="SemiBold"
                                                   Foreground="{StaticResource TextPrimary}"
                                                   TextTrimming="CharacterEllipsis"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="PUBLISHER" Style="{StaticResource TextLabel}"/>
                                        <TextBlock Text="{Binding SelectedDetail.Publisher}"
                                                   FontSize="12" FontWeight="SemiBold"
                                                   Foreground="{StaticResource TextPrimary}"
                                                   TextTrimming="CharacterEllipsis"/>
                                    </StackPanel>
                                </Grid>

                                <!-- ── PC Requirements section ── -->
                                <Border BorderBrush="{StaticResource Border}" BorderThickness="0,1,0,0"
                                        Margin="0,0,0,0" Padding="0,12,0,0">
                                    <StackPanel>
                                        <!-- Header (always visible, clickable) -->
                                        <Button Command="{Binding ToggleReqsCommand}"
                                                Background="Transparent" BorderThickness="0"
                                                HorizontalContentAlignment="Stretch" Padding="0"
                                                Cursor="Hand">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="Transparent">
                                                        <ContentPresenter/>
                                                    </Border>
                                                </ControlTemplate>
                                            </Button.Template>
                                            <Grid Margin="0,0,0,8">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="PC REQUIREMENTS"
                                                           Style="{StaticResource TextLabel}" Margin="0"/>
                                                <!-- Chevron -->
                                                <Viewbox Grid.Column="1" Width="12" Height="12">
                                                    <Canvas Width="24" Height="24">
                                                        <Path x:Name="ChevronReqs"
                                                              Data="M6,9 L12,15 L18,9"
                                                              Stroke="{StaticResource TextMuted}"
                                                              StrokeThickness="2"
                                                              StrokeStartLineCap="Round"
                                                              StrokeEndLineCap="Round"
                                                              Fill="Transparent"/>
                                                    </Canvas>
                                                </Viewbox>
                                            </Grid>
                                        </Button>

                                        <!-- Requirements table (collapsed by default) -->
                                        <StackPanel>
                                            <StackPanel.Style>
                                                <Style TargetType="StackPanel">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsReqsExpanded}" Value="True">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </StackPanel.Style>

                                            <!-- Column headers -->
                                            <Grid Margin="0,0,0,6">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="90"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="" FontSize="10" Foreground="{StaticResource TextMuted}"/>
                                                <TextBlock Grid.Column="1" Text="MINIMUM"   FontSize="10" FontWeight="SemiBold" Foreground="{StaticResource TextMuted}"/>
                                                <TextBlock Grid.Column="2" Text="RECOMMENDED" FontSize="10" FontWeight="SemiBold" Foreground="{StaticResource TextMuted}"/>
                                                <TextBlock Grid.Column="3" Text="YOUR PC"   FontSize="10" FontWeight="SemiBold" Foreground="{StaticResource TextMuted}"/>
                                            </Grid>

                                            <!-- Benchmark loading indicator -->
                                            <TextBlock Text="Fetching benchmark scores..."
                                                       FontSize="10" Margin="0,0,0,6"
                                                       HorizontalAlignment="Right">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="{StaticResource TextMuted}"/>
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsSpecsLoading}" Value="True">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>

                                            <!-- Spec rows -->
                                            <ItemsControl ItemsSource="{Binding SpecRows}" Margin="0,0,0,12">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate DataType="{x:Type models:SpecRow}">
                                                        <Grid Margin="0,0,0,6">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="90"/>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="*"/>
                                                            </Grid.ColumnDefinitions>
                                                            <!-- Label -->
                                                            <TextBlock Grid.Column="0" Text="{Binding Label}"
                                                                       FontSize="11" FontWeight="SemiBold"
                                                                       Foreground="{StaticResource TextSecondary}"
                                                                       VerticalAlignment="Top"/>
                                                            <!-- Min -->
                                                            <TextBlock Grid.Column="1" Text="{Binding MinValue}"
                                                                       FontSize="11" Foreground="{StaticResource TextBody}"
                                                                       TextWrapping="Wrap" Margin="0,0,8,0"
                                                                       VerticalAlignment="Top"/>
                                                            <!-- Rec -->
                                                            <TextBlock Grid.Column="2" Text="{Binding RecValue}"
                                                                       FontSize="11" Foreground="{StaticResource TextBody}"
                                                                       TextWrapping="Wrap" Margin="0,0,8,0"
                                                                       VerticalAlignment="Top"/>
                                                            <!-- Yours with status dot -->
                                                            <StackPanel Grid.Column="3" Orientation="Horizontal"
                                                                        VerticalAlignment="Top">
                                                                <!-- Status dot colour via styles -->
                                                                <Ellipse Width="7" Height="7"
                                                                         Margin="0,2,5,0" VerticalAlignment="Top">
                                                                    <Ellipse.Style>
                                                                        <Style TargetType="Ellipse">
                                                                            <Setter Property="Fill" Value="#888"/>
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding Status}" Value="MeetsRecommended">
                                                                                    <Setter Property="Fill" Value="#4CAF50"/>
                                                                                </DataTrigger>
                                                                                <DataTrigger Binding="{Binding Status}" Value="MeetsMinimum">
                                                                                    <Setter Property="Fill" Value="#FF9800"/>
                                                                                </DataTrigger>
                                                                                <DataTrigger Binding="{Binding Status}" Value="BelowMinimum">
                                                                                    <Setter Property="Fill" Value="#F44336"/>
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </Ellipse.Style>
                                                                </Ellipse>
                                                                <TextBlock Text="{Binding UserValue}"
                                                                           FontSize="11" TextWrapping="Wrap"
                                                                           VerticalAlignment="Top">
                                                                    <TextBlock.Style>
                                                                        <Style TargetType="TextBlock">
                                                                            <Setter Property="Foreground" Value="{StaticResource TextBody}"/>
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding Status}" Value="MeetsRecommended">
                                                                                    <Setter Property="Foreground" Value="#4CAF50"/>
                                                                                </DataTrigger>
                                                                                <DataTrigger Binding="{Binding Status}" Value="MeetsMinimum">
                                                                                    <Setter Property="Foreground" Value="#FF9800"/>
                                                                                </DataTrigger>
                                                                                <DataTrigger Binding="{Binding Status}" Value="BelowMinimum">
                                                                                    <Setter Property="Foreground" Value="#F44336"/>
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </TextBlock.Style>
                                                                </TextBlock>
                                                            </StackPanel>
                                                        </Grid>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>

                                <!-- ── Full Description section ── -->
                                <Border BorderBrush="{StaticResource Border}" BorderThickness="0,1,0,0"
                                        Margin="0,0,0,12" Padding="0,12,0,0">
                                    <StackPanel>
                                        <!-- Header (always visible, clickable) -->
                                        <Button Command="{Binding ToggleDescriptionCommand}"
                                                Background="Transparent" BorderThickness="0"
                                                HorizontalContentAlignment="Stretch" Padding="0"
                                                Cursor="Hand">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="Transparent">
                                                        <ContentPresenter/>
                                                    </Border>
                                                </ControlTemplate>
                                            </Button.Template>
                                            <Grid Margin="0,0,0,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="FULL DESCRIPTION"
                                                           Style="{StaticResource TextLabel}" Margin="0"/>
                                                <Viewbox Grid.Column="1" Width="12" Height="12">
                                                    <Canvas Width="24" Height="24">
                                                        <Path Data="M6,9 L12,15 L18,9"
                                                              Stroke="{StaticResource TextMuted}"
                                                              StrokeThickness="2"
                                                              StrokeStartLineCap="Round"
                                                              StrokeEndLineCap="Round"
                                                              Fill="Transparent"/>
                                                    </Canvas>
                                                </Viewbox>
                                            </Grid>
                                        </Button>

                                        <!-- Expanded content -->
                                        <StackPanel Margin="0,10,0,0">
                                            <StackPanel.Style>
                                                <Style TargetType="StackPanel">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsDescriptionExpanded}" Value="True">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </StackPanel.Style>

                                            <!-- Screenshots strip -->
                                            <ScrollViewer x:Name="ScreenshotScroller"
                                                          HorizontalScrollBarVisibility="Hidden"
                                                          VerticalScrollBarVisibility="Disabled"
                                                          Margin="0,0,0,12"
                                                          Cursor="Hand"
                                                          PreviewMouseLeftButtonDown="ScreenshotScroller_MouseDown"
                                                          PreviewMouseMove="ScreenshotScroller_MouseMove"
                                                          PreviewMouseLeftButtonUp="ScreenshotScroller_MouseUp"
                                                          MouseLeave="ScreenshotScroller_MouseLeave">
                                                <ItemsControl ItemsSource="{Binding SelectedDetail.Screenshots}">
                                                    <ItemsControl.ItemsPanel>
                                                        <ItemsPanelTemplate>
                                                            <StackPanel Orientation="Horizontal"/>
                                                        </ItemsPanelTemplate>
                                                    </ItemsControl.ItemsPanel>
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Border Width="200" Height="113"
                                                                    Margin="0,0,8,0"
                                                                    CornerRadius="8"
                                                                    ClipToBounds="True">
                                                                <Image Source="{Binding}" Stretch="UniformToFill"/>
                                                            </Border>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </ScrollViewer>

                                            <!-- Full description text -->
                                            <TextBlock Text="{Binding SelectedDetail.DetailedDescription}"
                                                       FontSize="12.5" Foreground="{StaticResource TextBody}"
                                                       TextWrapping="Wrap" LineHeight="20"
                                                       Margin="0,0,0,8"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>

                            </StackPanel>
                        </StackPanel>
                    </ScrollViewer>

                    <!-- ── Footer ── -->
                    <Border Grid.Row="2"
                            BorderBrush="{StaticResource Border}" BorderThickness="0,1,0,0"
                            Padding="20,14">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                <TextBlock Text="App ID" Style="{StaticResource TextLabel}" Margin="0"/>
                                <TextBlock FontFamily="Consolas" FontSize="13"
                                           Foreground="{StaticResource TextSecondary}"
                                           Text="{Binding SelectedGame.Game.AppId}"/>
                            </StackPanel>

                            <!-- Provider dropdown -->
                            <Grid Grid.Column="1" VerticalAlignment="Center">
                                <ToggleButton x:Name="providerToggle"
                                              Style="{StaticResource ProviderDropBtn}"
                                              IsChecked="{Binding IsProviderDropdownOpen, Mode=TwoWay}">
                                    <TextBlock Text="{Binding SelectedProviderLabel}"/>
                                </ToggleButton>

                                <Popup IsOpen="{Binding IsProviderDropdownOpen, Mode=TwoWay}"
                                       StaysOpen="False"
                                       Placement="Bottom"
                                       PlacementTarget="{Binding ElementName=providerToggle}"
                                       VerticalOffset="5"
                                       PopupAnimation="Fade"
                                       AllowsTransparency="True">
                                    <Border Background="White"
                                            CornerRadius="9"
                                            BorderBrush="{StaticResource Border}"
                                            BorderThickness="1"
                                            Padding="4"
                                            MinWidth="170">
                                        <Border.Effect>
                                            <DropShadowEffect BlurRadius="18" ShadowDepth="3" Direction="270"
                                                              Color="#1C1610" Opacity="0.10"/>
                                        </Border.Effect>
                                        <StackPanel>
                                            <!-- Ryuu option -->
                                            <Button Style="{StaticResource ProviderDropItem}"
                                                    Command="{Binding SelectProviderCommand}"
                                                    CommandParameter="{x:Static vm:ManifestProvider.Ryuu}"
                                                    IsEnabled="{Binding CanUseRyuu}">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel Grid.Column="0">
                                                        <TextBlock Text="Ryuu" FontWeight="SemiBold" FontSize="13"/>
                                                        <TextBlock Text="No API key configured"
                                                                   FontSize="10.5" Margin="0,1,0,0"
                                                                   Foreground="{StaticResource TextMuted}"
                                                                   Visibility="{Binding CanUseRyuu, Converter={StaticResource InvBoolToVis}}"/>
                                                    </StackPanel>
                                                    <Viewbox Grid.Column="1" Width="13" Height="13"
                                                             Margin="14,0,2,0" VerticalAlignment="Center"
                                                             Visibility="{Binding IsRyuuSelected, Converter={StaticResource BoolToVis}}">
                                                        <Canvas Width="24" Height="24">
                                                            <Path Data="M5,12 L10,17 L19,7"
                                                                  Stroke="{StaticResource Accent}"
                                                                  StrokeThickness="2.5" Fill="Transparent"
                                                                  StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                                                  StrokeLineJoin="Round"/>
                                                        </Canvas>
                                                    </Viewbox>
                                                </Grid>
                                            </Button>

                                            <!-- Hubcap option -->
                                            <Button Style="{StaticResource ProviderDropItem}"
                                                    Command="{Binding SelectProviderCommand}"
                                                    CommandParameter="{x:Static vm:ManifestProvider.Hubcap}"
                                                    IsEnabled="{Binding CanUseHubcap}">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel Grid.Column="0">
                                                        <TextBlock Text="Hubcap" FontWeight="SemiBold" FontSize="13"/>
                                                        <TextBlock Text="No API key configured"
                                                                   FontSize="10.5" Margin="0,1,0,0"
                                                                   Foreground="{StaticResource TextMuted}"
                                                                   Visibility="{Binding CanUseHubcap, Converter={StaticResource InvBoolToVis}}"/>
                                                    </StackPanel>
                                                    <Viewbox Grid.Column="1" Width="13" Height="13"
                                                             Margin="14,0,2,0" VerticalAlignment="Center"
                                                             Visibility="{Binding IsHubcapSelected, Converter={StaticResource BoolToVis}}">
                                                        <Canvas Width="24" Height="24">
                                                            <Path Data="M5,12 L10,17 L19,7"
                                                                  Stroke="{StaticResource Accent}"
                                                                  StrokeThickness="2.5" Fill="Transparent"
                                                                  StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                                                  StrokeLineJoin="Round"/>
                                                        </Canvas>
                                                    </Viewbox>
                                                </Grid>
                                            </Button>
                                        </StackPanel>
                                    </Border>
                                </Popup>
                            </Grid>

                            <Button Grid.Column="3"
                                    Style="{StaticResource BtnPrimary}"
                                    Padding="24,10"
                                    Command="{Binding DownloadGameCommand}">
                                <StackPanel Orientation="Horizontal">
                                    <Viewbox Width="15" Height="15" Margin="0,0,8,0">
                                        <Canvas Width="24" Height="24">
                                            <Path Data="M12,4 L12,16 M8,12 L12,16 L16,12 M4,19 L20,19"
                                                  Stroke="White"
                                                  StrokeThickness="2" StrokeStartLineCap="Round"
                                                  StrokeEndLineCap="Round" Fill="Transparent"/>
                                        </Canvas>
                                    </Viewbox>
                                    <TextBlock Text="Download" FontSize="13" FontWeight="SemiBold" Foreground="White"/>
                                </StackPanel>
                            </Button>
                        </Grid>
                    </Border>
                </Grid>
            </Border>
        </Grid>

    </Grid>
</UserControl>
