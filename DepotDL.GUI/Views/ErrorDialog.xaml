<Window x:Class="DepotDL.GUI.Views.ErrorDialog"
        xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        SystemDecorations="None"
        CanResize="False"
        ShowInTaskbar="False"
        Background="Transparent"
        TransparencyLevelHint="Transparent">

    <Grid>
        <!-- Backdrop -->
        <Rectangle Fill="#1C1610" Opacity="0.6"/>

        <!-- Card -->
        <Border Width="420" MaxHeight="520"
                HorizontalAlignment="Center" VerticalAlignment="Center"
                Background="{StaticResource BgCard}"
                BorderBrush="{StaticResource Border}"
                BorderThickness="1"
                CornerRadius="16"
                Padding="24"
                BoxShadow="0 8 40 0 #33000000">
            <StackPanel>
                <TextBlock Text="{Binding DialogTitle}"
                           FontSize="18" FontWeight="SemiBold"
                           Foreground="{StaticResource TextPrimary}"
                           Margin="0,0,0,12"/>

                <ScrollViewer MaxHeight="320" VerticalScrollBarVisibility="Auto" Margin="0,0,0,20">
                    <TextBlock Text="{Binding Message}"
                               FontSize="13" Foreground="{StaticResource TextBody}"
                               TextWrapping="Wrap"/>
                </ScrollViewer>

                <Button Content="OK"
                        Theme="{StaticResource BtnPrimary}"
                        Click="OkButton_Click"
                        Padding="12,10" FontSize="12" FontWeight="SemiBold"
                        HorizontalAlignment="Right" MinWidth="80"/>
            </StackPanel>
        </Border>
    </Grid>

</Window>
