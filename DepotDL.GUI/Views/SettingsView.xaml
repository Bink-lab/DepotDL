<UserControl x:Class="DepotDL.GUI.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             FontFamily="Segoe UI">

    <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="0,42,6,0">
        <Grid Margin="32,0,32,28">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="28"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="20"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="20"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="20"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="20"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="20"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="24"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0">
                <TextBlock Style="{StaticResource TextH1}" Text="Settings"/>
                <TextBlock Style="{StaticResource BodyText}" Margin="0,4,0,0"
                           Text="Configure default paths and preferences."/>
            </StackPanel>

            <Border Grid.Row="2" Style="{StaticResource Card}" Padding="20">
                <StackPanel>
                    <TextBlock Text="PATHS" Style="{StaticResource TextLabel}" Margin="0,0,0,16"/>

                    <TextBlock Text="Manifests Cache Directory"
                               Style="{StaticResource TextH3}" Margin="0,0,0,4"/>
                    <TextBlock Text="Folder containing .manifest files for offline installation."
                               Style="{StaticResource BodyText}" Margin="0,0,0,8"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0"
                                 Text="{Binding ManifestsDir, UpdateSourceTrigger=PropertyChanged}"
                                 />
                        <Button Grid.Column="2"
                                Style="{StaticResource BtnGhost}"
                                Command="{Binding BrowseManifestsDirCommand}"
                                Padding="12,8">
                            <TextBlock Text="Browse" FontSize="12"/>
                        </Button>
                    </Grid>

                    <Separator Margin="0,20"/>

                    <TextBlock Text="Default Download Base Directory"
                               Style="{StaticResource TextH3}" Margin="0,0,0,4"/>
                    <TextBlock Text="Game output folders are created as subfolders here (e.g. 480)."
                               Style="{StaticResource BodyText}" Margin="0,0,0,8"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0"
                                 Text="{Binding DownloadBaseDir, UpdateSourceTrigger=PropertyChanged}"
                                 />
                        <Button Grid.Column="2"
                                Style="{StaticResource BtnGhost}"
                                Command="{Binding BrowseDownloadBaseDirCommand}"
                                Padding="12,8">
                            <TextBlock Text="Browse" FontSize="12"/>
                        </Button>
                    </Grid>
                </StackPanel>
            </Border>

            <Border Grid.Row="4" Style="{StaticResource Card}" Padding="20">
                <StackPanel>
                    <TextBlock Text="DOWNLOAD" Style="{StaticResource TextLabel}" Margin="0,0,0,16"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="200"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Parallel Depots"
                                       Style="{StaticResource TextH3}" Margin="0,0,0,4"/>
                            <TextBlock Text="Number of depots downloaded simultaneously (1–8)."
                                       Style="{StaticResource BodyText}"/>
                        </StackPanel>
                        <Border Grid.Column="1" Style="{StaticResource CardSmall}"
                                Padding="16,12" VerticalAlignment="Center">
                            <StackPanel>
                                <Grid Margin="0,0,0,8">
                                    <TextBlock Text="Workers"
                                               FontSize="11" Foreground="{StaticResource TextMuted}"/>
                                    <TextBlock HorizontalAlignment="Right"
                                               Text="{Binding MaxParallelDepots}"
                                               FontSize="16" FontWeight="Bold"
                                               Foreground="{StaticResource Accent}"/>
                                </Grid>
                                <Slider Minimum="1" Maximum="8"
                                        TickFrequency="1"
                                        IsSnapToTickEnabled="True"
                                        Value="{Binding MaxParallelDepots}"/>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <Separator Margin="0,20"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock Text="Auto-select depots by OS"
                                       Style="{StaticResource TextH3}" Margin="0,0,0,4"/>
                            <TextBlock Style="{StaticResource BodyText}" TextWrapping="Wrap"
                                       Text="When loading a config, automatically deselect depots for other operating systems. Depots with no OS tag are always kept selected."/>
                        </StackPanel>
                        <CheckBox Grid.Column="1"
                                  IsChecked="{Binding AutoSelectOsByOs}"
                                  VerticalAlignment="Center"
                                  Margin="20,0,0,0"/>
                    </Grid>
                </StackPanel>
            </Border>

            <Border Grid.Row="6" Style="{StaticResource Card}" Padding="20">
                <StackPanel>
                    <TextBlock Text="API KEYS" Style="{StaticResource TextLabel}" Margin="0,0,0,16"/>

                    <TextBlock Text="Ryuu API Key"
                               Style="{StaticResource TextH3}" Margin="0,0,0,4"/>
                    <TextBlock Text="Required for downloading game configurations via the Ryuu service."
                               Style="{StaticResource BodyText}" Margin="0,0,0,8"/>
                    <TextBox Text="{Binding RyuuApiKey, UpdateSourceTrigger=PropertyChanged}"
                             />

                    <Separator Margin="0,20"/>

                    <TextBlock Text="Hubcap API Key"
                               Style="{StaticResource TextH3}" Margin="0,0,0,4"/>
                    <TextBlock Text="Required for downloading game configurations via the Hubcap service."
                               Style="{StaticResource BodyText}" Margin="0,0,0,8"/>
                    <TextBox Text="{Binding HubcapApiKey, UpdateSourceTrigger=PropertyChanged}"
                             />

                    <Separator Margin="0,20"/>

                    <TextBlock Text="Steam Web API Key"
                               Style="{StaticResource TextH3}" Margin="0,0,0,4"/>
                    <TextBlock Text="Used for downloading achievements and stats configuration from the Steam Web API."
                               Style="{StaticResource BodyText}" Margin="0,0,0,8"/>
                    <TextBox Text="{Binding SteamWebApiKey, UpdateSourceTrigger=PropertyChanged}"
                             />

                    <Separator Margin="0,20"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock Text="Download achievement images"
                                       Style="{StaticResource TextH3}" Margin="0,0,0,4"/>
                            <TextBlock Style="{StaticResource BodyText}" TextWrapping="Wrap"
                                       Text="When applying the Goldberg emulator, download achievement icons (normal and grayscale) to the local steam_settings/achievement_images folder and use those paths in achievements.json. Requires a Steam Web API Key."/>
                        </StackPanel>
                        <CheckBox Grid.Column="1"
                                  IsChecked="{Binding DownloadAchievementIcons}"
                                  VerticalAlignment="Center"
                                  Margin="20,0,0,0"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Store & Cache Settings -->
            <Border Grid.Row="8" Style="{StaticResource Card}" Padding="20">
                <StackPanel>
                    <TextBlock Text="STORE &amp; CACHE" Style="{StaticResource TextLabel}" Margin="0,0,0,16"/>

                    <!-- Store Page Size -->
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="200"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock Text="Store Page Size"
                                       Style="{StaticResource TextH3}" Margin="0,0,0,4"/>
                            <TextBlock Text="Number of game cards displayed per page (12–120)."
                                       Style="{StaticResource BodyText}"/>
                        </StackPanel>
                        <Border Grid.Column="1" Style="{StaticResource CardSmall}"
                                Padding="16,12" VerticalAlignment="Center">
                            <StackPanel>
                                <Grid Margin="0,0,0,8">
                                    <TextBlock Text="Games"
                                               FontSize="11" Foreground="{StaticResource TextMuted}"/>
                                    <TextBlock HorizontalAlignment="Right"
                                               Text="{Binding StorePageSize}"
                                               FontSize="16" FontWeight="Bold"
                                               Foreground="{StaticResource Accent}"/>
                                </Grid>
                                <Slider Minimum="12" Maximum="120"
                                        TickFrequency="6"
                                        IsSnapToTickEnabled="True"
                                        Value="{Binding StorePageSize}"/>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <Separator Margin="0,12"/>

                    <!-- Search Debounce -->
                    <Grid Margin="0,12,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="200"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock Text="Search Debounce Delay"
                                       Style="{StaticResource TextH3}" Margin="0,0,0,4"/>
                            <TextBlock Text="Delay after typing before searching begins (0–2000ms)."
                                       Style="{StaticResource BodyText}"/>
                        </StackPanel>
                        <Border Grid.Column="1" Style="{StaticResource CardSmall}"
                                Padding="16,12" VerticalAlignment="Center">
                            <StackPanel>
                                <Grid Margin="0,0,0,8">
                                    <TextBlock Text="Delay"
                                               FontSize="11" Foreground="{StaticResource TextMuted}"/>
                                    <TextBlock HorizontalAlignment="Right"
                                               FontSize="16" FontWeight="Bold"
                                               Foreground="{StaticResource Accent}">
                                        <Run Text="{Binding SearchDebounceMs}"/>
                                        <Run Text=" ms" FontSize="11" Foreground="{StaticResource TextMuted}"/>
                                    </TextBlock>
                                </Grid>
                                <Slider Minimum="0" Maximum="2000"
                                        TickFrequency="50"
                                        IsSnapToTickEnabled="True"
                                        Value="{Binding SearchDebounceMs}"/>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <Separator Margin="0,12"/>

                    <!-- Store Cache Hours -->
                    <Grid Margin="0,12,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="200"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock Text="Store Cache Lifetime"
                                       Style="{StaticResource TextH3}" Margin="0,0,0,4"/>
                            <TextBlock Text="Hours to cache store data locally before re-fetching (1–168h)."
                                       Style="{StaticResource BodyText}"/>
                        </StackPanel>
                        <Border Grid.Column="1" Style="{StaticResource CardSmall}"
                                Padding="16,12" VerticalAlignment="Center">
                            <StackPanel>
                                <Grid Margin="0,0,0,8">
                                    <TextBlock Text="Lifetime"
                                               FontSize="11" Foreground="{StaticResource TextMuted}"/>
                                    <TextBlock HorizontalAlignment="Right"
                                               FontSize="16" FontWeight="Bold"
                                               Foreground="{StaticResource Accent}">
                                        <Run Text="{Binding StoreCacheHours}"/>
                                        <Run Text=" hours" FontSize="11" Foreground="{StaticResource TextMuted}"/>
                                    </TextBlock>
                                </Grid>
                                <Slider Minimum="1" Maximum="168"
                                        TickFrequency="1"
                                        IsSnapToTickEnabled="True"
                                        Value="{Binding StoreCacheHours}"/>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <Separator Margin="0,12"/>

                    <!-- GPU Cache Days -->
                    <Grid Margin="0,12,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="200"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock Text="GPU Specs Cache Lifetime"
                                       Style="{StaticResource TextH3}" Margin="0,0,0,4"/>
                            <TextBlock Text="Days to cache GPU benchmark details locally (1–30d)."
                                       Style="{StaticResource BodyText}"/>
                        </StackPanel>
                        <Border Grid.Column="1" Style="{StaticResource CardSmall}"
                                Padding="16,12" VerticalAlignment="Center">
                            <StackPanel>
                                <Grid Margin="0,0,0,8">
                                    <TextBlock Text="Lifetime"
                                               FontSize="11" Foreground="{StaticResource TextMuted}"/>
                                    <TextBlock HorizontalAlignment="Right"
                                               FontSize="16" FontWeight="Bold"
                                               Foreground="{StaticResource Accent}">
                                        <Run Text="{Binding GpuCacheDays}"/>
                                        <Run Text=" days" FontSize="11" Foreground="{StaticResource TextMuted}"/>
                                    </TextBlock>
                                </Grid>
                                <Slider Minimum="1" Maximum="30"
                                        TickFrequency="1"
                                        IsSnapToTickEnabled="True"
                                        Value="{Binding GpuCacheDays}"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Smooth Scrolling Settings -->
            <Border Grid.Row="10" Style="{StaticResource Card}" Padding="20">
                <StackPanel>
                    <TextBlock Text="SMOOTH SCROLLING" Style="{StaticResource TextLabel}" Margin="0,0,0,16"/>

                    <!-- Scroll Sensitivity -->
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="200"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock Text="Scroll Sensitivity"
                                       Style="{StaticResource TextH3}" Margin="0,0,0,4"/>
                            <TextBlock Text="Multiplier applied to mouse wheel ticks (0.1–5.0)."
                                       Style="{StaticResource BodyText}"/>
                        </StackPanel>
                        <Border Grid.Column="1" Style="{StaticResource CardSmall}"
                                Padding="16,12" VerticalAlignment="Center">
                            <StackPanel>
                                <Grid Margin="0,0,0,8">
                                    <TextBlock Text="Sensitivity"
                                               FontSize="11" Foreground="{StaticResource TextMuted}"/>
                                    <TextBlock HorizontalAlignment="Right"
                                               Text="{Binding ScrollSensitivity, StringFormat={}{0:F1}}"
                                               FontSize="16" FontWeight="Bold"
                                               Foreground="{StaticResource Accent}"/>
                                </Grid>
                                <Slider Minimum="0.1" Maximum="5.0"
                                        TickFrequency="0.1"
                                        IsSnapToTickEnabled="True"
                                        Value="{Binding ScrollSensitivity}"/>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <Separator Margin="0,12"/>

                    <!-- Scroll Duration -->
                    <Grid Margin="0,12,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="200"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock Text="Scroll Duration"
                                       Style="{StaticResource TextH3}" Margin="0,0,0,4"/>
                            <TextBlock Text="Duration of the scrolling slide animation (50–1000ms)."
                                       Style="{StaticResource BodyText}"/>
                        </StackPanel>
                        <Border Grid.Column="1" Style="{StaticResource CardSmall}"
                                Padding="16,12" VerticalAlignment="Center">
                            <StackPanel>
                                <Grid Margin="0,0,0,8">
                                    <TextBlock Text="Duration"
                                               FontSize="11" Foreground="{StaticResource TextMuted}"/>
                                    <TextBlock HorizontalAlignment="Right"
                                               FontSize="16" FontWeight="Bold"
                                               Foreground="{StaticResource Accent}">
                                        <Run Text="{Binding ScrollDurationMs}"/>
                                        <Run Text=" ms" FontSize="11" Foreground="{StaticResource TextMuted}"/>
                                    </TextBlock>
                                </Grid>
                                <Slider Minimum="50" Maximum="1000"
                                        TickFrequency="25"
                                        IsSnapToTickEnabled="True"
                                        Value="{Binding ScrollDurationMs}"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </StackPanel>
            </Border>

            <Grid Grid.Row="14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="1"
                        Background="{StaticResource SuccessLight}"
                        CornerRadius="8" Padding="14,10"
                        Visibility="{Binding SaveSuccess, Converter={StaticResource BoolToVis}}">
                    <TextBlock Text="✓  Settings saved"
                               Foreground="{StaticResource Success}"
                               FontSize="13"/>
                </Border>

                <Button Grid.Column="3"
                        Style="{StaticResource BtnPrimary}"
                        Command="{Binding SaveCommand}"
                        Padding="24,12">
                    <StackPanel Orientation="Horizontal">
                        <Viewbox Width="14" Height="14" Margin="0,0,7,0">
                            <Canvas Width="24" Height="24">
                                <Path Data="M19,21 L5,21 A2,2,0,0,1,3,19 L3,5 A2,2,0,0,1,5,3 L16,3 L21,8 L21,19 A2,2,0,0,1,19,21 M7,21 L7,13 L17,13 L17,21 M7,3 L7,8 L15,8"
                                      Stroke="White" StrokeThickness="1.8" Fill="Transparent"
                                      StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                            </Canvas>
                        </Viewbox>
                        <TextBlock Text="Save Settings" FontSize="13" FontWeight="SemiBold"/>
                    </StackPanel>
                </Button>
            </Grid>
        </Grid>
    </ScrollViewer>
</UserControl>
