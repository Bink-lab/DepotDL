<UserControl x:Class="DepotDL.GUI.Views.DownloadView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:DepotDL.GUI.ViewModels"
             xmlns:models="clr-namespace:DepotDL.GUI.Models"
             FontFamily="Segoe UI"
             x:Name="Root"
             AllowDrop="True"
             Drop="OnDrop"
             DragOver="OnDragOver">

    <Grid Margin="32,28,32,28">

        <!-- ══════════════════════════════════════════════════════
             STEP 1 — Select File
             ══════════════════════════════════════════════════════ -->
        <Grid Visibility="{Binding CurrentStep, Converter={StaticResource EqToVis},
                            ConverterParameter={x:Static vm:DownloadStep.SelectFile}}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="24"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="16"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="16"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Heading -->
            <StackPanel Grid.Row="0">
                <TextBlock Style="{StaticResource TextH1}" Text="New Download"/>
                <TextBlock Style="{StaticResource BodyText}" Margin="0,4,0,0"
                           Text="Enter an App ID to fetch automatically, or load a Lua config file."/>
            </StackPanel>

            <!-- Ryuu API — primary hero card -->
            <Border Grid.Row="2"
                    Style="{StaticResource Card}"
                    Padding="28,24">
                <StackPanel>
                    <!-- Card header -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                        <Border Width="40" Height="40" CornerRadius="20"
                                Background="{StaticResource AccentVeryLight}"
                                Margin="0,0,14,0">
                            <Border.Effect>
                                <DropShadowEffect Color="#C07840" BlurRadius="10" ShadowDepth="1" Opacity="0.2"/>
                            </Border.Effect>
                            <Path Data="{StaticResource LucideDownload}"
                                  Width="18" Height="18" Stretch="Uniform"
                                  Stroke="{StaticResource Accent}" StrokeThickness="1.7" Fill="Transparent"
                                  StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Style="{StaticResource TextH2}" Text="Fetch from Ryuu API"/>
                            <TextBlock Style="{StaticResource BodyText}" Margin="0,3,0,0"
                                       Text="Enter an App ID to download the config and manifests automatically."/>
                        </StackPanel>
                    </StackPanel>

                    <!-- Inputs -->
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="6"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="160"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="App ID"
                                   Style="{StaticResource TextLabel}" Margin="0"/>
                        <TextBlock Grid.Row="0" Grid.Column="2" Text="API Key (Optional)"
                                   Style="{StaticResource TextLabel}" Margin="0"/>

                        <TextBox Grid.Row="2" Grid.Column="0"
                                 Text="{Binding RyuuAppId, UpdateSourceTrigger=PropertyChanged}"/>

                        <TextBox Grid.Row="2" Grid.Column="2"
                                 Text="{Binding RyuuApiKey, UpdateSourceTrigger=PropertyChanged}"/>

                        <Button Grid.Row="2" Grid.Column="4"
                                Style="{StaticResource BtnPrimary}"
                                Command="{Binding FetchFromRyuuAsyncCommand}"
                                IsEnabled="{Binding CanFetchRyuu}"
                                Padding="28,10"
                                VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Path Data="{StaticResource LucideDownload}"
                                      Width="14" Height="14" Stretch="Uniform" Margin="0,0,8,0"
                                      Visibility="{Binding IsRyuuBusy, Converter={StaticResource InvBoolToVis}}"
                                      Stroke="White" StrokeThickness="1.7" Fill="Transparent"
                                      StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"/>
                                <Grid>
                                    <TextBlock Text="Fetch Config" FontSize="12.5" FontWeight="SemiBold"
                                               Visibility="{Binding IsRyuuBusy, Converter={StaticResource InvBoolToVis}}"/>
                                    <TextBlock Text="{Binding RyuuStatusText}" FontSize="12.5" FontWeight="SemiBold"
                                               Visibility="{Binding IsRyuuBusy, Converter={StaticResource BoolToVis}}"/>
                                </Grid>
                            </StackPanel>
                        </Button>
                    </Grid>

                    <!-- Ryuu error -->
                    <Border Background="{StaticResource ErrorBg}"
                            CornerRadius="8" Padding="14,10"
                            Margin="0,14,0,0"
                            BorderBrush="#EBC5C1"
                            BorderThickness="1"
                            Visibility="{Binding RyuuError, Converter={StaticResource NotEmptyToVis}}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="⚠ " Foreground="{StaticResource Error}"
                                       FontWeight="Bold" FontSize="13" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBlock Text="{Binding RyuuError}"
                                       Foreground="{StaticResource Error}"
                                       FontSize="11.5" TextWrapping="Wrap" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>

            <!-- Hubcap API card -->
            <Border Grid.Row="4"
                    Style="{StaticResource Card}"
                    Padding="28,24">
                <StackPanel>
                    <!-- Card header -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                        <Border Width="40" Height="40" CornerRadius="20"
                                Background="{StaticResource AccentVeryLight}"
                                Margin="0,0,14,0">
                            <Border.Effect>
                                <DropShadowEffect Color="#C07840" BlurRadius="10" ShadowDepth="1" Opacity="0.2"/>
                            </Border.Effect>
                            <Path Data="{StaticResource LucideDownload}"
                                  Width="18" Height="18" Stretch="Uniform"
                                  Stroke="{StaticResource Accent}" StrokeThickness="1.7" Fill="Transparent"
                                  StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Style="{StaticResource TextH2}" Text="Fetch from Hubcap API"/>
                            <TextBlock Style="{StaticResource BodyText}" Margin="0,3,0,0"
                                       Text="Enter an App ID to download the config and manifests via Hubcap."/>
                        </StackPanel>
                    </StackPanel>

                    <!-- Inputs -->
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="6"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="160"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="App ID"
                                   Style="{StaticResource TextLabel}" Margin="0"/>
                        <TextBlock Grid.Row="0" Grid.Column="2" Text="API Key (Optional)"
                                   Style="{StaticResource TextLabel}" Margin="0"/>

                        <TextBox Grid.Row="2" Grid.Column="0"
                                 Text="{Binding HubcapAppId, UpdateSourceTrigger=PropertyChanged}"/>

                        <TextBox Grid.Row="2" Grid.Column="2"
                                 Text="{Binding HubcapApiKey, UpdateSourceTrigger=PropertyChanged}"/>

                        <Button Grid.Row="2" Grid.Column="4"
                                Style="{StaticResource BtnPrimary}"
                                Command="{Binding FetchFromHubcapAsyncCommand}"
                                IsEnabled="{Binding CanFetchHubcap}"
                                Padding="28,10"
                                VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Path Data="{StaticResource LucideDownload}"
                                      Width="14" Height="14" Stretch="Uniform" Margin="0,0,8,0"
                                      Visibility="{Binding IsHubcapBusy, Converter={StaticResource InvBoolToVis}}"
                                      Stroke="White" StrokeThickness="1.7" Fill="Transparent"
                                      StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"/>
                                <Grid>
                                    <TextBlock Text="Fetch Config" FontSize="12.5" FontWeight="SemiBold"
                                               Visibility="{Binding IsHubcapBusy, Converter={StaticResource InvBoolToVis}}"/>
                                    <TextBlock Text="Fetching..." FontSize="12.5" FontWeight="SemiBold"
                                               Visibility="{Binding IsHubcapBusy, Converter={StaticResource BoolToVis}}"/>
                                </Grid>
                            </StackPanel>
                        </Button>
                    </Grid>

                    <!-- Hubcap error -->
                    <Border Background="{StaticResource ErrorBg}"
                            CornerRadius="8" Padding="14,10"
                            Margin="0,14,0,0"
                            BorderBrush="#EBC5C1"
                            BorderThickness="1"
                            Visibility="{Binding HubcapError, Converter={StaticResource NotEmptyToVis}}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="⚠ " Foreground="{StaticResource Error}"
                                       FontWeight="Bold" FontSize="13" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBlock Text="{Binding HubcapError}"
                                       Foreground="{StaticResource Error}"
                                       FontSize="11.5" TextWrapping="Wrap" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>

            <!-- Local file — compact secondary strip -->
            <Border Grid.Row="6" Style="{StaticResource CardFlat}" Padding="20,16">
                <StackPanel>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock Style="{StaticResource TextH3}" Text="Use a local file"/>
                            <TextBlock Style="{StaticResource BodyText}"
                                       Foreground="{StaticResource TextMuted}"
                                       Margin="0,3,0,0"
                                       Text="Drag a .zip or .lua file anywhere in this window, or browse."/>
                        </StackPanel>

                        <Button Grid.Column="2"
                                Style="{StaticResource BtnGhost}"
                                Command="{Binding BrowseZipFileCommand}"
                                Padding="18,10"
                                VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal">
                                <Path Data="{StaticResource LucideUpload}"
                                      Width="13" Height="13" Stretch="Uniform" Margin="0,0,7,0"
                                      Stroke="{StaticResource TextSecondary}" StrokeThickness="1.7" Fill="Transparent"
                                      StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"/>
                                <TextBlock Text="Browse ZIP…" FontSize="12.5" FontWeight="SemiBold"/>
                            </StackPanel>
                        </Button>

                        <Button Grid.Column="4"
                                Style="{StaticResource BtnGhost}"
                                Command="{Binding BrowseLuaFileCommand}"
                                Padding="18,10"
                                VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal">
                                <Path Data="{StaticResource LucideFolder}"
                                      Width="13" Height="13" Stretch="Uniform" Margin="0,0,7,0"
                                      Stroke="{StaticResource TextSecondary}" StrokeThickness="1.7" Fill="Transparent"
                                      StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"/>
                                <TextBlock Text="Browse Lua…" FontSize="12.5" FontWeight="SemiBold"/>
                            </StackPanel>
                        </Button>
                    </Grid>

                    <!-- ZIP error -->
                    <Border Background="{StaticResource ErrorBg}"
                            CornerRadius="8" Padding="14,10"
                            Margin="0,12,0,0"
                            BorderBrush="#EBC5C1"
                            BorderThickness="1"
                            Visibility="{Binding ZipError, Converter={StaticResource NotEmptyToVis}}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="⚠ " Foreground="{StaticResource Error}"
                                       FontWeight="Bold" FontSize="13" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBlock Text="{Binding ZipError}"
                                       Foreground="{StaticResource Error}"
                                       FontSize="11.5" TextWrapping="Wrap" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- Parse error -->
                    <Border Background="{StaticResource ErrorBg}"
                            CornerRadius="8" Padding="14,10"
                            Margin="0,12,0,0"
                            BorderBrush="#EBC5C1"
                            BorderThickness="1"
                            Visibility="{Binding ParseError, Converter={StaticResource NotEmptyToVis}}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="⚠ " Foreground="{StaticResource Error}"
                                       FontWeight="Bold" FontSize="13" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBlock Text="{Binding ParseError}"
                                       Foreground="{StaticResource Error}"
                                       FontSize="11.5" TextWrapping="Wrap" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>
        </Grid>

        <!-- ══════════════════════════════════════════════════════
             STEP 2 — Configure Depots
             ══════════════════════════════════════════════════════ -->
        <Grid Visibility="{Binding CurrentStep, Converter={StaticResource EqToVis},
                            ConverterParameter={x:Static vm:DownloadStep.ConfigureDepots}}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="20"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="12"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="10"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header — title + inline Change Source (no top-right margin hack needed) -->
            <StackPanel Grid.Row="0">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Style="{StaticResource BtnGhost}"
                            Command="{Binding StartNewCommand}"
                            Padding="10,6"
                            Margin="0,0,10,0"
                            VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="{StaticResource LucideArrowLeft}"
                                  Width="11" Height="11" Stretch="Uniform" Margin="0,0,5,0"
                                  Stroke="{StaticResource TextSecondary}" StrokeThickness="1.7" Fill="Transparent"
                                  StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"/>
                            <TextBlock Text="Back" FontSize="11.5" FontWeight="SemiBold" Foreground="{StaticResource TextSecondary}"/>
                        </StackPanel>
                    </Button>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="App " Style="{StaticResource TextH1}"/>
                        <TextBlock Text="{Binding AppId}"
                                   Style="{StaticResource TextH1}"
                                   Foreground="{StaticResource Accent}"/>
                    </StackPanel>
                    <Button Style="{StaticResource BtnGhost}"
                            Command="{Binding BrowseLuaFileCommand}"
                            Padding="12,6"
                            Margin="14,0,0,0"
                            VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="{StaticResource LucidePencil}"
                                  Width="11" Height="11" Stretch="Uniform" Margin="0,0,5,0"
                                  Stroke="{StaticResource TextSecondary}" StrokeThickness="1.7" Fill="Transparent"
                                  StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"/>
                            <TextBlock Text="Change Source" FontSize="11.5" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
                <TextBlock Style="{StaticResource BodyText}"
                           Text="{Binding LuaFileName}"
                           Foreground="{StaticResource TextMuted}"
                           Margin="0,3,0,0"/>
            </StackPanel>

            <!-- Two-column content -->
            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="280"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Left: filter panel -->
                <Border Grid.Column="0" Style="{StaticResource Card}" Padding="22,20"
                        VerticalAlignment="Stretch">
                    <StackPanel>
                        <!-- Search -->
                        <TextBlock Text="SEARCH" Style="{StaticResource TextLabel}"/>
                        <Grid>
                            <TextBox Padding="10,7,34,7"
                                     Text="{Binding DepotSearchText, UpdateSourceTrigger=PropertyChanged}"/>
                            <TextBlock Text="Name or depot ID…"
                                       IsHitTestVisible="False"
                                       VerticalAlignment="Center"
                                       Margin="12,0,0,0"
                                       FontSize="12.5"
                                       Foreground="{StaticResource TextMuted}"
                                       Visibility="{Binding DepotSearchText, Converter={StaticResource EmptyToVis}}"/>
                            <Path Data="{StaticResource LucideSearch}"
                                  Width="13" Height="13" Stretch="Uniform"
                                  HorizontalAlignment="Right" VerticalAlignment="Center"
                                  Margin="0,0,11,0" IsHitTestVisible="False"
                                  Stroke="{StaticResource TextMuted}" StrokeThickness="1.7" Fill="Transparent"
                                  StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"/>
                        </Grid>

                        <Separator Margin="0,16"/>

                        <!-- Platform filter -->
                        <TextBlock Text="PLATFORM" Style="{StaticResource TextLabel}"/>
                        <StackPanel Margin="0,8,0,0">
                            <CheckBox IsChecked="{Binding FilterWindows}" Margin="0,0,0,8">
                                <TextBlock Text="Windows" FontSize="12.5"/>
                            </CheckBox>
                            <CheckBox IsChecked="{Binding FilterLinux}" Margin="0,0,0,8">
                                <TextBlock Text="Linux" FontSize="12.5"/>
                            </CheckBox>
                            <CheckBox IsChecked="{Binding FilterMacOs}" Margin="0,0,0,8">
                                <TextBlock Text="macOS" FontSize="12.5"/>
                            </CheckBox>
                            <CheckBox IsChecked="{Binding FilterCommon}">
                                <TextBlock Text="Common" FontSize="12.5"/>
                            </CheckBox>
                        </StackPanel>

                        <Separator Margin="0,16"/>

                        <!-- DLC filter -->
                        <TextBlock Text="CONTENT TYPE" Style="{StaticResource TextLabel}"/>
                        <StackPanel Margin="0,8,0,0">
                            <CheckBox IsChecked="{Binding FilterDlc}">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="DLC" FontSize="12.5" VerticalAlignment="Center"/>
                                    <Border CornerRadius="4" Padding="5,2" Margin="6,0,0,0"
                                            Background="{StaticResource DlcBadgeBg}" VerticalAlignment="Center">
                                        <TextBlock Text="DLC" FontSize="9" FontWeight="Bold" Foreground="{StaticResource DlcBadgeFg}"/>
                                    </Border>
                                </StackPanel>
                            </CheckBox>
                        </StackPanel>

                        <Separator Margin="0,16"/>

                        <!-- Count -->
                        <TextBlock FontSize="12" Foreground="{StaticResource TextMuted}">
                            <Run Text="{Binding FilteredCount, Mode=OneWay}"
                                 FontWeight="Bold" Foreground="{StaticResource Accent}"/>
                            <Run Text=" of "/>
                            <Run Text="{Binding Depots.Count, Mode=OneWay}" FontWeight="Bold"/>
                            <Run Text=" depots shown"/>
                        </TextBlock>

                        <Separator Margin="0,16"/>

                        <!-- Select / Deselect -->
                        <Grid>
                            <Button Style="{StaticResource BtnGhost}"
                                    HorizontalAlignment="Left"
                                    Padding="10,5"
                                    Command="{Binding SelectAllDepotsCommand}">
                                <TextBlock Text="Select All" FontSize="11" FontWeight="SemiBold"/>
                            </Button>
                            <Button Style="{StaticResource BtnGhost}"
                                    HorizontalAlignment="Right"
                                    Padding="10,5"
                                    Command="{Binding SelectNoDepotsCommand}">
                                <TextBlock Text="Deselect All" FontSize="11" FontWeight="SemiBold"/>
                            </Button>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Right: depot list card (fills height with no MaxHeight cap) -->
                <Border Grid.Column="2" Style="{StaticResource Card}" Padding="0"
                        VerticalAlignment="Stretch">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Orientation="Horizontal" VerticalAlignment="Center"
                                    Margin="20,16,20,12">
                            <TextBlock Text="AVAILABLE DEPOTS" Style="{StaticResource TextLabel}"
                                       VerticalAlignment="Center" Margin="0"/>
                            <Border Margin="8,0,0,0" Padding="6,2" CornerRadius="10"
                                    Background="{StaticResource AccentVeryLight}">
                                <TextBlock FontSize="10.5" FontWeight="Bold" Foreground="{StaticResource Accent}">
                                    <Run Text="{Binding FilteredCount, Mode=OneWay}"/>
                                    <Run Text=" / "/>
                                    <Run Text="{Binding Depots.Count, Mode=OneWay}"/>
                                </TextBlock>
                            </Border>
                        </StackPanel>

                        <Border Grid.Row="1" Height="1" Background="{StaticResource Border}" Margin="0,0,0,4"/>

                        <ScrollViewer Grid.Row="2"
                                      VerticalScrollBarVisibility="Auto"
                                      Padding="12,0,12,12">
                            <ItemsControl ItemsSource="{Binding FilteredDepots}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="{x:Type vm:DepotSelectionItem}">
                                        <Border Padding="12,9" Margin="0,1">
                                            <Border.Style>
                                                <Style TargetType="Border" BasedOn="{StaticResource DepotListItem}">
                                                    <Style.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Background" Value="{StaticResource AccentVeryLight}"/>
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="14"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <CheckBox Grid.Column="0"
                                                          IsChecked="{Binding IsSelected}"
                                                          VerticalAlignment="Center"/>
                                                <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding DisplayName}"
                                                               FontSize="12.5" FontWeight="SemiBold"
                                                               Foreground="{StaticResource TextPrimary}"/>
                                                    <TextBlock Margin="0,2,0,0"
                                                               FontSize="10.5"
                                                               Foreground="{StaticResource TextMuted}"
                                                               FontFamily="Consolas"
                                                               Text="{Binding DepotId}"/>
                                                </StackPanel>
                                                <StackPanel Grid.Column="3" Orientation="Horizontal"
                                                            VerticalAlignment="Center">
                                                    <Border CornerRadius="6" Padding="8,4"
                                                            Margin="0,0,4,0"
                                                            Background="{StaticResource DlcBadgeBg}"
                                                            VerticalAlignment="Center"
                                                            Visibility="{Binding IsDlc, Converter={StaticResource BoolToVis}}">
                                                        <TextBlock Text="DLC"
                                                                   FontSize="9.5" FontWeight="Bold"
                                                                   Foreground="{StaticResource DlcBadgeFg}"/>
                                                    </Border>
                                                    <Border CornerRadius="6" Padding="8,4"
                                                            Background="{StaticResource AccentVeryLight}"
                                                            VerticalAlignment="Center"
                                                            Visibility="{Binding OsText, Converter={StaticResource NotEmptyToVis}}">
                                                        <TextBlock Text="{Binding OsText}"
                                                                   FontSize="9.5" FontWeight="Bold"
                                                                   Foreground="{StaticResource Accent}"/>
                                                    </Border>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                </Border>
            </Grid>

            <!-- Compact config row -->
            <Border Grid.Row="4" Style="{StaticResource Card}" Padding="22,16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="170"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="OUTPUT DIRECTORY" Style="{StaticResource TextLabel}"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0"
                                     Text="{Binding OutputDir, UpdateSourceTrigger=PropertyChanged}"/>
                            <Button Grid.Column="2"
                                    Style="{StaticResource BtnGhost}"
                                    Command="{Binding BrowseOutputDirCommand}"
                                    Padding="14,9">
                                <TextBlock Text="Browse" FontSize="12" FontWeight="SemiBold"/>
                            </Button>
                        </Grid>
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Text="MANIFESTS CACHE (OPTIONAL)" Style="{StaticResource TextLabel}"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0"
                                     Text="{Binding ManifestsDir, UpdateSourceTrigger=PropertyChanged}"/>
                            <Button Grid.Column="2"
                                    Style="{StaticResource BtnGhost}"
                                    Command="{Binding BrowseManifestsDirCommand}"
                                    Padding="14,9">
                                <TextBlock Text="Browse" FontSize="12" FontWeight="SemiBold"/>
                            </Button>
                        </Grid>
                    </StackPanel>

                    <StackPanel Grid.Column="4">
                        <Grid>
                            <TextBlock Text="PARALLEL DEPOTS" Style="{StaticResource TextLabel}"
                                       VerticalAlignment="Center" Margin="0"/>
                            <TextBlock HorizontalAlignment="Right"
                                       Text="{Binding MaxParallel}"
                                       FontSize="14" FontWeight="Bold"
                                       Foreground="{StaticResource Accent}"/>
                        </Grid>
                        <Slider Minimum="1" Maximum="8"
                                TickFrequency="1"
                                IsSnapToTickEnabled="True"
                                Value="{Binding MaxParallel}"
                                Margin="0,10,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Start button / block reason — same slot, smooth swap -->
            <Grid Grid.Row="6" Height="46">
                <Button Style="{StaticResource BtnPrimary}"
                        Command="{Binding StartDownloadAsyncCommand}"
                        HorizontalAlignment="Stretch"
                        Visibility="{Binding CanStart, Converter={StaticResource BoolToVis}}">
                    <Button.Effect>
                        <DropShadowEffect Color="#C07840" BlurRadius="18" ShadowDepth="3" Opacity="0.3"/>
                    </Button.Effect>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Path Data="{StaticResource LucidePlay}"
                              Width="16" Height="16" Stretch="Uniform" Margin="0,0,10,0"
                              Fill="White" Stroke="White" StrokeThickness="1"
                              StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                        <TextBlock Text="Start Downloading" FontSize="13.5" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <Border Background="{StaticResource ErrorBg}"
                        CornerRadius="8" Padding="14,9"
                        BorderBrush="#EBC5C1" BorderThickness="1"
                        Visibility="{Binding StartBlockReason, Converter={StaticResource NotEmptyToVis}}">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock Text="⚠ " Foreground="{StaticResource Error}"
                                   FontWeight="Bold" FontSize="13" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="{Binding StartBlockReason}"
                                   Foreground="{StaticResource Error}"
                                   FontSize="11.5" VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>

        <!-- ══════════════════════════════════════════════════════
             STEP 3 — Downloading
             ══════════════════════════════════════════════════════ -->
        <Grid Visibility="{Binding CurrentStep, Converter={StaticResource EqToVis},
                            ConverterParameter={x:Static vm:DownloadStep.Downloading}}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="20"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="16"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="16"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header — title + inline Cancel (no top-right margin hack) -->
            <StackPanel Grid.Row="0">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="App " Style="{StaticResource TextH1}"/>
                        <TextBlock Text="{Binding AppId}"
                                   Style="{StaticResource TextH1}"
                                   Foreground="{StaticResource Accent}"/>
                    </StackPanel>
                    <Button Style="{StaticResource BtnDanger}"
                            Command="{Binding CancelDownloadCommand}"
                            Visibility="{Binding IsDownloading, Converter={StaticResource BoolToVis}}"
                            Padding="18,7"
                            Margin="14,0,0,0"
                            VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="{StaticResource LucideX}"
                                  Width="11" Height="11" Stretch="Uniform" Margin="0,0,5,0"
                                  Stroke="{StaticResource Error}" StrokeThickness="1.8" Fill="Transparent"
                                  StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                            <TextBlock Text="Cancel Download" FontSize="12" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
                <TextBlock Text="{Binding OverallStatus}"
                           Style="{StaticResource BodyText}"
                           Foreground="{StaticResource TextMuted}"
                           Margin="0,4,0,0"/>
            </StackPanel>

            <!-- Overall progress card -->
            <Border Grid.Row="2" Style="{StaticResource Card}" Padding="24,20">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="12"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0">
                        <TextBlock Text="OVERALL DOWNLOAD PROGRESS"
                                   Style="{StaticResource TextLabel}" VerticalAlignment="Center"/>
                        <TextBlock HorizontalAlignment="Right"
                                   FontSize="15" FontWeight="Bold"
                                   Foreground="{StaticResource Accent}"
                                   VerticalAlignment="Center">
                            <Run Text="{Binding OverallPercent, StringFormat={}{0:F1}}"/>
                            <Run Text="%"/>
                        </TextBlock>
                    </Grid>
                    <Border Grid.Row="2" Height="12" CornerRadius="6"
                            Background="{StaticResource AccentVeryLight}">
                        <Border HorizontalAlignment="Left" CornerRadius="6"
                                Background="{StaticResource Accent}">
                            <Border.Width>
                                <MultiBinding Converter="{StaticResource PctToWidth}">
                                    <Binding Path="OverallDisplayPercent"/>
                                    <Binding Path="ActualWidth"
                                             RelativeSource="{RelativeSource AncestorType=Border, AncestorLevel=1}"/>
                                </MultiBinding>
                            </Border.Width>
                        </Border>
                    </Border>
                </Grid>
            </Border>

            <!-- Per-depot list -->
            <ScrollViewer Grid.Row="4" VerticalScrollBarVisibility="Auto" Padding="0,0,4,0">
                <ItemsControl ItemsSource="{Binding DownloadStates}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type models:DepotDownloadState}">
                            <Border Margin="0,0,0,10"
                                    Style="{StaticResource CardFlat}"
                                    Padding="20,16">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="12"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="10"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <Grid Grid.Row="0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding DisplayName}"
                                                       FontSize="13.5" FontWeight="SemiBold"
                                                       Foreground="{StaticResource TextPrimary}"/>
                                            <TextBlock Text="{Binding DepotId}"
                                                       FontSize="10.5"
                                                       Foreground="{StaticResource TextMuted}"
                                                       FontFamily="Consolas"
                                                       Margin="0,2,0,0"/>
                                        </StackPanel>

                                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                            <Button Style="{StaticResource BtnGhost}"
                                                    Padding="7,4"
                                                    Margin="0,0,6,0"
                                                    VerticalAlignment="Center"
                                                    Visibility="{Binding Status, Converter={StaticResource EqToVis}, ConverterParameter={x:Static models:DepotStatus.Failed}}"
                                                    Command="{Binding DataContext.RetryDepotAsyncCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}"
                                                    ToolTip="Retry this depot">
                                                <Path Data="{StaticResource LucideRefreshCw}"
                                                      Width="12" Height="12" Stretch="Uniform"
                                                      Stroke="{StaticResource TextSecondary}" StrokeThickness="1.7" Fill="Transparent"
                                                      StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"/>
                                            </Button>
                                            <Border CornerRadius="6" Padding="8,3"
                                                    VerticalAlignment="Center">
                                                <Border.Background>
                                                    <SolidColorBrush Color="{StaticResource BgCardColor}"/>
                                                </Border.Background>
                                                <TextBlock Text="{Binding Status, Converter={StaticResource StatusToText}}"
                                                           FontSize="10.5" FontWeight="Bold"
                                                           Foreground="{Binding Status, Converter={StaticResource StatusToColor}}"/>
                                            </Border>
                                        </StackPanel>
                                    </Grid>

                                    <Border Grid.Row="2" Height="8" CornerRadius="4"
                                            Background="{StaticResource AccentVeryLight}">
                                        <Border HorizontalAlignment="Left" CornerRadius="4"
                                                Background="{Binding Status, Converter={StaticResource StatusToColor}}">
                                            <Border.Width>
                                                <MultiBinding Converter="{StaticResource PctToWidth}">
                                                    <Binding Path="DisplayPercent"/>
                                                    <Binding Path="ActualWidth"
                                                             RelativeSource="{RelativeSource AncestorType=Border, AncestorLevel=1}"/>
                                                </MultiBinding>
                                            </Border.Width>
                                        </Border>
                                    </Border>

                                    <Grid Grid.Row="4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Column="0"
                                                   FontSize="10.5"
                                                   Foreground="{StaticResource TextMuted}"
                                                   TextWrapping="Wrap"
                                                   Text="{Binding ActiveFile}"/>

                                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding SpeedText}"
                                                       FontSize="11"
                                                       Foreground="{StaticResource TextMuted}"
                                                       Margin="0,0,12,0"
                                                       VerticalAlignment="Center"
                                                       Visibility="{Binding SpeedText, Converter={StaticResource NotEmptyToVis}}"/>
                                            <TextBlock FontSize="11" FontWeight="Bold"
                                                       Foreground="{StaticResource TextSecondary}"
                                                       VerticalAlignment="Center">
                                                <Run Text="{Binding Percent, StringFormat={}{0:F1}}"/>
                                                <Run Text="%"/>
                                            </TextBlock>
                                        </StackPanel>
                                    </Grid>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <!-- Success banner -->
            <Border Grid.Row="6"
                    CornerRadius="12" Padding="20,14"
                    Background="{StaticResource SuccessBg}"
                    BorderBrush="#C5E1D4"
                    BorderThickness="1"
                    Visibility="{Binding DownloadComplete, Converter={StaticResource BoolToVis}}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="✓ " Foreground="{StaticResource Success}"
                                   FontWeight="Bold" FontSize="16" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding CompletionMessage}"
                                   Foreground="{StaticResource Success}"
                                   FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    </StackPanel>
                    <Button Grid.Column="1"
                            Style="{StaticResource BtnSecondary}"
                            Command="{Binding StartNewCommand}"
                            Padding="18,8" Height="36">
                        <TextBlock Text="New Download" FontSize="12" FontWeight="SemiBold"/>
                    </Button>
                </Grid>
            </Border>

            <!-- Failure banner -->
            <Border Grid.Row="6"
                    CornerRadius="12" Padding="20,14"
                    Background="{StaticResource ErrorBg}"
                    BorderBrush="#EBC5C1"
                    BorderThickness="1"
                    Visibility="{Binding DownloadFailed, Converter={StaticResource BoolToVis}}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="⚠ " Foreground="{StaticResource Error}"
                                   FontWeight="Bold" FontSize="16" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="{Binding CompletionMessage}"
                                   Foreground="{StaticResource Error}"
                                   FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <Button Style="{StaticResource BtnSecondary}"
                                Command="{Binding RetryFailedAsyncCommand}"
                                Padding="18,8" Height="36" Margin="0,0,8,0">
                            <StackPanel Orientation="Horizontal">
                                <Path Data="{StaticResource LucideRefreshCw}"
                                      Width="12" Height="12" Stretch="Uniform" Margin="0,0,6,0"
                                      Stroke="{StaticResource TextPrimary}" StrokeThickness="1.7" Fill="Transparent"
                                      StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"/>
                                <TextBlock Text="Retry Failed" FontSize="12" FontWeight="SemiBold"/>
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource BtnSecondary}"
                                Command="{Binding StartNewCommand}"
                                Padding="18,8" Height="36">
                            <TextBlock Text="New Download" FontSize="12" FontWeight="SemiBold"/>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

    </Grid>
</UserControl>
