<Window x:Class="DepotDL.GUI.MainWindow"
        xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="using:DepotDL.GUI.Views"
        Title="DepotDL"
        Width="1280" Height="780"
        MinWidth="960" MinHeight="620"
        WindowStartupLocation="CenterScreen"
        SystemDecorations="None"
        TransparencyLevelHint="Transparent"
        Background="Transparent"
        FontFamily="Inter,Segoe UI"
        UseLayoutRounding="True">

    <Window.Resources>
        <!-- NavItem ControlTheme -->
        <ControlTheme x:Key="NavItem" TargetType="Button">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="0,1"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <ControlTemplate TargetType="Button">
                    <Border Name="bg" Background="{TemplateBinding Background}"
                            CornerRadius="10" Padding="12,9">
                        <Border.Transitions>
                            <Transitions>
                                <BrushTransition Property="Background" Duration="0:0:0.15"/>
                            </Transitions>
                        </Border.Transitions>
                        <ContentPresenter Name="PART_ContentPresenter"
                                          Content="{TemplateBinding Content}"
                                          ContentTemplate="{TemplateBinding ContentTemplate}"
                                          HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}"/>
                    </Border>
                </ControlTemplate>
            </Setter>
            <Style Selector="^:pointerover /template/ Border#bg">
                <Setter Property="Background" Value="{StaticResource Border}"/>
            </Style>
        </ControlTheme>
        <!-- ChromeBtn ControlTheme -->
        <ControlTheme x:Key="ChromeBtn" TargetType="Button">
            <Setter Property="Width" Value="28"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <ControlTemplate TargetType="Button">
                    <Border Name="bg" Background="{TemplateBinding Background}" CornerRadius="8">
                        <Border.Transitions>
                            <Transitions>
                                <BrushTransition Property="Background" Duration="0:0:0.15"/>
                            </Transitions>
                        </Border.Transitions>
                        <ContentPresenter Name="PART_ContentPresenter"
                                          Content="{TemplateBinding Content}"
                                          ContentTemplate="{TemplateBinding ContentTemplate}"
                                          HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Setter>
            <Style Selector="^:pointerover /template/ Border#bg">
                <Setter Property="Background" Value="{StaticResource Border}"/>
            </Style>
        </ControlTheme>
    </Window.Resources>

    <Window.Styles>
        <Style Selector="Button.navActive /template/ Border#bg">
            <Setter Property="Background" Value="{StaticResource AccentLight}"/>
        </Style>

        <!-- Default/Inactive styling -->
        <Style Selector="Border.navIndicator">
            <Setter Property="Background" Value="Transparent"/>
        </Style>
        <Style Selector="Path.navIcon">
            <Setter Property="Stroke" Value="{StaticResource TextMuted}"/>
        </Style>
        <Style Selector="Path.navIconFill">
            <Setter Property="Fill" Value="{StaticResource TextMuted}"/>
        </Style>
        <Style Selector="TextBlock.navText">
            <Setter Property="Foreground" Value="{StaticResource TextBody}"/>
            <Setter Property="FontWeight" Value="Normal"/>
        </Style>

        <!-- Active styling -->
        <Style Selector="Button.navActive Border.navIndicator">
            <Setter Property="Background" Value="{StaticResource Accent}"/>
        </Style>
        <Style Selector="Button.navActive Path.navIcon">
            <Setter Property="Stroke" Value="{StaticResource Accent}"/>
        </Style>
        <Style Selector="Button.navActive Path.navIconFill">
            <Setter Property="Fill" Value="{StaticResource Accent}"/>
        </Style>
        <Style Selector="Button.navActive TextBlock.navText">
            <Setter Property="Foreground" Value="{StaticResource Accent}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
    </Window.Styles>

    <Border Name="RootBorder"
            CornerRadius="14"
            Background="{StaticResource BgPage}"
            BorderBrush="{StaticResource Border}"
            BorderThickness="1">
        <Grid Name="ContentGrid">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="210"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ── Sidebar ─────────────────────────────────────────── -->
            <Border Grid.Column="0"
                    Background="{StaticResource BgSidebar}"
                    CornerRadius="14,0,0,14"
                    BorderThickness="0,0,1,0"
                    BorderBrush="{StaticResource Border}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="54"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Titlebar drag area + logo -->
                    <Border Grid.Row="0" Background="Transparent"
                            PointerPressed="TitleBar_PointerPressed">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="16,0">
                            <Border Width="32" Height="32" CornerRadius="9"
                                    Background="{StaticResource Accent}" Margin="0,0,10,0">
                                <TextBlock Text="D" FontSize="16" FontWeight="Bold"
                                           Foreground="White"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="DepotDL" FontSize="14" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextH}"/>
                                <TextBlock Text="Game Downloader" FontSize="9.5"
                                           Foreground="{StaticResource TextMuted}"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Nav items -->
                    <StackPanel Grid.Row="1" Margin="10,6,10,0">

                        <Button Theme="{StaticResource NavItem}"
                                Command="{Binding NavigateStoreCommand}"
                                Classes.navActive="{Binding IsStorePage}">
                            <StackPanel Orientation="Horizontal">
                                <Border Classes="navIndicator" Width="3" Height="18" CornerRadius="2" Margin="0,0,10,0"/>
                                <Path Classes="navIcon" Data="{StaticResource LucideShoppingBag}"
                                      Width="16" Height="16" Stretch="Uniform" Margin="0,0,10,0"
                                      StrokeThickness="1.7" StrokeLineCap="Round"
                                      StrokeJoin="Round" Fill="Transparent"/>
                                <TextBlock Classes="navText" Text="Store" FontSize="13" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Button Theme="{StaticResource NavItem}"
                                Command="{Binding NavigateLibraryCommand}"
                                Classes.navActive="{Binding IsLibraryPage}">
                            <StackPanel Orientation="Horizontal">
                                <Border Classes="navIndicator" Width="3" Height="18" CornerRadius="2" Margin="0,0,10,0"/>
                                <Path Classes="navIconFill" Data="{StaticResource LucideLayoutGrid}"
                                      Width="16" Height="16" Stretch="Uniform" Margin="0,0,10,0"
                                      StrokeThickness="0"/>
                                <TextBlock Classes="navText" Text="Library" FontSize="13" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Button Theme="{StaticResource NavItem}"
                                Command="{Binding NavigateDownloadCommand}"
                                Classes.navActive="{Binding IsDownloadPage}">
                            <StackPanel Orientation="Horizontal">
                                <Border Classes="navIndicator" Width="3" Height="18" CornerRadius="2" Margin="0,0,10,0"/>
                                <Path Classes="navIcon" Data="{StaticResource LucideDownload}"
                                      Width="16" Height="16" Stretch="Uniform" Margin="0,0,10,0"
                                      StrokeThickness="1.7" StrokeLineCap="Round"
                                      StrokeJoin="Round" Fill="Transparent"/>
                                <TextBlock Classes="navText" Text="Download" FontSize="13" VerticalAlignment="Center"/>
                                <Border Width="8" Height="8" CornerRadius="4"
                                        Background="{StaticResource Accent}"
                                        Margin="7,0,0,0" VerticalAlignment="Center"
                                        IsVisible="{Binding Download.IsDownloading}">
                                    <Border.Styles>
                                        <Style Selector="Border">
                                            <Style.Animations>
                                                <Animation IterationCount="INFINITE" PlaybackDirection="Alternate" Duration="0:0:0.85">
                                                    <KeyFrame Cue="0%"><Setter Property="Opacity" Value="1"/></KeyFrame>
                                                    <KeyFrame Cue="100%"><Setter Property="Opacity" Value="0.25"/></KeyFrame>
                                                </Animation>
                                            </Style.Animations>
                                        </Style>
                                    </Border.Styles>
                                </Border>
                            </StackPanel>
                        </Button>

                    </StackPanel>

                    <!-- Settings nav (bottom) -->
                    <StackPanel Grid.Row="2" Margin="10,0,10,14">
                        <Button Theme="{StaticResource NavItem}"
                                Command="{Binding NavigateSettingsCommand}"
                                Classes.navActive="{Binding IsSettingsPage}">
                            <StackPanel Orientation="Horizontal">
                                <Border Classes="navIndicator" Width="3" Height="18" CornerRadius="2" Margin="0,0,10,0"/>
                                <Path Classes="navIcon" Data="{StaticResource LucideSettings}"
                                      Width="16" Height="16" Stretch="Uniform" Margin="0,0,10,0"
                                      StrokeThickness="1.5" StrokeLineCap="Round"
                                      StrokeJoin="Round" Fill="Transparent"/>
                                <TextBlock Classes="navText" Text="Settings" FontSize="13" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ── Content area ────────────────────────────────────── -->
            <Border Grid.Column="1" Background="{StaticResource BgPage}" CornerRadius="0,14,14,0">
                <Grid ClipToBounds="True">

                    <!-- Titlebar drag strip (right side) -->
                    <Border Height="40" Background="Transparent" VerticalAlignment="Top"
                            PointerPressed="TitleBar_PointerPressed"/>

                    <!-- Chrome buttons -->
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Top"
                                Margin="0,10,14,0"
                                ZIndex="10">
                        <Button Theme="{StaticResource ChromeBtn}" Click="MinimizeBtn_Click">
                            <Path Data="{StaticResource LucideMinus}" Width="10" Height="10" Stretch="Uniform"
                                  Stroke="{StaticResource TextMuted}" StrokeThickness="1.5"
                                  StrokeLineCap="Round" StrokeJoin="Round" Fill="Transparent"/>
                        </Button>
                        <Button Theme="{StaticResource ChromeBtn}" Click="MaximizeBtn_Click" Margin="4,0">
                            <Path Data="{StaticResource LucideSquare}" Width="10" Height="10" Stretch="Uniform"
                                  Stroke="{StaticResource TextMuted}" StrokeThickness="1.5" Fill="Transparent"/>
                        </Button>
                        <Button Theme="{StaticResource ChromeBtn}" Click="CloseBtn_Click">
                            <Path Data="{StaticResource LucideX}" Width="10" Height="10" Stretch="Uniform"
                                  Stroke="{StaticResource TextMuted}" StrokeThickness="1.5"
                                  StrokeLineCap="Round" StrokeJoin="Round" Fill="Transparent"/>
                        </Button>
                    </StackPanel>

                    <!-- Page views -->
                    <views:StoreView    Name="StoreViewEl"    DataContext="{Binding Store}"    IsVisible="False" Opacity="0">
                        <views:StoreView.Transitions>
                            <Transitions>
                                <DoubleTransition Property="Opacity" Duration="0:0:0.15"/>
                            </Transitions>
                        </views:StoreView.Transitions>
                    </views:StoreView>
                    <views:LibraryView  Name="LibraryViewEl"  DataContext="{Binding Library}"  IsVisible="True"  Opacity="1">
                        <views:LibraryView.Transitions>
                            <Transitions>
                                <DoubleTransition Property="Opacity" Duration="0:0:0.15"/>
                            </Transitions>
                        </views:LibraryView.Transitions>
                    </views:LibraryView>
                    <views:DownloadView Name="DownloadViewEl" DataContext="{Binding Download}" IsVisible="False" Opacity="0">
                        <views:DownloadView.Transitions>
                            <Transitions>
                                <DoubleTransition Property="Opacity" Duration="0:0:0.15"/>
                            </Transitions>
                        </views:DownloadView.Transitions>
                    </views:DownloadView>
                    <views:SettingsView Name="SettingsViewEl" DataContext="{Binding Settings}" IsVisible="False" Opacity="0">
                        <views:SettingsView.Transitions>
                            <Transitions>
                                <DoubleTransition Property="Opacity" Duration="0:0:0.15"/>
                            </Transitions>
                        </views:SettingsView.Transitions>
                    </views:SettingsView>

                    <!-- Update notification banner -->
                    <Border VerticalAlignment="Bottom" HorizontalAlignment="Left"
                            Margin="16,0,0,16" ZIndex="6" CornerRadius="12"
                            BorderThickness="1" BorderBrush="#DDB060" Background="#FEF3E2"
                            MaxWidth="420" Padding="14,10"
                            IsVisible="{Binding UpdateAvailable}">
                        <StackPanel>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <Path Grid.Column="0" Data="{StaticResource LucideAlertTriangle}"
                                      Width="15" Height="15" Stretch="Uniform" Margin="0,0,10,0"
                                      Stroke="#C07012" StrokeThickness="1.8" Fill="Transparent"
                                      StrokeLineCap="Round" StrokeJoin="Round"/>

                                <TextBlock Grid.Column="1"
                                           Text="{Binding UpdateBannerText}"
                                           FontSize="12.5" Foreground="#7A5500"
                                           VerticalAlignment="Center"
                                           TextTrimming="CharacterEllipsis"/>

                                <Button Grid.Column="3"
                                        Command="{Binding InstallUpdateCommand}"
                                        Background="Transparent" BorderThickness="0"
                                        Cursor="Hand" Padding="0"
                                        IsEnabled="{Binding IsUpdating, Converter={StaticResource InvBool}}"
                                        IsVisible="{Binding CanInstallUpdate}">
                                    <TextBlock FontSize="12" Foreground="#1A73E8"
                                               TextDecorations="Underline" VerticalAlignment="Center"
                                               Text="{Binding IsUpdating, Converter={StaticResource BoolToVis}}"
                                               Classes.updating="{Binding IsUpdating}">
                                        <TextBlock.Styles>
                                            <Style Selector="TextBlock"><Setter Property="Text" Value="Install update"/></Style>
                                            <Style Selector="TextBlock.updating">
                                                <Setter Property="Text" Value="{Binding UpdateProgress, StringFormat='Downloading… {0}%'}"/>
                                            </Style>
                                        </TextBlock.Styles>
                                    </TextBlock>
                                </Button>

                                <Button Grid.Column="5"
                                        Command="{Binding OpenUpdateUrlCommand}"
                                        Background="Transparent" BorderThickness="0"
                                        Cursor="Hand" Padding="0">
                                    <TextBlock Text="View release" FontSize="12"
                                               Foreground="#1A73E8"
                                               TextDecorations="Underline"
                                               VerticalAlignment="Center"/>
                                </Button>

                                <Button Grid.Column="7"
                                        Command="{Binding DismissUpdateCommand}"
                                        Background="Transparent" BorderThickness="0"
                                        Cursor="Hand" Padding="2,0" VerticalAlignment="Center"
                                        IsEnabled="{Binding IsUpdating, Converter={StaticResource InvBool}}">
                                    <Path Data="{StaticResource LucideX}"
                                          Width="8" Height="8" Stretch="Uniform"
                                          Stroke="#9C8E82" StrokeThickness="1.5"
                                          StrokeLineCap="Round" StrokeJoin="Round" Fill="Transparent"/>
                                </Button>
                            </Grid>

                            <ProgressBar Height="3" Margin="0,6,0,0" Minimum="0" Maximum="100"
                                         Value="{Binding UpdateProgress}"
                                         Foreground="#C07012" Background="#F5E0B0" BorderThickness="0"
                                         CornerRadius="1.5"
                                         IsVisible="{Binding IsUpdating}"/>
                        </StackPanel>
                    </Border>

                    <!-- Floating widgets (bottom-right) -->
                    <StackPanel HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                Margin="0,0,24,24" ZIndex="5">

                        <!-- Pack progress widget -->
                        <Border Margin="0,0,0,10"
                                IsVisible="{Binding ShowPackWidget}">
                            <Border Width="280" CornerRadius="14"
                                    Background="{StaticResource BgCard}"
                                    BorderBrush="{StaticResource Border}"
                                    BorderThickness="1"
                                    Padding="16,14">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="3"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="10"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Grid Grid.Row="0">
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                            <Path Data="{StaticResource LucidePackage}"
                                                  Width="13" Height="13" Stretch="Uniform" Margin="0,0,7,0"
                                                  Stroke="{StaticResource Accent}" StrokeThickness="1.7"
                                                  Fill="Transparent" StrokeLineCap="Round"
                                                  StrokeJoin="Round"/>
                                            <TextBlock FontSize="12.5" FontWeight="SemiBold"
                                                       Foreground="{StaticResource TextPrimary}"
                                                       VerticalAlignment="Center"
                                                       Text="{Binding Library.PackGameName}"
                                                       MaxWidth="150"
                                                       TextTrimming="CharacterEllipsis"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                            <TextBlock FontSize="13" FontWeight="Bold"
                                                       Foreground="{StaticResource Accent}" VerticalAlignment="Center"
                                                       Margin="0,0,6,0">
                                                <Run Text="{Binding Library.PackPercent, StringFormat='{}{0:F0}'}"/>
                                                <Run Text="%"/>
                                            </TextBlock>
                                            <Button Command="{Binding Library.CancelPackCommand}"
                                                    Width="18" Height="18" Padding="0"
                                                    Background="Transparent" BorderThickness="0"
                                                    Cursor="Hand" ToolTip.Tip="Cancel and delete unfinished pack">
                                                <Path Data="{StaticResource LucideX}"
                                                      Width="10" Height="10" Stretch="Uniform"
                                                      Stroke="{StaticResource TextMuted}" StrokeThickness="2"
                                                      Fill="Transparent" StrokeLineCap="Round"
                                                      StrokeJoin="Round"/>
                                            </Button>
                                        </StackPanel>
                                    </Grid>
                                    <TextBlock Grid.Row="2"
                                               Text="{Binding Library.PackStatus}"
                                               FontSize="10.5" Foreground="{StaticResource TextMuted}"
                                               TextTrimming="CharacterEllipsis"/>
                                    <ProgressBar Grid.Row="4" Height="6" Minimum="0" Maximum="100"
                                                 Value="{Binding Library.PackPercent}"
                                                 Foreground="{StaticResource Accent}"
                                                 Background="{StaticResource AccentVeryLight}"
                                                 CornerRadius="3" BorderThickness="0"/>
                                </Grid>
                            </Border>
                        </Border>

                        <!-- OnlineFix progress widget -->
                        <Border Margin="0,0,0,10"
                                IsVisible="{Binding ShowOnlineFixWidget}">
                            <Border Width="280" CornerRadius="14"
                                    Background="{StaticResource BgCard}"
                                    BorderBrush="{StaticResource Border}"
                                    BorderThickness="1"
                                    Padding="16,14">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="8"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Grid Grid.Row="0">
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                            <Path Data="{StaticResource LucideDownload}"
                                                  Width="13" Height="13" Stretch="Uniform" Margin="0,0,7,0"
                                                  Stroke="{StaticResource Accent}" StrokeThickness="1.7"
                                                  Fill="Transparent" StrokeLineCap="Round"
                                                  StrokeJoin="Round"/>
                                            <TextBlock FontSize="12.5" FontWeight="SemiBold"
                                                       Foreground="{StaticResource TextPrimary}"
                                                       VerticalAlignment="Center"
                                                       Text="OnlineFix"/>
                                        </StackPanel>
                                        <TextBlock HorizontalAlignment="Right" FontSize="11.5"
                                                   Foreground="{StaticResource Accent}" VerticalAlignment="Center"
                                                   Text="{Binding Library.OnlineFixGameName}"
                                                   MaxWidth="100" TextTrimming="CharacterEllipsis"/>
                                    </Grid>
                                    <TextBlock Grid.Row="2"
                                               Text="{Binding Library.OnlineFixStatus}"
                                               FontSize="10.5" Foreground="{StaticResource TextMuted}"
                                               TextTrimming="CharacterEllipsis"/>
                                </Grid>
                            </Border>
                        </Border>

                        <!-- Floating download widget -->
                        <Border IsVisible="{Binding ShowDownloadWidget}">
                            <Button Command="{Binding NavigateDownloadCommand}"
                                    BorderThickness="0" Background="Transparent"
                                    Padding="0" Cursor="Hand">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <ContentPresenter Name="PART_ContentPresenter"
                                                          Content="{TemplateBinding Content}"
                                                          ContentTemplate="{TemplateBinding ContentTemplate}"/>
                                    </ControlTemplate>
                                </Button.Template>
                                <Border Width="280" CornerRadius="14"
                                        Background="{StaticResource BgCard}"
                                        BorderBrush="{StaticResource Border}"
                                        BorderThickness="1"
                                        Padding="16,14">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="3"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="10"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="8"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <Grid Grid.Row="0">
                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                <Path Data="{StaticResource LucideDownload}"
                                                      Width="13" Height="13" Stretch="Uniform" Margin="0,0,7,0"
                                                      Stroke="{StaticResource Accent}" StrokeThickness="1.7"
                                                      Fill="Transparent" StrokeLineCap="Round"
                                                      StrokeJoin="Round"/>
                                                <TextBlock FontSize="12.5" FontWeight="SemiBold"
                                                           Foreground="{StaticResource TextPrimary}"
                                                           VerticalAlignment="Center">
                                                    <Run Text="App "/>
                                                    <Run Text="{Binding Download.AppId}" Foreground="{StaticResource Accent}"/>
                                                </TextBlock>
                                            </StackPanel>
                                            <TextBlock HorizontalAlignment="Right" FontSize="13" FontWeight="Bold"
                                                       Foreground="{StaticResource Accent}" VerticalAlignment="Center">
                                                <Run Text="{Binding Download.OverallDisplayPercent, StringFormat='{}{0:F0}'}"/>
                                                <Run Text="%"/>
                                            </TextBlock>
                                        </Grid>
                                        <TextBlock Grid.Row="2"
                                                   Text="{Binding Download.OverallStatus}"
                                                   FontSize="10.5" Foreground="{StaticResource TextMuted}"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <ProgressBar Grid.Row="4" Height="6" Minimum="0" Maximum="100"
                                                     Value="{Binding Download.OverallDisplayPercent}"
                                                     Foreground="{StaticResource Accent}"
                                                     Background="{StaticResource AccentVeryLight}"
                                                     CornerRadius="3" BorderThickness="0"/>
                                        <TextBlock Grid.Row="6"
                                                   Text="Click to view →" FontSize="10.5"
                                                   Foreground="{StaticResource TextMuted}"
                                                   HorizontalAlignment="Right"/>
                                    </Grid>
                                </Border>
                            </Button>
                        </Border>

                    </StackPanel>
                </Grid>
            </Border>

            <!-- ── Splash overlay ─────────────────────────────────── -->
            <Border Name="SplashOverlay"
                    Grid.ColumnSpan="2"
                    CornerRadius="14"
                    ZIndex="100"
                    RenderTransformOrigin="0.5,0.5">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0%,0%" EndPoint="0%,100%">
                        <GradientStop Color="#FEFCF8" Offset="0"/>
                        <GradientStop Color="#F5F0E8" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Border.RenderTransform>
                    <TransformGroup>
                        <ScaleTransform ScaleX="1" ScaleY="1"/>
                        <TranslateTransform Y="0"/>
                    </TransformGroup>
                </Border.RenderTransform>
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <Border Width="80" Height="80" CornerRadius="40"
                            Background="{StaticResource Accent}"
                            HorizontalAlignment="Center" Margin="0,0,0,24"
                            BoxShadow="0 3 25 3 #4DC07840">
                        <TextBlock Text="D" FontSize="36" FontWeight="Bold" Foreground="White"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="DepotDL" FontSize="24" FontWeight="Bold"
                               Foreground="{StaticResource TextH}" HorizontalAlignment="Center"
                               Margin="0,0,0,6"/>
                    <TextBlock Name="SplashStatus"
                               Text="Booting download engine..."
                               FontSize="12" Foreground="{StaticResource TextSecondary}"
                               HorizontalAlignment="Center" Margin="0,0,0,32"/>
                    <Border Width="200" Height="3" CornerRadius="1.5"
                            Background="{StaticResource AccentLight}"
                            HorizontalAlignment="Center">
                        <Border Name="SplashProgressBar"
                                Width="0" Height="3" CornerRadius="1.5"
                                Background="{StaticResource Accent}"
                                HorizontalAlignment="Left"/>
                    </Border>
                </StackPanel>
            </Border>

        </Grid>
    </Border>
</Window>
